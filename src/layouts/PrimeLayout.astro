---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="description" content="3 Lines. 1 Minute. The path to self-metamorphosis." />
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/prime-manifest.json" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <title>{title} | NANOPRIME</title>
  </head>
  <body class="prime-app">
    <main>
      <slot />
    </main>

    <nav class="prime-nav">
      <a href="/prime/" class="nav-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
        <span>Daily</span>
      </a>
      <a href="/prime/history/" class="nav-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
        <span>History</span>
      </a>
    </nav>

    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/prime-sw.js')
            .then(registration => console.log('PWA ServiceWorker registered'))
            .catch(err => console.log('PWA ServiceWorker registration failed: ', err));
        });
      }

      // Nav highlighting based on current path
      const path = window.location.pathname;
      document.querySelectorAll('.nav-btn').forEach(btn => {
        if (btn.getAttribute('href') === path || (path === '/prime' && btn.getAttribute('href') === '/prime/')) {
          btn.classList.add('active');
        }
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --p-bg: #0a0a0f;
    --p-bg2: #111118;
    --p-bdr: rgba(255,255,255,0.08);
    --p-gold: #D4A843;
    --p-blue: #2874A6;
    --p-green: #27AE60;
    --p-t1: #f0f0f5;
    --p-t2: #c4c9d1;
    --p-t3: #8B949E;
  }
  
  * { box-sizing: border-box; margin: 0; padding: 0; }
  
  html, body {
    height: 100%;
    width: 100%;
    background: var(--p-bg);
    color: var(--p-t1);
    font-family: 'Inter', -apple-system, sans-serif;
    -webkit-font-smoothing: antialiased;
    overflow: hidden; /* App mode */
  }

  main {
    height: calc(100% - 65px);
    overflow-y: auto;
    padding: 2rem 1.5rem 4rem;
    -webkit-overflow-scrolling: touch;
  }

  .prime-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 65px;
    background: var(--p-bg2);
    border-top: 1px solid var(--p-bdr);
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding-bottom: env(safe-area-inset-bottom); /* For iOS notch */
    z-index: 100;
  }

  .nav-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    color: var(--p-t3);
    text-decoration: none;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
    width: 60px;
    transition: color 0.2s;
  }

  .nav-btn svg {
    opacity: 0.7;
    transition: opacity 0.2s, stroke 0.2s;
  }

  .nav-btn.active {
    color: #fff;
  }
  .nav-btn.active svg {
    opacity: 1;
    stroke: var(--p-gold);
  }
</style>
