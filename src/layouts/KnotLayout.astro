---
import Base from "./Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import TamilRoot from "../components/TamilRoot.astro";

interface Props {
  title: string;
  description: string;
  knotNumber: number;
  series: string;
  seriesNumber: number;
  punchLine1: string;
  punchLine2: string;
  feltHook?: string;
  kuralTamil?: string;
  kuralTranslation?: string;
  kuralNumber?: number;
  kuralBridge?: string;
  prevKnot?: string;
  prevKnotTitle?: string;
  nextKnot?: string;
  nextKnotTitle?: string;
}

const {
  title,
  description,
  knotNumber,
  series,
  seriesNumber,
  punchLine1,
  punchLine2,
  feltHook,
  kuralTamil,
  kuralTranslation,
  kuralNumber,
  kuralBridge,
  prevKnot,
  prevKnotTitle,
  nextKnot,
  nextKnotTitle,
} = Astro.props;

const paddedNum = String(knotNumber).padStart(3, "0");

// Build display title
const displayTitle = title.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());

// Series color mapping (MBS aligned)
const seriesColors: Record<string, string> = {
  identity: "var(--soul-color)",
  culture: "var(--soul-color)",
  trust: "var(--soul-color)",
  decisions: "var(--mind-color)",
  change: "var(--mind-color)",
  intelligence: "var(--mind-color)",
  structure: "var(--body-color)",
  capability: "var(--body-color)",
  energy: "var(--body-color)",
};

const accentColor = seriesColors[series] || "var(--accent)";
---

<Base
  title={`KNOT #${paddedNum}: ${title}`}
  description={description}
>
  <Header activeNav="knots" />
  <main class="knot-page">
    <article class="container container--narrow">

      <!-- Series Badge + Knot Number -->
      <header class="knot-header animate-in">
        <div class="knot-badge">
          <span class="series-label" style={`color: ${accentColor}`}>
            Untangling {series.charAt(0).toUpperCase() + series.slice(1)}
          </span>
          <span class="knot-num" style={`color: ${accentColor}`}>
            KNOT #{paddedNum}
          </span>
        </div>
        <h1>{displayTitle}</h1>
        {feltHook && <p class="felt-hook">{feltHook}</p>}
      </header>

      <!-- 3-Layer Palm Manuscript: Soul (Kural) → Mind (Knot Name) → Body (Bridge) -->
      {kuralTamil ? (
        <div class="knot-manuscript animate-in animate-delay-1">
          <TamilRoot
            tamil={displayTitle}
            transliteration={`Knot #${paddedNum}`}
            meaning={kuralBridge || punchLine2}
            kural={kuralTamil}
            kuralNumber={kuralNumber}
            kuralTranslation={kuralTranslation}
          />
        </div>
      ) : (
        <div class="punch-block animate-in animate-delay-1" style={`border-color: ${accentColor}`}>
          <p class="punch-line-1">{punchLine1}</p>
          <p class="punch-line-2" style={`color: ${accentColor}`}>{punchLine2}</p>
        </div>
      )}

      <!-- Story + Content -->
      <section class="knot-body animate-in animate-delay-2">
        <slot />
      </section>

      <!-- Navigation: Prev / Index / Next -->
      <nav class="knot-nav">
        <div class="knot-nav-links">
          {prevKnot ? (
            <a href={`/knots/${prevKnot}`} class="nav-link nav-link--prev" style={`border-color: ${accentColor}`}>
              <span class="nav-arrow">←</span>
              <div class="nav-text">
                <span class="nav-label">Previous Knot</span>
                <span class="nav-title">{prevKnotTitle || prevKnot}</span>
              </div>
            </a>
          ) : (
            <div class="nav-link nav-link--empty"></div>
          )}

          {nextKnot ? (
            <a href={`/knots/${nextKnot}`} class="nav-link nav-link--next" style={`border-color: ${accentColor}`}>
              <div class="nav-text">
                <span class="nav-label">Next Knot</span>
                <span class="nav-title">{nextKnotTitle || nextKnot}</span>
              </div>
              <span class="nav-arrow">→</span>
            </a>
          ) : (
            <div class="nav-link nav-link--empty"></div>
          )}
        </div>

        <div class="knot-ctas">
          <a href="/knots/" class="btn">All 108 Knots</a>
        </div>
      </nav>

    </article>
  </main>
  <Footer />
</Base>

<style define:vars={{ accentColor }}>
  .knot-page {
    padding: var(--space-3xl) 0;
  }

  /* ── Header ──────────────────────────────────── */
  .knot-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .knot-badge {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-lg);
  }

  .series-label {
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .knot-num {
    font-family: var(--font-label);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .knot-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--text-primary) !important;
    text-transform: capitalize;
    margin-bottom: var(--space-md);
  }

  .felt-hook {
    font-style: italic;
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  /* ── PUNCH Block ─────────────────────────────── */
  .punch-block {
    text-align: center;
    padding: var(--space-3xl) var(--space-xl);
    margin: var(--space-2xl) 0 var(--space-3xl);
    border-top: 1px solid;
    border-bottom: 1px solid;
    border-color: rgba(255, 255, 255, 0.08);
  }

  .punch-line-1 {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
    margin-bottom: var(--space-xl);
  }

  .punch-line-2 {
    font-family: var(--font-heading);
    font-size: clamp(1.3rem, 3.5vw, 1.8rem);
    font-weight: 600;
    line-height: 1.3;
  }

  /* ── Body (rendered markdown) ────────────────── */
  .knot-body {
    max-width: 680px;
    margin: 0 auto;
  }

  .knot-body :global(h2) {
    font-size: 1.4rem;
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-md);
    color: var(--accentColor, var(--accent)) !important;
  }

  .knot-body :global(p) {
    font-size: 1.05rem;
    line-height: 1.85;
    margin-bottom: var(--space-lg);
  }

  .knot-body :global(strong) {
    color: var(--text-primary);
  }

  .knot-body :global(blockquote) {
    border-left: 3px solid var(--accentColor, var(--accent));
    padding-left: var(--space-lg);
    margin: var(--space-xl) 0;
    font-style: italic;
    color: var(--text-secondary);
  }

  .knot-body :global(hr) {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin: var(--space-3xl) 0;
  }

  /* ── Navigation ──────────────────────────────── */
  .knot-nav {
    margin-top: var(--space-4xl);
    padding-top: var(--space-2xl);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .knot-nav-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg);
    border: 1px solid;
    border-radius: var(--border-radius);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .nav-link:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.02);
    text-decoration: none;
  }

  .nav-link--prev {
    justify-content: flex-start;
  }

  .nav-link--next {
    justify-content: flex-end;
    text-align: right;
  }

  .nav-link--empty {
    border: none;
  }

  .nav-arrow {
    font-size: 1.5rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .nav-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .nav-label {
    font-family: var(--font-label);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .nav-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    text-transform: capitalize;
  }

  .knot-ctas {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    margin-top: var(--space-lg);
  }

  @media (max-width: 768px) {
    .knot-badge {
      flex-direction: column;
      gap: var(--space-xs);
    }

    .punch-block {
      padding: var(--space-2xl) var(--space-md);
    }

    .knot-nav-links {
      grid-template-columns: 1fr;
    }

    .nav-link--next {
      justify-content: flex-start;
      text-align: left;
    }
  }
</style>
