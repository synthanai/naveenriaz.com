---
import Base from "./Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import TamilRoot from "../components/TamilRoot.astro";
import OuroborosFooter from "../components/OuroborosFooter.astro";

interface Props {
  title: string;
  description: string;
  knotNumber: number;
  series: string;
  seriesNumber: number;
  punchLine1: string;
  punchLine2: string;
  feltHook?: string;
  kuralTamil?: string;
  kuralTranslation?: string;
  kuralNumber?: number;
  kuralBridge?: string;
  prevKnot?: string;
  prevKnotTitle?: string;
  nextKnot?: string;
  nextKnotTitle?: string;
}

const {
  title,
  description,
  knotNumber,
  series,
  seriesNumber,
  punchLine1,
  punchLine2,
  feltHook,
  kuralTamil,
  kuralTranslation,
  kuralNumber,
  kuralBridge,
  prevKnot,
  prevKnotTitle,
  nextKnot,
  nextKnotTitle,
} = Astro.props;

const paddedNum = String(knotNumber).padStart(3, "0");

// Build display title
const displayTitle = title.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());

// Series color mapping (MBS aligned)
const seriesColors: Record<string, string> = {
  identity: "var(--soul-color)",
  culture: "var(--soul-color)",
  trust: "var(--soul-color)",
  decisions: "var(--mind-color)",
  change: "var(--mind-color)",
  intelligence: "var(--mind-color)",
  structure: "var(--body-color)",
  capability: "var(--body-color)",
  energy: "var(--body-color)",
};

const accentColor = seriesColors[series] || "var(--accent)";
---

<Base
  title={`KNOT #${paddedNum}: ${title}`}
  description={description}
>
  <Header activeNav="knots" />
  <main class="knot-page">
    <article class="container container--narrow">

      <!-- Series Badge + Knot Number -->
      <header class="knot-header animate-in">
        <div class="knot-badge">
          <span class="series-label" style={`color: ${accentColor}`}>
            Untangling {series.charAt(0).toUpperCase() + series.slice(1)}
          </span>
          <span class="knot-num" style={`color: ${accentColor}`}>
            KNOT #{paddedNum}
          </span>
        </div>
        <h1>{displayTitle}</h1>
        {feltHook && <p class="felt-hook">{feltHook}</p>}
      </header>

      <!-- 3-Layer Palm Manuscript: Soul (Kural) → Mind (Knot Name) → Body (Bridge) -->
      {kuralTamil ? (
        <div class="knot-manuscript animate-in animate-delay-1">
          <TamilRoot
            tamil={displayTitle}
            transliteration={`Knot #${paddedNum}`}
            meaning={kuralBridge || punchLine2}
            kural={kuralTamil}
            kuralNumber={kuralNumber}
            kuralTranslation={kuralTranslation}
          />
        </div>
      ) : (
        <div class="punch-block animate-in animate-delay-1" style={`border-color: ${accentColor}`}>
          <p class="punch-line-1">{punchLine1}</p>
          <p class="punch-line-2" style={`color: ${accentColor}`}>{punchLine2}</p>
        </div>
      )}

      <!-- Story + Content -->
      <section class="knot-body animate-in animate-delay-2">
        <slot />
      </section>

      <script>
        // Enhance the Untie section into a visual process pipeline
        const stepMeta: Record<string, { icon: string; color: string; label: string }> = {
          'uproot': { icon: '🔍', color: 'soul', label: 'Diagnose' },
          'navigate': { icon: '🧭', color: 'soul-light', label: 'Direction' },
          'tool': { icon: '🔧', color: 'mind', label: 'Framework' },
          'implement': { icon: '⚡', color: 'body', label: 'Action' },
          'emerge': { icon: '🌱', color: 'emerge', label: 'Outcome' },
        };

        document.addEventListener('DOMContentLoaded', () => {
          const body = document.querySelector('.knot-body');
          if (!body) return;

          // Find "The Untie" heading
          const h2s = body.querySelectorAll('h2');
          let untieH2: Element | null = null;
          h2s.forEach(h => {
            if (h.textContent?.trim().toLowerCase().includes('untie')) untieH2 = h;
          });
          if (!untieH2) return;

          // Collect all siblings after the Untie heading
          const siblings: Element[] = [];
          let el = (untieH2 as Element).nextElementSibling;
          while (el) {
            siblings.push(el);
            el = el.nextElementSibling;
          }

          // Build pipeline container
          const pipeline = document.createElement('div');
          pipeline.className = 'untie-pipeline';

          let currentStep: HTMLElement | null = null;

          for (const sib of siblings) {
            const strong = sib.querySelector('strong:first-child');
            const text = strong?.textContent?.trim().toLowerCase() || '';
            const meta = stepMeta[text];

            if (strong && sib.children.length === 1 && strong === sib.firstElementChild && meta) {
              // This is a step header
              currentStep = document.createElement('div');
              currentStep.className = `untie-step untie-step--${meta.color}`;

              const header = document.createElement('div');
              header.className = 'untie-step__header';
              header.innerHTML = `
                <span class="untie-step__icon">${meta.icon}</span>
                <span class="untie-step__name">${strong.textContent?.trim()}</span>
                <span class="untie-step__label">${meta.label}</span>
              `;
              currentStep.appendChild(header);
              pipeline.appendChild(currentStep);
            } else if (currentStep) {
              // Step body paragraph
              const bodyDiv = document.createElement('div');
              bodyDiv.className = 'untie-step__body';
              bodyDiv.innerHTML = sib.innerHTML;
              currentStep.appendChild(bodyDiv);
              currentStep = null; // Reset after body collected
            }
          }

          // Replace original content with pipeline
          if (pipeline.children.length > 0) {
            // Remove old siblings
            siblings.forEach(s => s.remove());
            // Insert pipeline after the heading
            (untieH2 as Element).after(pipeline);
          }
        });
      </script>

      <!-- Navigation: Prev / Index / Next -->
      <nav class="knot-nav">
        <div class="knot-nav-links">
          {prevKnot ? (
            <a href={`/knots/${prevKnot}`} class="nav-link nav-link--prev" style={`border-color: ${accentColor}`}>
              <span class="nav-arrow">←</span>
              <div class="nav-text">
                <span class="nav-label">Previous Knot</span>
                <span class="nav-title">{prevKnotTitle || prevKnot}</span>
              </div>
            </a>
          ) : (
            <div class="nav-link nav-link--empty"></div>
          )}

          {nextKnot ? (
            <a href={`/knots/${nextKnot}`} class="nav-link nav-link--next" style={`border-color: ${accentColor}`}>
              <div class="nav-text">
                <span class="nav-label">Next Knot</span>
                <span class="nav-title">{nextKnotTitle || nextKnot}</span>
              </div>
              <span class="nav-arrow">→</span>
            </a>
          ) : (
            <div class="nav-link nav-link--empty"></div>
          )}
        </div>

        <div class="knot-ctas">
          <a href="/knots/" class="btn">All 108 Knots</a>
        </div>
      </nav>

      <OuroborosFooter collection="knots" slug={Astro.params.slug as string || Astro.url.pathname.replace(/\/$/, '').split('/').pop() || ''} />
    </article>
  </main>
  <Footer />
</Base>

<style define:vars={{ accentColor }}>
  .knot-page {
    padding: var(--space-3xl) 0;
  }

  /* ── Header ──────────────────────────────────── */
  .knot-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .knot-badge {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-lg);
  }

  .series-label {
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .knot-num {
    font-family: var(--font-label);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .knot-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--text-primary) !important;
    text-transform: capitalize;
    margin-bottom: var(--space-md);
  }

  .felt-hook {
    font-style: italic;
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  /* ── PUNCH Block ─────────────────────────────── */
  .punch-block {
    text-align: center;
    padding: var(--space-3xl) var(--space-xl);
    margin: var(--space-2xl) 0 var(--space-3xl);
    border-top: 1px solid;
    border-bottom: 1px solid;
    border-color: rgba(255, 255, 255, 0.08);
  }

  .punch-line-1 {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
    margin-bottom: var(--space-xl);
  }

  .punch-line-2 {
    font-family: var(--font-heading);
    font-size: clamp(1.3rem, 3.5vw, 1.8rem);
    font-weight: 600;
    line-height: 1.3;
  }

  /* ── Body (rendered markdown) ────────────────── */
  .knot-body {
    max-width: 680px;
    margin: 0 auto;
  }

  .knot-body :global(h2) {
    font-size: 1.4rem;
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-md);
    color: var(--accentColor, var(--accent)) !important;
  }

  .knot-body :global(p) {
    font-size: 1.05rem;
    line-height: 1.85;
    margin-bottom: var(--space-lg);
  }

  .knot-body :global(strong) {
    color: var(--text-primary);
  }

  .knot-body :global(blockquote) {
    border-left: 3px solid var(--accentColor, var(--accent));
    padding-left: var(--space-lg);
    margin: var(--space-xl) 0;
    font-style: italic;
    color: var(--text-secondary);
  }

  .knot-body :global(hr) {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin: var(--space-3xl) 0;
  }

  /* ═══════════════════════════════════════════════════
     THE UNTIE: Visual Process Pipeline
     5 steps: Uproot → Navigate → Tool → Implement → Emerge
     ═══════════════════════════════════════════════════ */

  /* Untie section header */
  .knot-body :global(h2:last-of-type) {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 800;
    text-align: center;
    letter-spacing: 0.06em;
    margin-top: var(--space-4xl);
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-md);
    border-bottom: 2px solid rgba(255, 255, 255, 0.06);
    background: linear-gradient(90deg, var(--soul-color), var(--mind-color), var(--body-color));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Pipeline Container ── */
  .knot-body :global(.untie-pipeline) {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    padding-left: 32px;
  }

  /* Vertical connector line */
  .knot-body :global(.untie-pipeline)::before {
    content: '';
    position: absolute;
    left: 11px;
    top: 16px;
    bottom: 16px;
    width: 2px;
    background: linear-gradient(
      180deg,
      var(--soul-color) 0%,
      var(--soul-color) 40%,
      var(--mind-color) 60%,
      var(--body-color) 100%
    );
    opacity: 0.25;
    border-radius: 1px;
  }

  /* ── Step Container ── */
  .knot-body :global(.untie-step) {
    position: relative;
    padding: var(--space-md) 0;
    animation: untie-fade-in 0.4s ease both;
  }

  .knot-body :global(.untie-step:nth-child(1)) { animation-delay: 0.1s; }
  .knot-body :global(.untie-step:nth-child(2)) { animation-delay: 0.2s; }
  .knot-body :global(.untie-step:nth-child(3)) { animation-delay: 0.3s; }
  .knot-body :global(.untie-step:nth-child(4)) { animation-delay: 0.4s; }
  .knot-body :global(.untie-step:nth-child(5)) { animation-delay: 0.5s; }

  @keyframes untie-fade-in {
    from { opacity: 0; transform: translateX(-8px); }
    to { opacity: 1; transform: translateX(0); }
  }

  /* ── Step Header ── */
  .knot-body :global(.untie-step__header) {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 6px;
    position: relative;
  }

  .knot-body :global(.untie-step__icon) {
    position: absolute;
    left: -32px;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    background: var(--bg-primary, #0a0a0a);
    border-radius: 50%;
    z-index: 1;
  }

  .knot-body :global(.untie-step__name) {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .knot-body :global(.untie-step__label) {
    font-family: var(--font-label);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.4;
    padding: 2px 8px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.04);
  }

  /* ── Step Body ── */
  .knot-body :global(.untie-step__body) {
    font-size: 0.92rem;
    line-height: 1.75;
    color: var(--text-secondary);
    padding-left: 0;
    padding-bottom: var(--space-sm);
  }

  /* ═══ Per-Step Color Variants ═══ */

  /* Uproot: Soul gold */
  .knot-body :global(.untie-step--soul .untie-step__name) {
    color: var(--soul-color);
  }
  .knot-body :global(.untie-step--soul .untie-step__icon) {
    border: 2px solid var(--soul-color);
    box-shadow: 0 0 8px rgba(212, 168, 67, 0.15);
  }

  /* Navigate: Soul gold (lighter) */
  .knot-body :global(.untie-step--soul-light .untie-step__name) {
    color: var(--soul-color);
    opacity: 0.8;
  }
  .knot-body :global(.untie-step--soul-light .untie-step__icon) {
    border: 2px solid var(--soul-color);
    opacity: 0.7;
  }

  /* Tool: Mind blue */
  .knot-body :global(.untie-step--mind .untie-step__name) {
    color: var(--mind-color);
  }
  .knot-body :global(.untie-step--mind .untie-step__icon) {
    border: 2px solid var(--mind-color);
    box-shadow: 0 0 8px rgba(40, 116, 166, 0.15);
  }

  /* Implement: Body green */
  .knot-body :global(.untie-step--body .untie-step__name) {
    color: var(--body-color);
  }
  .knot-body :global(.untie-step--body .untie-step__icon) {
    border: 2px solid var(--body-color);
    box-shadow: 0 0 8px rgba(39, 174, 96, 0.15);
  }

  /* Emerge: Gradient glow */
  .knot-body :global(.untie-step--emerge .untie-step__name) {
    background: linear-gradient(90deg, var(--soul-color), var(--mind-color), var(--body-color));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .knot-body :global(.untie-step--emerge .untie-step__icon) {
    border: 2px solid var(--body-color);
    box-shadow:
      0 0 6px rgba(212, 168, 67, 0.12),
      0 0 6px rgba(40, 116, 166, 0.12),
      0 0 6px rgba(39, 174, 96, 0.12);
  }

  /* ── Navigation ──────────────────────────────── */
  .knot-nav {
    margin-top: var(--space-4xl);
    padding-top: var(--space-2xl);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .knot-nav-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg);
    border: 1px solid;
    border-radius: var(--border-radius);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .nav-link:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.02);
    text-decoration: none;
  }

  .nav-link--prev {
    justify-content: flex-start;
  }

  .nav-link--next {
    justify-content: flex-end;
    text-align: right;
  }

  .nav-link--empty {
    border: none;
  }

  .nav-arrow {
    font-size: 1.5rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .nav-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .nav-label {
    font-family: var(--font-label);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .nav-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    text-transform: capitalize;
  }

  .knot-ctas {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    margin-top: var(--space-lg);
  }

  @media (max-width: 768px) {
    .knot-badge {
      flex-direction: column;
      gap: var(--space-xs);
    }

    .punch-block {
      padding: var(--space-2xl) var(--space-md);
    }

    .knot-nav-links {
      grid-template-columns: 1fr;
    }

    .nav-link--next {
      justify-content: flex-start;
      text-align: left;
    }
  }
</style>
