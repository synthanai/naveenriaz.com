---
interface Props {
  activeNav?: string;
}

const { activeNav } = Astro.props;

const parentMap: Record<string, string> = {};
const resolvedNav = parentMap[activeNav ?? ""] ?? activeNav;

const navItems = [
  {
    label: "Think",
    href: "/think/",
    id: "think",
    color: "var(--mind-color)",
    icon: "💡",
  },
  {
    label: "Play",
    href: "/play/",
    id: "play",
    color: "var(--soul-color)",
    icon: "✨",
  },
  {
    label: "Work",
    href: "/work/",
    id: "work",
    color: "var(--body-color)",
    icon: "⚡",
  },
  {
    label: "Vibe",
    href: "/vibe/",
    id: "vibe",
    color: "var(--text-primary)",
    icon: "🎯",
  },
  {
    label: "Pulse",
    href: "/pulse/",
    id: "pulse",
    color: "var(--soul-color)",
    icon: "📡",
  },
];
---

<header class="site-header" id="site-header">
  <div class="header-inner">
    <a href="/" class="header-logo" aria-label="Home">
      <img
        src="/logo.svg"
        class="logo-svg"
        width="28"
        height="28"
        alt=""
        aria-hidden="true"
      />
    </a>

    <nav class="swoosh-nav" aria-label="Main navigation">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "swoosh-tab",
              `swoosh-tab--${item.id}`,
              { active: resolvedNav === item.id },
            ]}
            style={`--tab-color: ${item.color};`}
          >
            <span class="swoosh-label">{item.label}</span>
          </a>
        ))
      }
    </nav>

    <a
      href="/about/"
      class:list={["header-about", { active: resolvedNav === "about" }]}
      aria-label="About"
    >
      <span class="about-initials">NR</span>
    </a>
  </div>
</header>

<!-- Mobile bottom tab bar (always visible on mobile) -->
<nav class="mobile-tab-bar" id="mobile-tab-bar" aria-label="Mobile navigation">
  <a href="/" class="mob-tab mob-tab--home" aria-label="Home">
    <img src="/logo.svg" width="20" height="20" alt="" aria-hidden="true" />
    <span>Home</span>
  </a>
  {
    navItems.map((item) => (
      <a
        href={item.href}
        class:list={[
          "mob-tab",
          `mob-tab--${item.id}`,
          { active: resolvedNav === item.id },
        ]}
        style={`--tab-color: ${item.color};`}
      >
        <span class="mob-icon">{item.icon}</span>
        <span>{item.label}</span>
      </a>
    ))
  }
  <a
    href="/about/"
    class:list={["mob-tab mob-tab--about", { active: resolvedNav === "about" }]}
  >
    <span class="mob-icon">👤</span>
    <span>About</span>
  </a>
</nav>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-primary);
  }

  .header-inner {
    display: flex;
    align-items: center;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* Logo: fixed left slot */
  .header-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    flex-shrink: 0;
    text-decoration: none;
    transition: opacity var(--transition-fast);
    padding: var(--space-sm) 0;
  }

  .header-logo:hover {
    opacity: 0.8;
  }

  /* Swoosh nav: tabs fill remaining width */
  .swoosh-nav {
    flex: 1;
    display: flex;
    gap: 0;
  }

  .swoosh-tab {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    position: relative;
    background: transparent;
    border: 4px solid var(--tab-color);
    border-top: none;
    color: var(--tab-color);
    padding: 0.7rem 0 1.2rem;
    border-radius: 0 0 50% 50%;
    margin: 4px;
    transition:
      background var(--transition-base),
      transform var(--transition-base);
  }

  .swoosh-tab:hover {
    text-decoration: none;
    background: rgba(255, 255, 255, 0.03);
    transform: translateY(1px);
  }

  .swoosh-tab.active {
    background: rgba(255, 255, 255, 0.05);
  }

  /* Pulse tab: MBS tri-color gradient */
  .swoosh-tab--pulse {
    border-image: linear-gradient(90deg, var(--mind-color), var(--soul-color), var(--body-color)) 1;
    border-top: none;
  }

  .swoosh-tab--pulse .swoosh-label {
    background: linear-gradient(90deg, var(--mind-color), var(--soul-color), var(--body-color));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .swoosh-label {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: var(--tab-color);
  }

  /* NR avatar */
  .header-about {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    flex-shrink: 0;
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  .header-about:hover {
    opacity: 0.8;
    text-decoration: none;
  }

  .about-initials {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--bg-primary);
    border: 2px solid var(--text-dim);
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    transition:
      border-color var(--transition-base),
      color var(--transition-base);
  }

  .header-about:hover .about-initials,
  .header-about.active .about-initials {
    border-color: var(--accent);
    color: var(--text-primary);
  }

  /* ── Mobile Bottom Tab Bar ────────────────────── */
  .mobile-tab-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: var(--bg-primary);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 6px 4px;
    padding-bottom: calc(6px + env(safe-area-inset-bottom, 0px));
  }

  .mob-tab {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    text-decoration: none;
    font-family: var(--font-label);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: rgba(255, 255, 255, 0.4);
    padding: 4px 0;
    transition: color var(--transition-fast);
  }

  .mob-tab:hover,
  .mob-tab.active {
    color: var(--tab-color, var(--accent));
    text-decoration: none;
  }

  .mob-tab--home {
    --tab-color: var(--accent);
  }

  .mob-tab--about {
    --tab-color: var(--text-primary);
  }

  .mob-icon {
    font-size: 1.1rem;
    line-height: 1;
  }

  .mob-tab img {
    opacity: 0.4;
    transition: opacity var(--transition-fast);
  }

  .mob-tab:hover img,
  .mob-tab.active img {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .swoosh-nav,
    .header-about {
      display: none;
    }

    .header-inner {
      justify-content: center;
    }

    .mobile-tab-bar {
      display: flex;
    }

    /* Push footer above the mobile tab bar */
    .site-footer {
      margin-bottom: 64px;
    }
  }
</style>
