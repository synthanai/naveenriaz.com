---
interface Props {
  activeNav?: string;
}

const { activeNav } = Astro.props;

const parentMap: Record<string, string> = {};
const resolvedNav = parentMap[activeNav ?? ""] ?? activeNav;

const navItems = [
  { label: "Think", href: "/think/", id: "think", color: "var(--mind-color)" },
  { label: "Play", href: "/play/", id: "play", color: "var(--soul-color)" },
  { label: "Work", href: "/work/", id: "work", color: "var(--body-color)" },
  { label: "Pulse", href: "/pulse/", id: "pulse", color: "var(--accent, #f59e0b)" },
  { label: "Vibe", href: "/vibe/", id: "vibe", color: "var(--text-primary)" },
];
---

<header class="site-header" id="site-header">
  <div class="header-inner">
    <a href="/" class="header-logo" aria-label="Home">
      <img
        src="/logo.svg"
        class="logo-svg"
        width="28"
        height="28"
        alt=""
        aria-hidden="true"
      />
    </a>

    <nav class="swoosh-nav" aria-label="Main navigation">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "swoosh-tab",
              `swoosh-tab--${item.id}`,
              { active: resolvedNav === item.id },
            ]}
            style={`--tab-color: ${item.color};`}
          >
            <span class="swoosh-label">{item.label}</span>
          </a>
        ))
      }
    </nav>

    <a
      href="/about/"
      class:list={["header-about", { active: resolvedNav === "about" }]}
      aria-label="About"
    >
      <span class="about-initials">NR</span>
    </a>
  </div>

  <!-- Mobile -->
  <button
    class="mobile-menu-btn"
    aria-label="Toggle menu"
    aria-expanded="false"
    id="mobile-menu-toggle"
  >
    <span></span>
    <span></span>
    <span></span>
  </button>

  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation">
    <ul class="mobile-nav-list">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                "mobile-nav-link",
                `mobile-nav-link--${item.id}`,
                { active: resolvedNav === item.id },
              ]}
              style={`--tab-color: ${item.color};`}
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li>
        <a
          href="/about/"
          class:list={["mobile-nav-link", { active: resolvedNav === "about" }]}
        >
          About
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const nav = document.getElementById("mobile-nav");
  const header = document.getElementById("site-header");

  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    nav?.classList.toggle("open");
    header?.classList.toggle("menu-open");
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-primary);
  }

  .header-inner {
    display: flex;
    align-items: center;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* Logo: fixed left slot */
  .header-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    flex-shrink: 0;
    text-decoration: none;
    transition: opacity var(--transition-fast);
    padding: var(--space-sm) 0;
  }

  .header-logo:hover {
    opacity: 0.8;
  }

  /* Swoosh nav: 4 tabs fill remaining width */
  .swoosh-nav {
    flex: 1;
    display: flex;
    gap: 0;
  }

  /* Each tab: outline only, no fill */
  .swoosh-tab {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    position: relative;
    background: transparent;
    border: 4px solid var(--tab-color);
    border-top: none;
    color: var(--tab-color);
    padding: 0.7rem 0 1.2rem;
    border-radius: 0 0 50% 50%;
    margin: 4px;
    transition:
      background var(--transition-base),
      transform var(--transition-base);
  }

  .swoosh-tab:hover {
    text-decoration: none;
    background: rgba(255, 255, 255, 0.03);
    transform: translateY(1px);
  }

  .swoosh-tab.active {
    background: rgba(255, 255, 255, 0.05);
  }

  .swoosh-label {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: var(--tab-color);
  }

  /* NR avatar (About link, right side) */
  .header-about {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    flex-shrink: 0;
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  .header-about:hover {
    opacity: 0.8;
    text-decoration: none;
  }

  .about-initials {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--bg-primary);
    border: 2px solid var(--text-dim);
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    transition:
      border-color var(--transition-base),
      color var(--transition-base);
  }

  .header-about:hover .about-initials,
  .header-about.active .about-initials {
    border-color: var(--accent);
    color: var(--text-primary);
  }

  /* Mobile menu button */
  .mobile-menu-btn {
    display: none;
    position: absolute;
    top: 12px;
    right: 16px;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 101;
  }

  .mobile-menu-btn span {
    display: block;
    width: 22px;
    height: 2px;
    border-radius: 1px;
    transition: all var(--transition-fast);
  }

  .mobile-menu-btn span:nth-child(1) {
    background: var(--mind-color);
  }
  .mobile-menu-btn span:nth-child(2) {
    background: var(--body-color);
  }
  .mobile-menu-btn span:nth-child(3) {
    background: var(--soul-color);
  }

  .site-header.menu-open .mobile-menu-btn span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .site-header.menu-open .mobile-menu-btn span:nth-child(2) {
    opacity: 0;
  }
  .site-header.menu-open .mobile-menu-btn span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  /* Mobile nav */
  .mobile-nav {
    display: none;
    background: var(--bg-secondary);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .mobile-nav.open {
    display: block;
  }

  .mobile-nav-list {
    list-style: none;
    padding: var(--space-md) var(--space-xl);
  }

  .mobile-nav-link {
    display: block;
    padding: var(--space-sm) 0;
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-muted);
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    transition: color var(--transition-fast);
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    color: var(--tab-color, var(--accent));
  }

  @media (max-width: 768px) {
    .swoosh-nav {
      display: none;
    }
    .mobile-menu-btn {
      display: flex;
    }
    .header-inner {
      justify-content: center;
    }
  }
</style>
