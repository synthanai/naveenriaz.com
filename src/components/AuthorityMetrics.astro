---
/**
 * AuthorityMetrics — Personal authority stats grid with animated counters
 * Pattern: mirrors PulseMetrics.astro (grid + icons + values + labels)
 * Source: STEAL sudharsananganapathy.com (E83)
 */

const metrics = [
  { label: "Books & eBooks", value: 10, suffix: "", color: "soul", icon: "📖" },
  { label: "Research Papers", value: 5, suffix: "", color: "mind", icon: "📄" },
  {
    label: "Open-Source Repos",
    value: 23,
    suffix: "",
    color: "body",
    icon: "⚙",
  },
  {
    label: "Frameworks Created",
    value: 7,
    suffix: "",
    color: "mind",
    icon: "🔬",
  },
];
---

<section class="authority-metrics" id="authority-metrics">
  <div class="container">
    <div class="authority-header">
      <span class="authority-label">Proof of Work</span>
      <span class="authority-sub"
        >Not followers. Not impressions. What I actually built.</span
      >
    </div>
    <div class="authority-grid">
      {
        metrics.map((m, i) => (
          <div
            class={`authority-metric authority-metric--${m.color}`}
            data-target={m.value}
            data-suffix={m.suffix}
            style={`animation-delay: ${i * 80}ms`}
          >
            <span class="authority-icon">{m.icon}</span>
            <span class="authority-value">0{m.suffix}</span>
            <span class="authority-metric-label">{m.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const metrics = entry.target.querySelectorAll(".authority-metric");
          metrics.forEach((metric) => {
            const el = metric as HTMLElement;
            const target = parseInt(el.dataset.target || "0");
            const suffix = el.dataset.suffix || "";
            const valueEl = el.querySelector(".authority-value");
            if (!valueEl) return;

            const duration = 1200;
            const steps = 30;
            const stepTime = duration / steps;
            let current = 0;

            const timer = setInterval(() => {
              current += Math.ceil(target / steps);
              if (current >= target) {
                current = target;
                clearInterval(timer);
              }
              valueEl.textContent = current.toLocaleString() + suffix;
            }, stepTime);

            el.classList.add("animate-in");
          });
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.2 },
  );

  const section = document.getElementById("authority-metrics");
  if (section) observer.observe(section);
</script>

<style>
  .authority-metrics {
    padding: var(--space-2xl) 0;
  }

  .authority-header {
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .authority-label {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: var(--space-xs);
  }

  .authority-sub {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .authority-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: var(--space-md);
  }

  .authority-metric {
    background: var(--bg-card);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: var(--border-radius);
    padding: var(--space-lg) var(--space-md);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    opacity: 0;
    transform: translateY(12px);
    transition:
      transform var(--transition-base),
      box-shadow var(--transition-base),
      opacity 0.6s ease;
  }

  .authority-metric.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .authority-metric:hover {
    transform: translateY(-3px);
  }

  .authority-metric--mind {
    border-top: 2px solid var(--mind-color);
  }
  .authority-metric--mind:hover {
    box-shadow: 0 4px 20px var(--mind-glow);
  }

  .authority-metric--body {
    border-top: 2px solid var(--body-color);
  }
  .authority-metric--body:hover {
    box-shadow: 0 4px 20px var(--body-glow);
  }

  .authority-metric--soul {
    border-top: 2px solid var(--soul-color);
  }
  .authority-metric--soul:hover {
    box-shadow: 0 4px 20px var(--soul-glow);
  }

  .authority-icon {
    font-size: 1.3rem;
  }

  .authority-value {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .authority-metric-label {
    font-size: 0.68rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1.3;
  }

  @media (max-width: 480px) {
    .authority-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-sm);
    }

    .authority-metric {
      padding: var(--space-md) var(--space-sm);
    }

    .authority-value {
      font-size: 1.4rem;
    }
  }
</style>
