---
/**
 * ConstellationGraph — Interactive SVG concept map
 * Renders nodes from concepts.json, colored by dimension,
 * with edges showing relationships. Respects reveal gate.
 */
import conceptsData from '../data/concepts.json';
import revealData from '../data/reveal.json';

// Build a reveal lookup
const revealMap = new Map(revealData.map(r => [r.id, r]));

// Filter & enrich nodes based on reveal status
const visibleNodes = conceptsData.nodes
  .filter(n => {
    const reveal = revealMap.get(n.id);
    return reveal && reveal.status !== 'stealth';
  })
  .map(n => {
    const reveal = revealMap.get(n.id)!;
    return { ...n, ...reveal };
  });

const visibleIds = new Set(visibleNodes.map(n => n.id));

// Filter edges to only visible nodes
const visibleEdges = conceptsData.edges.filter(
  e => visibleIds.has(e.source) && visibleIds.has(e.target)
);

// Layout: arrange nodes in a circle
const width = 800;
const height = 600;
const cx = width / 2;
const cy = height / 2;
const radius = 220;

const nodePositions = new Map();
visibleNodes.forEach((node, i) => {
  const angle = (Math.PI * 2 * i / visibleNodes.length) - Math.PI / 2;
  const x = cx + radius * Math.cos(angle);
  const y = cy + radius * Math.sin(angle);
  nodePositions.set(node.id, { x, y });
});

// Dimension colors
const dimColors: Record<string, string> = {
  think: 'var(--mind-color)',
  work: 'var(--body-color)',
  play: 'var(--soul-color)',
};

const dimGlows: Record<string, string> = {
  think: 'var(--mind-glow)',
  work: 'var(--body-glow)',
  play: 'var(--soul-glow)',
};
---

<div class="constellation-container">
  <svg
    class="constellation-svg"
    viewBox={`0 0 ${width} ${height}`}
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Edges -->
    {visibleEdges.map(edge => {
      const from = nodePositions.get(edge.source);
      const to = nodePositions.get(edge.target);
      if (!from || !to) return null;
      return (
        <line
          x1={from.x} y1={from.y}
          x2={to.x} y2={to.y}
          stroke="rgba(255,255,255,0.06)"
          stroke-width="1"
          stroke-dasharray="4 4"
          class="constellation-edge"
        />
      );
    })}

    <!-- Center label -->
    <text x={cx} y={cy - 8} text-anchor="middle" fill="var(--accent)" font-size="10"
      font-family="var(--font-heading)" font-weight="700" letter-spacing="0.12em" opacity="0.5">
      THE
    </text>
    <text x={cx} y={cy + 8} text-anchor="middle" fill="var(--text-dim)" font-size="8"
      font-family="var(--font-heading)" letter-spacing="0.08em" opacity="0.4">
      NEBULA
    </text>

    <!-- Nodes -->
    {visibleNodes.map(node => {
      const pos = nodePositions.get(node.id)!;
      const color = dimColors[node.dimension] || 'var(--accent)';
      const glow = dimGlows[node.dimension] || 'var(--accent)';
      const isTeaser = node.status === 'teaser';
      const nodeRadius = isTeaser ? 5 : 8;
      const nodeOpacity = isTeaser ? 0.4 : 0.9;
      const label = node.publicName || node.label;
      const href = node.status === 'reveal' ? `/concept/${node.id}/` : undefined;

      return (
        <g class={`constellation-node constellation-node--${node.status}`}>
          {/* Glow ring for revealed nodes */}
          {!isTeaser && (
            <circle cx={pos.x} cy={pos.y} r={nodeRadius + 6}
              fill="none" stroke={color} stroke-width="0.5" opacity="0.2" />
          )}
          {/* Main dot */}
          <circle cx={pos.x} cy={pos.y} r={nodeRadius}
            fill={color} opacity={nodeOpacity}
            class="node-circle" />
          {/* Label */}
          {href ? (
            <a href={href}>
              <text x={pos.x} y={pos.y + nodeRadius + 16} text-anchor="middle"
                fill="var(--text-secondary)" font-size="11"
                font-family="var(--font-heading)" font-weight="600"
                class="node-label">
                {label}
              </text>
            </a>
          ) : (
            <text x={pos.x} y={pos.y + nodeRadius + 16} text-anchor="middle"
              fill="var(--text-dim)" font-size="10"
              font-family="var(--font-heading)" font-weight="500"
              font-style="italic" class="node-label--teaser">
              {label}
            </text>
          )}
        </g>
      );
    })}

  </svg>

  <!-- Legend -->
  <div class="constellation-legend">
    <span class="legend-item"><span class="legend-dot" style="background: var(--mind-color)"></span> Think</span>
    <span class="legend-item"><span class="legend-dot" style="background: var(--body-color)"></span> Work</span>
    <span class="legend-item"><span class="legend-dot" style="background: var(--soul-color)"></span> Play</span>
    <span class="legend-sep">|</span>
    <span class="legend-item legend-item--teaser"><span class="legend-dot legend-dot--dim"></span> Emerging</span>
  </div>
</div>

<style>
  .constellation-container {
    position: relative;
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
  }

  .constellation-svg {
    width: 100%;
    height: auto;
  }

  .constellation-edge {
    transition: stroke 0.3s ease;
  }

  .constellation-node:hover .node-circle {
    filter: brightness(1.3);
    cursor: pointer;
  }

  .constellation-node--reveal:hover .node-label {
    fill: var(--text-primary);
  }

  .node-label {
    transition: fill 0.2s ease;
    cursor: pointer;
  }

  .node-label:hover {
    fill: var(--text-primary) !important;
  }

  .constellation-legend {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) 0;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.72rem;
    color: var(--text-muted);
    font-family: var(--font-heading);
    letter-spacing: 0.04em;
  }

  .legend-item--teaser {
    font-style: italic;
    color: var(--text-dim);
  }

  .legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .legend-dot--dim {
    background: rgba(255, 255, 255, 0.15) !important;
  }

  .legend-sep {
    color: rgba(255, 255, 255, 0.08);
    font-size: 0.8rem;
  }

  @media (max-width: 600px) {
    .constellation-container {
      overflow-x: auto;
    }
    .constellation-svg {
      min-width: 600px;
    }
  }
</style>
