---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <!-- Daily Pulse Question -->
    <div class="pulse-question-wrap">
      <span class="pulse-q-label">Today's Pulse</span>
      <p class="pulse-q-text" id="daily-pulse-q"></p>
    </div>

    <div class="footer-brand">
      <span class="tamil-mark">ஃ</span>
      <span class="footer-tagline"
        >Where ancient patterns collide with emergent intelligence</span
      >
    </div>

    <div class="footer-links">
      <a
        href="https://www.linkedin.com/in/mnaveenriaz/"
        target="_blank"
        rel="noopener">LinkedIn</a
      >
      <a href="https://github.com/synthanai" target="_blank" rel="noopener"
        >GitHub</a
      >
      <a href="/challenge/">Challenge</a>
      <a href="/about/">Contact</a>
    </div>

    <div class="footer-copy">
      &copy; {year} Naveen Riaz Mohamed Kani. Pattern Connector. Transmuter.
    </div>
  </div>
</footer>

<script>
  const pulseQs = [
    "What decision are you avoiding right now?",
    "Which of your team's rituals have outlived their purpose?",
    "When was the last time you changed your mind about something important?",
    "What would you build if you knew it would fail?",
    "Which voice in your organization is being silenced?",
    "What is the most honest conversation you are not having?",
    "If you could only keep three processes, which three?",
    "What assumption did you make today without testing it?",
    "Who disagrees with you most? When did you last seek their input?",
    "What would 10x improvement look like, not 10%?",
    "What part of your work are you doing out of habit, not purpose?",
    "If your organization were a person, what would it be afraid of?",
  ];
  const pq = document.getElementById("daily-pulse-q");
  if (pq) pq.textContent = pulseQs[Math.floor(Math.random() * pulseQs.length)];
</script>

<style>
  .site-footer {
    margin-top: var(--space-4xl);
    padding: var(--space-2xl) 0;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    text-align: center;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .footer-tagline {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .footer-links {
    display: flex;
    gap: var(--space-lg);
  }

  .footer-links a {
    font-size: 0.85rem;
    color: var(--text-muted);
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--accent);
  }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  /* ── Daily Pulse ──────────────── */
  .pulse-question-wrap {
    text-align: center;
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    max-width: 480px;
  }

  .pulse-q-label {
    font-family: var(--font-label);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: var(--space-xs);
  }

  .pulse-q-text {
    font-size: 0.9rem;
    font-style: italic;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
    min-height: 1.6em;
  }
</style>
