---
const year = new Date().getFullYear();
---

<footer class="site-footer" id="site-footer">
  <div class="footer-slogan">
    Everything we build is <span class="tamil">Alive!</span>
    Nurture its <span class="c-mind">Mind</span>,
    <span class="c-body">Body</span> &amp;
    <span class="c-soul">Soul</span>. Watch it <span class="tamil">Thrive!</span
    >
  </div>

  <div class="footer-inner">
    <a href="/" class="footer-brand" aria-label="Home">
      <img
        src="/logo.svg"
        class="footer-logo"
        width="24"
        height="24"
        alt=""
        aria-hidden="true"
      />
      <span class="footer-name">Naveen Riaz</span>
    </a>

    <div class="footer-links">
      <a
        href="https://www.linkedin.com/in/mnaveenriaz/"
        target="_blank"
        rel="noopener">LinkedIn</a
      >
      <a href="https://github.com/synthanai" target="_blank" rel="noopener"
        >GitHub</a
      >
      <a href="/about/">About</a>
    </div>

    <div class="footer-meta">
      <span class="footer-views" id="page-views" title="Page views"></span>
      <span class="footer-copy">&copy; {year} Naveen Riaz</span>
    </div>
  </div>
</footer>

