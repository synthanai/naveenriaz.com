---
/**
 * SocialProof — "Published & Active On" text-based logo strip
 * Grayscale platform names with hover glow. No image dependencies.
 * Source: STEAL sudharsananganapathy.com (E84)
 */

const platforms = [
  { name: 'LinkedIn', url: 'https://www.linkedin.com/in/mnaveenriaz/', icon: '◆' },
  { name: 'Zenodo', url: 'https://zenodo.org/records/14838659', icon: '◆' },
  { name: 'Medium', url: '#', icon: '◆' },
  { name: 'GitHub', url: 'https://github.com/synthanai', icon: '◆' },
  { name: 'Substack', url: '#', icon: '◆' },
];
---

<div class="social-proof">
  <span class="proof-label">Published & Active On</span>
  <div class="proof-strip">
    {platforms.map(p => (
      <a href={p.url} class="proof-item" target="_blank" rel="noopener" title={p.name}>
        <span class="proof-name">{p.name}</span>
      </a>
    ))}
  </div>
</div>

<style>
  .social-proof {
    padding: var(--space-lg) 0;
    text-align: center;
  }

  .proof-label {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    display: block;
    margin-bottom: var(--space-md);
  }

  .proof-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  .proof-item {
    text-decoration: none;
    color: var(--text-dim);
    transition: all var(--transition-base);
    position: relative;
  }

  .proof-name {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    opacity: 0.4;
    transition: opacity var(--transition-base), color var(--transition-base);
  }

  .proof-item:hover .proof-name {
    opacity: 1;
    color: var(--accent);
  }

  .proof-item:hover {
    text-shadow: 0 0 12px var(--accent-glow);
  }

  .proof-item::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transition: transform var(--transition-base);
  }

  .proof-item:hover::after {
    transform: scaleX(1);
  }

  @media (max-width: 480px) {
    .proof-strip {
      gap: var(--space-lg);
    }

    .proof-name {
      font-size: 0.8rem;
    }
  }
</style>
