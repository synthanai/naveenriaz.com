---
interface Props {
  severity: 'low' | 'medium' | 'high';
  active: boolean;
}

const { severity, active } = Astro.props;

const pulseSpeed = severity === 'high' ? '0.8s' : severity === 'medium' ? '1.5s' : '3s';
const pulseColor = severity === 'high' ? '#ff4444' : severity === 'medium' ? 'var(--p-gold)' : 'var(--p-blue)';
---

<div class={`pulse-container ${active ? 'active' : ''}`} style={`--pulse-speed: ${pulseSpeed}; --pulse-color: ${pulseColor};`}>
  <div class="pulse-ring ring-1"></div>
  <div class="pulse-ring ring-2"></div>
  <div class="pulse-core">
    <svg viewBox="0 0 100 100" class="pulse-hexagon">
      <path d="M50 5 L90 28 L90 72 L50 95 L10 72 L10 28 Z" fill="none" stroke="currentColor" stroke-width="2" />
    </svg>
  </div>
</div>

<style>
  .pulse-container {
    position: relative;
    width: 200px;
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 1s ease;
  }
  
  .pulse-container.active {
    opacity: 1;
  }

  .pulse-core {
    position: relative;
    width: 100px;
    height: 100px;
    color: var(--pulse-color);
    z-index: 10;
  }

  .pulse-hexagon {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 0 10px var(--pulse-color));
    animation: rotate 20s linear infinite;
  }

  .pulse-ring {
    position: absolute;
    width: 100px;
    height: 100px;
    border: 1px solid var(--pulse-color);
    border-radius: 50%;
    opacity: 0;
    animation: pulse-ring var(--pulse-speed) cubic-bezier(0.24, 0, 0.38, 1) infinite;
  }

  .ring-2 {
    animation-delay: calc(var(--pulse-speed) / 2);
  }

  @keyframes pulse-ring {
    0% { transform: scale(1); opacity: 0.6; }
    100% { transform: scale(2.5); opacity: 0; }
  }

  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes shimmer {
    0% { opacity: 0.3; }
    50% { opacity: 1; }
    100% { opacity: 0.3; }
  }
</style>
