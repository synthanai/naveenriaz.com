---
interface Props {
  question: string;
  context?: string;
}

const { question, context = "This week's collision" } = Astro.props;
---

<section class="collision-gate" id="collision-gate">
  <div class="container">
    <div class="gate-content animate-in">
      <span class="gate-label">{context}</span>
      <h1 class="gate-question">{question}</h1>
      <div class="gate-pulse">
        <span class="glow-dot"></span>
      </div>
    </div>
  </div>
</section>

<style>
  .collision-gate {
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4xl) 0;
    position: relative;
    overflow: hidden;
  }

  .collision-gate::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 50% 50%,
      var(--accent-glow) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .gate-content {
    text-align: center;
    max-width: 700px;
    position: relative;
    z-index: 1;
  }

  .gate-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-lg);
    padding: var(--space-xs) var(--space-md);
    border: 1px solid var(--accent-border);
    border-radius: 20px;
  }

  .gate-question {
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .gate-pulse {
    margin-top: var(--space-xl);
    display: flex;
    justify-content: center;
  }

  .gate-pulse .glow-dot {
    width: 8px;
    height: 8px;
    animation: pulseGlow 2s ease-in-out infinite;
  }
</style>
