---
interface Props {
  title: string;
  description: string;
  href: string;
  dimension?: 'mind' | 'body' | 'soul';
  tags?: string[];
  status?: string;
  phase?: 'discover' | 'decide' | 'deliver';
}

const { title, description, href, dimension, tags = [], status, phase } = Astro.props;

const dimensionLabels: Record<string, string> = {
  mind: 'Think',
  body: 'Work',
  soul: 'Play',
};

const phaseLabels: Record<string, string> = {
  discover: 'Discover',
  decide: 'Decide',
  deliver: 'Deliver',
};

const phaseIcons: Record<string, string> = {
  discover: '🔭',
  decide: '⚖️',
  deliver: '✅',
};
---

<a href={href} class:list={['pattern-card', 'card', dimension && `card--${dimension}`]}>
  <div class="pattern-card-header">
    {dimension && <span class:list={['dimension-badge', `badge--${dimension}`]}>{dimensionLabels[dimension] || dimension}</span>}
    {phase && <span class:list={['phase-badge', `phase--${phase}`]}>{phaseIcons[phase]} {phaseLabels[phase]}</span>}
    {status && <span class="status-badge">{status}</span>}
  </div>
  <h3 class="pattern-card-title">{title}</h3>
  <p class="pattern-card-desc">{description}</p>
  {tags.length > 0 && (
    <div class="pattern-card-tags">
      {tags.map((tag) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  )}
  <span class="pattern-card-arrow" aria-hidden="true">&rarr;</span>
</a>

<style>
  .pattern-card {
    display: block;
    position: relative;
    text-decoration: none;
    color: inherit;
    padding: var(--space-lg) var(--space-lg) var(--space-xl);
  }

  .pattern-card-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .dimension-badge {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 2px 10px;
    border-radius: 20px;
  }

  .badge--mind {
    color: var(--mind-color);
    background: var(--mind-glow);
    border: 1px solid rgba(40, 116, 166, 0.25);
  }

  .badge--body {
    color: var(--body-color);
    background: var(--body-glow);
    border: 1px solid rgba(39, 174, 96, 0.25);
  }

  .badge--soul {
    color: var(--soul-color);
    background: var(--soul-glow);
    border: 1px solid rgba(212, 168, 67, 0.25);
  }

  .status-badge {
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--text-dim);
    padding: 2px 8px;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .phase-badge {
    font-family: var(--font-heading);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 10px;
    border-radius: 20px;
  }

  .phase--discover {
    color: var(--soul-color);
    background: var(--soul-glow);
    border: 1px solid rgba(212, 168, 67, 0.2);
  }

  .phase--decide {
    color: var(--mind-color);
    background: var(--mind-glow);
    border: 1px solid rgba(40, 116, 166, 0.2);
  }

  .phase--deliver {
    color: var(--body-color);
    background: var(--body-glow);
    border: 1px solid rgba(39, 174, 96, 0.2);
  }

  .pattern-card-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: var(--space-sm);
    transition: color var(--transition-fast);
  }

  .pattern-card:hover .pattern-card-title {
    color: var(--accent);
  }

  .pattern-card-desc {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }

  .pattern-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .tag {
    font-size: 0.7rem;
    color: var(--text-dim);
    padding: 2px 8px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.03);
  }

  .pattern-card-arrow {
    position: absolute;
    right: var(--space-lg);
    bottom: var(--space-md);
    font-size: 1.1rem;
    color: var(--text-dim);
    transition: all var(--transition-fast);
  }

  .pattern-card:hover .pattern-card-arrow {
    color: var(--accent);
    transform: translateX(4px);
  }
</style>
