---
/**
 * PulseMetrics — Vital signs dashboard showing ecosystem health
 * Reads from pulse.json (auto-generated by scanner)
 */
import pulseData from "../data/pulse.json";

const p = pulseData.pulse;
const generatedDate = new Date(pulseData.generatedAt).toLocaleDateString(
  "en-AU",
  {
    year: "numeric",
    month: "short",
    day: "numeric",
  },
);

const metrics = [
  {
    label: "Research Notes",
    value: p.researchFiles.toLocaleString(),
    color: "think",
    icon: "🔬",
  },
  { label: "Chapters Built", value: p.bookChapters, color: "play", icon: "✍" },
  { label: "Workflows", value: p.workflows, color: "work", icon: "🔄" },
  {
    label: "Knowledge Items",
    value: p.knowledgeItems,
    color: "think",
    icon: "🧠",
  },
  {
    label: "Total Commits",
    value: p.totalCommits.toLocaleString(),
    color: "work",
    icon: "⚡",
  },
];
---

<div class="pulse-metrics">
  <div class="pulse-header">
    <span class="pulse-dot"></span>
    <span class="pulse-label">Ecosystem Pulse</span>
    <span class="pulse-date">Last scan: {generatedDate}</span>
  </div>
  <div class="pulse-grid">
    {
      metrics.map((m) => (
        <div class={`pulse-metric pulse-metric--${m.color}`}>
          <span class="metric-icon">{m.icon}</span>
          <span class="metric-value">{m.value}</span>
          <span class="metric-label">{m.label}</span>
        </div>
      ))
    }
  </div>
</div>

<style>
  .pulse-metrics {
    padding: var(--space-xl) 0;
  }

  .pulse-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--body-color);
    box-shadow:
      0 0 0 3px rgba(39, 174, 96, 0.15),
      0 0 8px var(--body-color);
    animation: pulseGlow 3s ease-in-out infinite;
  }

  .pulse-label {
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .pulse-date {
    margin-left: auto;
    font-size: 0.72rem;
  }

  .pulse-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--space-md);
  }

  .pulse-metric {
    background: var(--bg-card);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: var(--border-radius);
    padding: var(--space-md);
    text-align: center;
    transition:
      transform var(--transition-base),
      box-shadow var(--transition-base);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .pulse-metric:hover {
    transform: translateY(-2px);
  }

  .pulse-metric--think {
    border-top: 2px solid var(--mind-color);
  }
  .pulse-metric--think:hover {
    box-shadow: 0 4px 20px var(--mind-glow);
  }

  .pulse-metric--work {
    border-top: 2px solid var(--body-color);
  }
  .pulse-metric--work:hover {
    box-shadow: 0 4px 20px var(--body-glow);
  }

  .pulse-metric--play {
    border-top: 2px solid var(--soul-color);
  }
  .pulse-metric--play:hover {
    box-shadow: 0 4px 20px var(--soul-glow);
  }

  .metric-icon {
    font-size: 1.2rem;
    margin-bottom: 2px;
  }

  .metric-value {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
  }

  .metric-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  @media (max-width: 480px) {
    .pulse-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
