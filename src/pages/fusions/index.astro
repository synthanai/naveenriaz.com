---
import { getCollection } from 'astro:content';
import Page from '../../layouts/Page.astro';

const allFusions = await getCollection('fusions');
const sorted = allFusions
  .filter((c) => c.data.collision_type !== 'internal')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categoryColors: Record<string, [string, string]> = {
  "ai-emergence": ["#2874A6", "rgba(40, 116, 166, 0.08)"],
  "living-organisations": ["#D4A843", "rgba(212, 168, 67, 0.08)"],
  "pattern": ["#27ae60", "rgba(39, 174, 96, 0.08)"],
  "methodology": ["#2874A6", "rgba(40, 116, 166, 0.06)"],
};

const categoryLabels: Record<string, string> = {
  "ai-emergence": "AI & Emergence",
  "living-organisations": "Living Organisations",
  "pattern": "Pattern Connections",
  "methodology": "Methodology",
};
---

<Page title="Fusions" description="Two unrelated ideas crash. A completely new, heavier element emerges." activeNav="fusions">
  <section class="collisions-hero">
    <div class="container">
      <p class="hero-badge">INTELLECTUAL EVENTS</p>
      <h1>
        <span class="title-accent">Fusions</span>
      </h1>
      <p class="hero-sub">
        Two distinct domains forced together under extreme pressure.<br />
        A new, heavier intellectual element is born.
      </p>
      <p class="hero-count">{sorted.length} fusions published</p>
    </div>
  </section>

  <section class="collisions-grid container">
    {sorted.map((collision) => {
      const cat = collision.data.categories?.[0] || "pattern";
      const [solidColor, glowColor] = categoryColors[cat] || ["#d4a574", "rgba(212, 165, 116, 0.08)"];
      const label = categoryLabels[cat] || cat.replace(/-/g, " ");
      const displayTitle = collision.data.display_title || collision.data.title;
      const date = collision.data.date.toLocaleDateString("en-GB", {
        day: "numeric",
        month: "short",
        year: "numeric",
      });

      return (
        <a
          href={`/fusions/${collision.slug}`}
          class="collision-card"
          style={`--cc: ${solidColor}; --cg: ${glowColor}`}
        >
          <div class="collision-card__top">
            <span class="collision-card__cat" style={`color: ${solidColor}`}>
              {label}
            </span>
            <span class="collision-card__date">{date}</span>
          </div>
          <h3 class="collision-card__title">{displayTitle}</h3>
          {collision.data.display_subtitle && (
            <p class="collision-card__sub">{collision.data.display_subtitle}</p>
          )}
          <div class="collision-card__tags">
            {collision.data.tags?.slice(0, 3).map((tag) => (
              <span class="collision-card__tag">{tag}</span>
            ))}
          </div>
        </a>
      );
    })}
  </section>
</Page>

<style>
  /* ═══ Hero ═══ */
  .collisions-hero {
    padding: var(--space-3xl) 0 var(--space-xl);
    text-align: center;
  }

  .hero-badge {
    font-family: var(--font-label);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--mind-color);
    margin-bottom: var(--space-sm);
  }

  .collisions-hero h1 {
    font-size: clamp(2.5rem, 7vw, 4rem);
    font-weight: 800;
    color: var(--text-primary) !important;
    margin-bottom: var(--space-sm);
  }

  .title-accent {
    background: linear-gradient(135deg, var(--mind-color), var(--soul-color), var(--body-color));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1rem;
    color: var(--text-secondary);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .hero-count {
    font-family: var(--font-label);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    opacity: 0.5;
    margin-top: var(--space-md);
  }

  /* ═══ Grid ═══ */
  .collisions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-md);
    padding-bottom: var(--space-4xl);
  }

  /* ═══ Card ═══ */
  .collision-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-lg) var(--space-xl);
    border-radius: var(--border-radius);
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: linear-gradient(180deg, var(--cg, rgba(255,255,255,0.02)), transparent);
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .collision-card:hover {
    transform: translateY(-3px);
    border-color: var(--cc, rgba(255, 255, 255, 0.15));
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.4);
    text-decoration: none;
  }

  .collision-card__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-sm);
  }

  .collision-card__cat {
    font-family: var(--font-label);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .collision-card__date {
    font-family: var(--font-label);
    font-size: 0.6rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.04em;
  }

  .collision-card__title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
    margin-bottom: var(--space-sm);
  }

  .collision-card__sub {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.45);
    font-style: italic;
    line-height: 1.45;
    margin-bottom: var(--space-sm);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .collision-card__tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: var(--space-sm);
  }

  .collision-card__tag {
    font-family: var(--font-label);
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.3);
    padding: 2px 8px;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(255, 255, 255, 0.02);
  }

  /* ═══ Responsive ═══ */
  @media (max-width: 640px) {
    .collisions-grid {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
    }

    .collision-card {
      padding: var(--space-md) var(--space-lg);
    }

    .collision-card__sub {
      display: none;
    }
  }
</style>
