---
/**
 * SURGE Your Clarity — Product showcase
 * Pattern: methodology-hero (centered) + 5-step process + cognitive science
 * Source: 5-text/ebooks/SURGE-Your-Clarity/
 */
import Page from "../layouts/Page.astro";
import TamilRoot from "../components/TamilRoot.astro";

const steps = [
    {
        letter: "S",
        name: "Surface",
        color: "body",
        desc: "Write down every open loop in your mind. Every unfinished task, lingering worry, half-formed idea. Get it out of your head.",
        science: "Zeigarnik Effect: unfinished tasks consume working memory.",
    },
    {
        letter: "U",
        name: "Untangle",
        color: "mind",
        desc: "Sort everything into three columns: Act (do it), Delegate (move it), Release (let it go). No fourth option.",
        science:
            "Cognitive Offloading: external sorting frees internal bandwidth.",
    },
    {
        letter: "R",
        name: "Release",
        color: "soul",
        desc: "Cross out everything in the Release column. This is not productivity, it is permission. You are allowed to stop carrying it.",
        science: "Decision Fatigue: fewer open loops means sharper decisions.",
    },
    {
        letter: "G",
        name: "Grill",
        color: "mind",
        desc: "Interrogate the Act column. Sequence it. Not a to-do list, an architecture. What comes first? What depends on what?",
        science: "Metacognition: thinking about your thinking patterns.",
    },
    {
        letter: "E",
        name: "Execute",
        color: "body",
        desc: "Pick one item. Start. Not the most important one, the one with the lowest resistance. Momentum builds clarity.",
        science: "Behavioral Activation: action precedes motivation.",
    },
];
---

<Page
    title="SURGE Your Clarity"
    description="A 5-step guide to clearing cognitive fog. Surface, Untangle, Release, Grill, Execute. Your brain is holding 150+ open loops right now."
    activeNav="clarity"
>
    <section class="clarity-hero">
        <div
            class="orb"
            style="width:500px;height:500px;background:var(--accent);top:-180px;left:50%;transform:translateX(-50%);opacity:0.12;"
        >
        </div>

        <div class="container" style="text-align:center;">
            <span class="clarity-label">SURGE Your Clarity</span>
            <h1>
                Your Brain Is Holding <span class="gt">150+ Open Loops</span>
            </h1>
            <p class="clarity-desc">
                Every unfinished task, lingering worry, and half-formed idea
                consumes working memory. This guide gives you 5 steps to clear
                the fog.
            </p>
        </div>
    </section>

    <section class="section--tight">
        <div class="container container--narrow">
            <TamilRoot
                tamil="தெளிவு"
                transliteration="Thelivu"
                meaning="Clarity. Not the absence of complexity, but the ability to see through it. The mind, unclogged, sees what was always there."
                tamilMeaning="சிக்கலின் இல்லாமை அல்ல, ஆனால் அதன் வழியாகப் பார்க்கும் திறன். அடைப்பு நீங்கிய மனம், எப்போதும் இருந்ததைக் காண்கிறது."
                kural="எப்பொருள் யார்யார்வாய்க் கேட்பினும் அப்பொருள் மெய்ப்பொருள் காண்பதறிவு."
                kuralNumber={423}
                kuralTranslation="True wisdom is hearing any claim from any source and discerning the truth within it."
            />
        </div>
    </section>

    <!-- The 5 Steps -->
    <section class="section--tight">
        <div class="container container--narrow">
            <h2 class="section-label">The SURGE Process</h2>
            <p class="section-sub">
                Five steps. Each one backed by cognitive science. Each one
                designed to reduce the loops your brain is holding.
            </p>

            <div class="steps-stack">
                {
                    steps.map((step, i) => (
                        <div class={`step step--${step.color}`}>
                            <div class="step-letter-col">
                                <span class="step-letter">{step.letter}</span>
                                <span class="step-index">{i + 1}/5</span>
                            </div>
                            <div class="step-content">
                                <h3>{step.name}</h3>
                                <p class="step-desc">{step.desc}</p>
                                <div class="step-science">
                                    <span class="science-tag">Science</span>
                                    {step.science}
                                </div>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Closing -->
    <section class="section--tight">
        <div class="container container--narrow">
            <div class="manifesto">
                <h2>The <span class="gt">Shift</span></h2>
                <p>
                    Before SURGE: a foggy mind carrying everything. After SURGE:
                    a clear mind carrying only what matters. The difference is
                    not what you add. It is what you release.
                </p>
                <p>
                    The full guide is a formatted ebook with worksheets,
                    reflection prompts, and the cognitive science behind each
                    step.
                </p>
            </div>
        </div>
    </section>
</Page>

<style>
    .clarity-hero {
        padding: var(--space-4xl) 0 var(--space-2xl);
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .clarity-label {
        font-family: var(--font-label);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: var(--space-sm);
        display: block;
    }

    .clarity-desc {
        max-width: 600px;
        margin: var(--space-md) auto 0;
        color: var(--text-secondary);
        font-size: 1.05rem;
        line-height: 1.7;
    }

    .section-label {
        font-family: var(--font-label);
        font-size: 1rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: var(--space-xs);
    }

    .section-sub {
        font-size: 0.9rem;
        color: var(--text-dim);
        margin-bottom: var(--space-xl);
        max-width: 560px;
    }

    /* ── Steps Stack ─────────────────────────── */
    .steps-stack {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
    }

    .step {
        display: flex;
        gap: var(--space-lg);
        padding: var(--space-lg) var(--space-xl);
        background: var(--bg-card);
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: var(--border-radius);
        transition: transform var(--transition-base);
    }

    .step:hover {
        transform: translateX(4px);
    }

    .step--body {
        border-left: 4px solid var(--body-color);
    }
    .step--mind {
        border-left: 4px solid var(--mind-color);
    }
    .step--soul {
        border-left: 4px solid var(--soul-color);
    }

    .step-letter-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        flex-shrink: 0;
    }

    .step-letter {
        font-family: var(--font-heading);
        font-size: 2rem;
        font-weight: 800;
        line-height: 1;
    }

    .step--body .step-letter {
        color: var(--body-color);
    }
    .step--mind .step-letter {
        color: var(--mind-color);
    }
    .step--soul .step-letter {
        color: var(--soul-color);
    }

    .step-index {
        font-size: 0.55rem;
        font-weight: 600;
        color: var(--text-dim);
        letter-spacing: 0.06em;
    }

    .step-content h3 {
        margin-bottom: var(--space-xs);
    }

    .step--body h3 {
        color: var(--body-color);
    }
    .step--mind h3 {
        color: var(--mind-color);
    }
    .step--soul h3 {
        color: var(--soul-color);
    }

    .step-desc {
        font-size: 0.88rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin-bottom: var(--space-sm);
    }

    .step-science {
        font-size: 0.75rem;
        color: var(--text-dim);
        line-height: 1.4;
        font-style: italic;
    }

    .science-tag {
        font-size: 0.55rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--accent);
        margin-right: var(--space-xs);
        font-style: normal;
    }

    /* ── Responsive ─────────────────────────── */
    @media (max-width: 768px) {
        .step {
            flex-direction: column;
            gap: var(--space-sm);
        }
        .step-letter-col {
            flex-direction: row;
            gap: var(--space-sm);
        }
    }
</style>
