---
/**
 * Work Page — Layer 1
 * Tiered repo showcase: Hero (2) + Shipped (5) + Cooking (2+2 books).
 * SPAR verdict: Curate on site, don't censor on GitHub.
 */
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import TamilRoot from "../components/TamilRoot.astro";
import { getCollection } from "astro:content";

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Work | Naveen Riaz</title>
    <meta
      name="description"
      content="What I build. Papers, open source tools, and books. Honesty over impressiveness."
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Work | Naveen Riaz" />
    <meta property="og:description" content="What I build. Papers, open source tools, and books. Honesty over impressiveness." />
    <meta property="og:image" content="https://naveenriaz.com/og-image.png" />
    <meta property="og:url" content="https://naveenriaz.com/work/" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
    </style>
  </head>
  <body class="section-work">
    <Header activeNav="work" />

    <main class="container container--narrow">
      <section class="page-hero section">
        <h1>Work</h1>
        <p class="page-subtitle">What I build.</p>
        <p>
          I organise my work in three layers. <br />What my body has shipped.
          What my mind is cooking. What my soul is exploring. <br />Every tool
          here serves one belief: living systems thrive when their decisions
          improve.
        </p>
      </section>

      <!-- Execution: Knots & Beads -->
      <section class="section--tight">
        <p class="knots-badge" style="color: var(--body-color);">SHORT FORM</p>
        <div class="layer-header">
          <span class="glow-dot" style="color: var(--color-gold, #ffd700);"></span>
          <h2>Knots <span class="layer-label">Untangling</span></h2>
        </div>
        <p class="section-hook">
          The tangled friction inside organisations.
        </p>
        <p>
          108 diagnostic patterns that show up in every organisation,
          community, and product. Each knot is named, felt, and
          untied, across Soul, Mind, and Body.
        </p>
        <div class="proof-links">
          <a href="/knots/" class="btn">Browse 108 Knots →</a>
        </div>
      </section>

      <div class="divider"><img src="/logo-h.svg" alt="ஃ" /></div>

      <section class="section--tight">
        <p class="knots-badge" style="color: var(--body-color);">SHORT FORM</p>
        <div class="layer-header">
          <span class="glow-dot" style="color: var(--color-gold, #ffd700);"></span>
          <h2>Beads <span class="layer-label">Thought</span></h2>
        </div>
        <p class="section-hook">
          The hardened wisdom doing the untangling.
        </p>

        <div class="proof-links">
          <a href="/beads/" class="btn">Browse All Beads →</a>
        </div>
      </section>

      <div class="divider"><img src="/logo-h.svg" alt="ஃ" /></div>
      
      <section class="section--tight">
        <p class="knots-badge" style="color: var(--body-color);">LONG FORM</p>
        <div class="layer-header" style="opacity: 0.7;">
          <span class="glow-dot" style="color: var(--color-gold, #ffd700);"></span>
          <h2 style="display: flex; align-items: center; gap: 8px;">Digs <span class="layer-label">Literature</span> <span class="knots-badge" style="background: rgba(255,255,255,0.1); padding: 2px 6px; border-radius: 4px; font-size: 0.6rem; color: var(--text-muted); margin-left: 8px;">COMING SOON</span></h2>
        </div>
        <p class="section-hook" style="opacity: 0.7;">
          Heavy literature and organisational excavation.
        </p>
        <p>
          Digs are deep-dive research pieces. When a topic requires more than a tactical Bead, we excavate. This involves extracting artifacts, naming the strata layers, and cataloguing the findings.
        </p>
      </section>

      <div class="divider"><img src="/logo-h.svg" alt="ஃ" /></div>

      <!-- Body: Shipped -->
      <section class="section--tight">
        <div class="layer-header">
          <span class="glow-dot" style="color: var(--body-color);"></span>
          <h2>Contributions <span class="layer-label">Thriving</span></h2>
        </div>

        <div class="hero-grid">
          <div class="hero-card">
            <h3>SPAR-Kit</h3>
            <p class="work-type">Open Source CLI</p>
            <p>
              Run structured AI debates in your terminal. Multiple personas
              argue, a critic stress-tests, an arbiter synthesises. The friction
              is the feature.
            </p>
            <a
              href="https://github.com/synthanai/spar-kit"
              target="_blank"
              rel="noopener">View on GitHub →</a
            >
          </div>

          <div class="hero-card">
            <h3>Intent of Thought</h3>
            <p class="work-type">Academic Paper</p>
            <p>
              GPS for AI reasoning. A framework where AI declares its thinking
              strategy before generating, the same way a GPS announces your
              route before you drive.
            </p>
            <div class="link-row">
              <a
                href="https://github.com/synthanai/intent-of-thought/blob/main/paper/intent_of_thought.pdf"
                target="_blank"
                rel="noopener">Read the Paper →</a
              >
              <a
                href="https://doi.org/10.5281/zenodo.18836659"
                target="_blank"
                rel="noopener"
                class="link-secondary">Zenodo DOI →</a
              >
            </div>
          </div>
        </div>

        <div class="shipped-grid">
          <a
            href="https://github.com/synthanai/decision-moment-graph"
            target="_blank"
            rel="noopener"
            class="shipped-card"
          >
            <h4>Decision Moment Graph</h4>
            <p>
              Open standard for decision governance. Stop storing chats, store
              decision objects.
            </p>
          </a>

          <a
            href="https://github.com/synthanai/ramp-kit"
            target="_blank"
            rel="noopener"
            class="shipped-card"
          >
            <h4>RAMP-Kit</h4>
            <p>
              Reversible Action Management Protocol. Govern decision velocity
              based on reversibility.
            </p>
          </a>

          <a
            href="https://github.com/synthanai/agentic-kit"
            target="_blank"
            rel="noopener"
            class="shipped-card"
          >
            <h4>Agentic-Kit</h4>
            <p>
              Reusable infrastructure for AI decision systems. Agents need
              infrastructure, not just prompts.
            </p>
          </a>

          <a
            href="https://github.com/synthanai/steal-kit"
            target="_blank"
            rel="noopener"
            class="shipped-card"
          >
            <h4>STEAL-Kit</h4>
            <p>
              Structured intelligence capture. Scan, Translate, Evaluate,
              Abstract, Leverage.
            </p>
          </a>

          <a
            href="https://github.com/synthanai/decision-moment-standard"
            target="_blank"
            rel="noopener"
            class="shipped-card"
          >
            <h4>Decision Moment Standard</h4>
            <p>
              The specification behind DMG. Decision governance as a protocol.
            </p>
          </a>
        </div>

        <h3 class="subsection-heading">Published Ebooks</h3>
        <div class="ebook-grid">
          <div class="work-item work-item--compact">
            <h4>PIC Your Profile</h4>
            <p class="work-type">Published</p>
            <p>Identity architecture ebook.</p>
          </div>
          <div class="work-item work-item--compact">
            <h4>21-Rep AI Gym</h4>
            <p class="work-type">Published</p>
            <p>AI capability building through structured reps.</p>
          </div>
        </div>
      </section>

      <div class="divider"><img src="/logo-h.svg" alt="ஃ" /></div>

      <!-- Mind: Cooking -->
      <section class="section--tight">
        <div class="layer-header">
          <span class="glow-dot" style="color: var(--body-color);"></span>
          <h2>Recipes <span class="layer-label">Cooking</span></h2>
        </div>

        <div class="work-grid">
          <div class="work-item">
            <h3>Let's SPAR: Disagree to Agree</h3>
            <p class="work-type">Book · 21 Chapters · Publication-Ready</p>
            <p>
              How to argue with yourself productively. Structured dialectic
              thinking for better decisions, built on the SPAR protocol.
            </p>
          </div>

          <div class="work-item">
            <h3>Thirukkural: Mind, Body, Soul</h3>
            <p class="work-type">Book · In Active Writing</p>
            <p>
              Bridging 2000-year-old Tamil wisdom to modern leadership through
              the Mind-Body-Soul lens.
            </p>
          </div>
        </div>

        <div class="ebook-grid">
          <div class="work-item work-item--compact">
            <h4>SPAR Gracefully</h4>
            <p class="work-type">Ebook · Cooking</p>
            <p>SPAR methodology in practice.</p>
          </div>
          <div class="work-item work-item--compact">
            <h4>PURGE Your Clarity</h4>
            <p class="work-type">Ebook · Cooking</p>
            <p>Clarity through structured emergence.</p>
          </div>
        </div>

        <div class="cooking-repos">
          <p class="cooking-label">Also cooking on GitHub:</p>
          <ul>
            <li>
              <a
                href="https://github.com/synthanai/intent-of-thought-lifecycle"
                target="_blank"
                rel="noopener">Intent of Thought Lifecycle</a
              > — Extending the IoT paper into a living protocol
            </li>
            <li>
              <a
                href="https://github.com/synthanai/student-kit"
                target="_blank"
                rel="noopener">Student-Kit</a
              > — AI toolkit for students
            </li>
          </ul>
        </div>
      </section>



      <!-- Soul: Ideas & Concepts -->
      <section class="section--tight">
        <div class="layer-header">
          <span class="glow-dot" style="color: var(--body-color);"></span>
          <h2>Ideas <span class="layer-label">Igniting</span></h2>
        </div>

        <div class="soul-grid">
          <div class="soul-card">
            <h4>Living Systems</h4>
            <p>
              Organisations are not machines. They breathe, grow, decay. Every
              framework I build starts from this belief.
            </p>
          </div>
          <div class="soul-card">
            <h4>Structured Deliberation</h4>
            <p>
              Thinking is a craft. SPAR, RAMP, DMG: all exist because decisions
              deserve more friction, not less.
            </p>
          </div>
          <div class="soul-card">
            <h4>Tamil Wisdom Bridge</h4>
            <p>
              The Thirukkural is 2000 years old and speaks to modern leadership.
              Bridging ancient wisdom to contemporary practice.
            </p>
          </div>
          <div class="soul-card">
            <h4>AI with Intent</h4>
            <p>
              AI should declare its reasoning before generating. Transparency is
              not a feature, it is a requirement.
            </p>
          </div>
        </div>
      </section>

      <TamilRoot
        tamil="செயல்"
        transliteration="Seyal"
        meaning="Action, work, the doing. Not mere activity, but purposeful creation that leaves a mark."
        kural={`முடிவும் இடையூறும் முற்றியாங்கு எய்தும்\nபடுபயனும் பார்த்துச் செயல்.`}
        kuralNumber={676}
        kuralTranslation="Consider the end, the obstacles, and the benefit before acting."
      />
    </main>

    <Footer />
  </body>
</html>
