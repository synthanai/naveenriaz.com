---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import TamilRoot from "../../components/TamilRoot.astro";

// Use negative dates to sort backwards
const allSpars = (await getCollection("spars")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base
  title="SPARs | Multi-player Dialectic"
  description="Structured Persona Argumentation. Testing ideas through structured friction."
>
  <Header activeNav="vibe" />
  <main class="spar-index section">
    <div class="container container--narrow">
      <header class="section-header align-center">
        <h1>SPARs</h1>
        <p class="section-subtitle">
          Multi-player dialectic. Testing ideas through structured friction.
        </p>
      </header>

      <div class="spar-list">
        {allSpars.length > 0 ? (
          allSpars.map((spar) => {
            const formattedDate = spar.data.date.toLocaleDateString("en-GB", {
              day: "numeric",
              month: "short",
              year: "numeric",
            });
            return (
              <a href={`/spars/${spar.slug}/`} class="spar-list-item">
                <div class="spar-item-meta">
                  <span class="spar-item-date">{formattedDate}</span>
                  {spar.data.confidence && <span class="spar-confidence-badge">{spar.data.confidence}</span>}
                </div>
                <h2>{spar.data.title}</h2>
                <p>{spar.data.description}</p>
                <div class="spar-item-read">
                  Read Transcript <span class="arrow">→</span>
                </div>
              </a>
            );
          })
        ) : (
          <p class="empty-state">No SPAR sessions have been published yet.</p>
        )}
      </div>

    </div>
  </main>
  <Footer />
</Base>

<style>
  .spar-index {
    min-height: 70vh;
  }

  .spar-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    margin-top: var(--space-2xl);
  }

  .spar-list-item {
    display: block;
    padding: var(--space-xl);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    transition: all var(--transition-normal);
    text-decoration: none;
    position: relative;
    overflow: hidden;
  }

  /* Left accent border */
  .spar-list-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--vibe-color);
    opacity: 0.5;
    transition: opacity var(--transition-normal);
  }

  .spar-list-item:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.1);
    transform: translateY(-2px);
  }

  .spar-list-item:hover::before {
    opacity: 1;
  }

  .spar-item-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-sm);
  }

  .spar-item-date {
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--vibe-color);
    text-transform: uppercase;
  }

  .spar-confidence-badge {
    font-family: var(--font-label);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--bg-primary);
    background: var(--vibe-color);
    padding: 2px 8px;
    border-radius: 12px;
  }

  .spar-list-item h2 {
    font-size: 1.4rem;
    color: var(--text-primary);
    margin-bottom: var(--space-xs);
    line-height: 1.3;
  }

  .spar-list-item p {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  .spar-item-read {
    font-family: var(--font-label);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 8px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .spar-item-read .arrow {
    transition: transform var(--transition-fast);
    color: var(--vibe-color);
  }

  .spar-list-item:hover .arrow {
    transform: translateX(4px);
  }

  .empty-state {
    text-align: center;
    color: var(--text-muted);
    font-style: italic;
    padding: var(--space-2xl) 0;
  }

  @media (max-width: 768px) {
    .spar-list-item {
      padding: var(--space-lg);
    }
  }
</style>
