---
/**
 * Arena Detail Page — Individual SPAR debate view
 * Dynamic route: /arena/[id]/
 * Reads from arena.json
 */
import Page from '../../layouts/Page.astro';
import arenaData from '../../data/arena.json';

export function getStaticPaths() {
  return arenaData.spars
    .filter(s => s.visibility === 'public')
    .map(s => ({
      params: { id: s.id },
      props: { spar: s }
    }));
}

const { spar } = Astro.props;

const dimColors: Record<string, string> = {
  think: 'var(--mind-color)',
  work: 'var(--body-color)',
  play: 'var(--soul-color)',
  soul: 'var(--soul-color)',
};

const dimClass = spar.dimension === 'think' ? 'mind' : spar.dimension === 'work' ? 'body' : 'soul';
const dimLabel = spar.dimension === 'think' ? 'Think' : spar.dimension === 'work' ? 'Work' : 'Play';
---

<Page title={`SPAR #${spar.number}: ${spar.title}`} description={spar.question} activeNav="arena">

  <!-- Hero -->
  <section class="spar-hero">
    <div class="orb" style={`width:400px;height:400px;background:${dimColors[spar.dimension]};top:-120px;right:-100px;`}></div>

    <div class="container container--narrow" style="text-align:center;">
      <span class={`spar-badge spar-badge--${dimClass}`}>SPAR #{spar.number.toString().padStart(3, '0')}</span>
      <h1>{spar.title}</h1>
      <p class="spar-question">{spar.question}</p>

      <div class="spar-meta-bar">
        <span class="meta-item">
          <span class="meta-label">Date</span>
          <span class="meta-value">{new Date(spar.date).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
        </span>
        <span class="meta-sep">·</span>
        <span class="meta-item">
          <span class="meta-label">RAMP</span>
          <span class="meta-value">{spar.ramp}</span>
        </span>
        <span class="meta-sep">·</span>
        <span class="meta-item">
          <span class="meta-label">Confidence</span>
          <span class="meta-value" style={`color:${dimColors[spar.dimension]};`}>{spar.confidence}%</span>
        </span>
        <span class="meta-sep">·</span>
        <span class="meta-item">
          <span class="meta-label">Config</span>
          <span class="meta-value meta-value--mono">{spar.tesseract.depth} / {spar.tesseract.pattern} / {spar.tesseract.style}</span>
        </span>
      </div>
    </div>
  </section>

  <!-- Agents -->
  <section class="section--tight">
    <div class="container container--narrow">
      <h2 class="section-label">Agents in the Arena</h2>
      <div class="agents-grid">
        {spar.agents.map(agent => (
          <span class={`agent-tag ${agent === 'PROBE' ? 'agent-tag--probe' : ''}`}>{agent}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Key Tensions -->
  <section class="section--tight">
    <div class="container container--narrow">
      <h2 class="section-label">Key Tensions</h2>
      <div class="tensions-list">
        {spar.tensions.map((tension, i) => (
          <div class="tension-row">
            <span class="tension-num">{i + 1}</span>
            <p class="tension-text">{tension}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Best Exchange -->
  {spar.bestExchange && (
    <section class="section--tight">
      <div class="container container--narrow">
        <h2 class="section-label">Most Compelling Exchange</h2>
        <blockquote class="best-exchange">
          <p>"{spar.bestExchange.quote}"</p>
          <cite>— {spar.bestExchange.agent}</cite>
        </blockquote>
      </div>
    </section>
  )}

  <!-- Synthesis -->
  <section class="section--tight">
    <div class="container container--narrow">
      <h2 class="section-label">Synthesis</h2>
      <div class="synthesis-block">
        <p>{spar.synthesis}</p>
      </div>
    </div>
  </section>

  <!-- Verdict -->
  <section class="section--tight">
    <div class="container container--narrow">
      <div class={`verdict-card verdict-card--${dimClass}`}>
        <span class="verdict-label">Verdict</span>
        <h2 class="verdict-value">{spar.verdict}</h2>
        <div class="verdict-meta">
          <span>{spar.confidence}% confidence</span>
          <span>·</span>
          <span>{spar.ramp}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Dissent -->
  {spar.dissent && (
    <section class="section--tight">
      <div class="container container--narrow">
        <h2 class="section-label">Dissent Record</h2>
        <p class="dissent-text">{spar.dissent}</p>
      </div>
    </section>
  )}

  <!-- Back link -->
  <section class="section--tight">
    <div class="container container--narrow" style="text-align: center;">
      <a href="/arena/" class="back-link">← Back to the Arena</a>
    </div>
  </section>

</Page>

<style>
  .spar-hero {
    padding: var(--space-4xl) 0 var(--space-xl);
    position: relative;
    overflow: hidden;
  }

  .spar-badge {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border: 1px solid;
    border-radius: 20px;
    padding: 4px 16px;
    margin-bottom: var(--space-md);
  }

  .spar-badge--mind { color: var(--mind-color); border-color: var(--mind-color); }
  .spar-badge--body { color: var(--body-color); border-color: var(--body-color); }
  .spar-badge--soul { color: var(--soul-color); border-color: var(--soul-color); }

  .spar-question {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 540px;
    margin: var(--space-sm) auto var(--space-lg);
    line-height: 1.6;
  }

  .spar-meta-bar {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
    font-size: 0.8rem;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .meta-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .meta-value {
    color: var(--text-secondary);
    font-family: var(--font-heading);
    font-weight: 600;
  }

  .meta-value--mono {
    font-size: 0.7rem;
    font-family: monospace;
    color: var(--text-muted);
  }

  .meta-sep {
    color: rgba(255, 255, 255, 0.1);
    font-size: 1rem;
    align-self: flex-end;
    margin-bottom: 2px;
  }

  .section-label {
    font-family: var(--font-label);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-xs);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  /* Agents */
  .agents-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .agent-tag {
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-secondary);
    background: var(--bg-card);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 20px;
    padding: 5px 14px;
    letter-spacing: 0.02em;
  }

  .agent-tag--probe {
    color: var(--accent);
    border-color: var(--accent-border);
  }

  /* Tensions */
  .tensions-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .tension-row {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .tension-num {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-card);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 50%;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-dim);
  }

  .tension-text {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    padding-top: 3px;
  }

  /* Best Exchange */
  .best-exchange {
    background: var(--bg-card);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-left: 3px solid var(--accent);
    border-radius: var(--border-radius);
    padding: var(--space-xl);
    margin: 0;
  }

  .best-exchange p {
    font-size: 1.05rem;
    color: var(--text-primary);
    line-height: 1.7;
    font-style: italic;
    margin: 0 0 var(--space-md);
  }

  .best-exchange cite {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    font-style: normal;
    letter-spacing: 0.03em;
  }

  /* Synthesis */
  .synthesis-block {
    background: var(--bg-card);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: var(--border-radius-lg);
    padding: var(--space-xl);
  }

  .synthesis-block p {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.8;
    margin: 0;
  }

  /* Verdict */
  .verdict-card {
    text-align: center;
    background: var(--bg-card);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--border-radius-lg);
    padding: var(--space-2xl) var(--space-xl);
  }

  .verdict-card--mind { border-top: 3px solid var(--mind-color); }
  .verdict-card--body { border-top: 3px solid var(--body-color); }
  .verdict-card--soul { border-top: 3px solid var(--soul-color); }

  .verdict-label {
    font-family: var(--font-label);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
    display: block;
    margin-bottom: var(--space-sm);
  }

  .verdict-value {
    font-size: 2rem;
    margin: 0 0 var(--space-md);
  }

  .verdict-meta {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* Dissent */
  .dissent-text {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
    font-style: italic;
    border-left: 2px solid rgba(255, 255, 255, 0.06);
    padding-left: var(--space-md);
  }

  /* Back link */
  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
    padding: var(--space-sm) var(--space-md);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--border-radius);
    transition: all var(--transition-base);
  }

  .back-link:hover {
    color: var(--accent);
    border-color: var(--accent-border);
  }

  @media (max-width: 600px) {
    .spar-meta-bar {
      flex-direction: column;
      gap: var(--space-md);
    }
    .meta-sep { display: none; }
    .meta-item { flex-direction: row; gap: var(--space-sm); }
  }
</style>
