---
import PrimeLayout from '../../../layouts/PrimeLayout.astro';
import { AuraMap } from '../../../components/prime/onboarding/AuraMap';
import { synthesizeSights } from '../../../components/prime/onboarding/SynthesisEngine';

// We will handle the logic client-side to ensure VAULT-KIT privacy (local-first)
---

<PrimeLayout title="Day 3: REVEAL">
  <div class="reveal-page">
    <div id="reveal-container">
      
      <!-- Act 1: The Synthesis (The Aura Map) -->
      <section id="act-1" class="active">
        <h1 class="reveal-title">Day 3: THE REVEAL</h1>
        <p class="reveal-subtitle">Monday was Recall. Wednesday was Resonance. Today, we map the Shift.</p>
        
        <div id="aura-map-root"></div>

        <div class="sights-legend glass-card">
          <div class="legend-item"><span class="dot-blue"></span> Current Reality</div>
          <div class="legend-item"><span class="dot-gold"></span> Sovereign Potential</div>
        </div>

        <button id="see-the-brief" class="prime-btn">Read the Legacy Brief</button>
      </section>

      <!-- Act 2: The Brief -->
      <section id="act-2">
        <div class="vow-speech-box glass-card">
          <h2 class="brief-title">Sovereign Legacy Brief</h2>
          <p id="vow-brief-text" class="vow-voice"></p>
          <div class="legacy-highlights">
            <div class="h-item"><strong>Archetype:</strong> <span id="archetype-val"></span></div>
            <div class="h-item"><strong>Shadow:</strong> <span id="shadow-val"></span></div>
            <div class="h-item"><strong>Tension:</strong> <span id="tension-val"></span></div>
          </div>
          <button id="make-declaration" class="prime-btn">Make the Declaration</button>
        </div>
      </section>

      <!-- Act 3: The Declaration -->
      <section id="act-3">
        <h2 class="reveal-title">The Final Declaration</h2>
        <p class="reveal-subtitle">To Seal the Initiation, declare your intent for the 1.3M Legacy path. Your word is your bond.</p>
        
        <textarea id="declaration-input" placeholder="I declare that I will..." class="reveal-input"></textarea>
        
        <button id="seal-initiation" class="prime-btn">Seal the Initiation</button>
      </section>

      <!-- Completion -->
      <section id="act-complete">
        <h2 class="reveal-title">Initiation Sealed</h2>
        <p class="reveal-subtitle">You have transitioned from Prospect to Sovereign. Coach Naveen will see you in Session 1.</p>
        <a href="/prime/" class="prime-btn-reverse">Go to Dashboard</a>
      </section>

    </div>
  </div>

  <script data-aura-map={AuraMap} data-synthesize-sights={synthesizeSights}>
    import React from 'react';
    import ReactDOM from 'react-dom/client';
    import { AuraMap } from '../../../components/prime/onboarding/AuraMap';
    import { synthesizeSights } from '../../../components/prime/onboarding/SynthesisEngine';

    const act1 = document.getElementById('act-1');
    const act2 = document.getElementById('act-2');
    const act3 = document.getElementById('act-3');
    const actComplete = document.getElementById('act-complete');
    const auraMapRoot = document.getElementById('aura-map-root');

    let mondayData = null;
    let resonanceData = null;
    let finalSynthesis = null;

    // Load All Data (Janazah Privacy)
    const loadAllData = () => {
      const monRaw = localStorage.getItem('synthai_onboarding_monday') || localStorage.getItem('synthai_prime_chronicle');
      const wedRaw = localStorage.getItem('synthai_onboarding_wednesday');
      
      if (monRaw && wedRaw) {
        mondayData = JSON.parse(monRaw);
        resonanceData = JSON.parse(wedRaw);
        finalSynthesis = synthesizeSights(mondayData, resonanceData);
        return true;
      } else {
        window.location.href = '/prime/onboarding/monday';
        return false;
      }
    };

    if (loadAllData()) {
      // Render Aura Map
      if (auraMapRoot) {
        const root = ReactDOM.createRoot(auraMapRoot);
        root.render(React.createElement(AuraMap, {
          vectors: finalSynthesis.vectors
        }));
      }

      // Set Brief Values
      const briefText = document.getElementById('vow-brief-text');
      const archetypeVal = document.getElementById('archetype-val');
      const shadowVal = document.getElementById('shadow-val');
      const tensionVal = document.getElementById('tension-val');

      if (briefText) briefText.innerText = finalSynthesis.brief.legacyPath;
      if (archetypeVal) archetypeVal.innerText = finalSynthesis.brief.archetype.toUpperCase();
      if (shadowVal) shadowVal.innerText = finalSynthesis.brief.shadow.toUpperCase();
      if (tensionVal) tensionVal.innerText = finalSynthesis.brief.dissonancePoint.toUpperCase();
    }

    const seeBriefButton = document.getElementById('see-the-brief');
    if (seeBriefButton) {
      seeBriefButton.onclick = () => {
        act1?.classList.remove('active');
        act2?.classList.add('active');
      };
    }

    const declarationButton = document.getElementById('make-declaration');
    if (declarationButton) {
      declarationButton.onclick = () => {
        act2?.classList.remove('active');
        act3?.classList.add('active');
      };
    }

    const sealButton = document.getElementById('seal-initiation');
    if (sealButton) {
      sealButton.onclick = () => {
        const declarationInput = document.getElementById('declaration-input');
        const declaration = declarationInput?.value || '';
        localStorage.setItem('synthai_onboarding_final_declaration', declaration);
        act3?.classList.remove('active');
        actComplete?.classList.add('active');
      };
    }
  </script>

  <style>
    .reveal-page {
      min-height: 80vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    #reveal-container > section {
      display: none;
      width: 100%;
      max-width: 600px;
      animation: fadeIn 1s ease-out;
    }
    #reveal-container > section.active {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2rem;
    }

    @keyframes fadeIn {
      from { opacity: 0; filter: blur(10px); }
      to { opacity: 1; filter: blur(0); }
    }

    .reveal-title { 
      font-size: 2.8rem; font-weight: 900; 
      background: linear-gradient(135deg, #fff 0%, var(--p-gold) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      text-align: center; margin-bottom: 0.5rem;
    }
    .reveal-subtitle { color: var(--p-t3); font-size: 1rem; text-align: center; }

    .sights-legend { display: flex; gap: 2rem; padding: 1rem 2rem; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--p-t3); }
    .dot-blue { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--p-blue); margin-right: 6px; }
    .dot-gold { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--p-gold); margin-right: 6px; }

    .vow-speech-box { padding: 3rem; text-align: left; width: 100%; }
    .brief-title { font-size: 1.5rem; font-weight: 800; color: var(--p-gold); margin-bottom: 1.5rem; }
    .vow-voice { font-size: 1.25rem; line-height: 1.4; color: #fff; margin-bottom: 2rem; }

    .legacy-highlights { background: rgba(255,255,255,0.03); padding: 1.5rem; border-radius: 16px; margin-bottom: 2.5rem; border: 1px solid rgba(255,255,255,0.08); }
    .h-item { margin-bottom: 0.75rem; font-size: 0.9rem; color: var(--p-t3); }
    .h-item strong { color: var(--p-t2); text-transform: uppercase; font-size: 0.75rem; margin-right: 10px; }

    .reveal-input {
      width: 100%; min-height: 150px; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1);
      border-radius: 20px; padding: 1.5rem; color: #fff; font-family: inherit; font-size: 1.1rem;
      outline: none; margin-bottom: 2.5rem;
    }
    .reveal-input:focus { border-color: var(--p-gold); box-shadow: 0 0 20px rgba(212, 168, 67, 0.2); }

    .prime-btn {
      width: 100%; padding: 1.5rem; border-radius: 20px; background: var(--p-gold); color: #000; font-weight: 900; font-size: 1.1rem; border: none; cursor: pointer; text-align: center; text-decoration: none;
    }
    .prime-btn-reverse {
      display: block; width: 100%; padding: 1.5rem; border-radius: 20px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; text-align: center; text-decoration: none; margin-top: 2rem;
    }
  </style>
</PrimeLayout>
