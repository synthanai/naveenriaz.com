---
/**
 * Author — Books, Ebooks, Publications
 * Vibe sub-page scaffold
 */
import Page from "../layouts/Page.astro";
import TamilRoot from "../components/TamilRoot.astro";
---

<Page
    title="Author"
    description="13-book SHIFT series, ebooks, and research publications. Writing that bridges ancient wisdom and AI-era leadership."
    activeNav="author"
>
    <section class="scaffold-hero">
        <div
            class="orb"
            style="width:400px;height:400px;background:var(--mind-color);top:-160px;left:50%;transform:translateX(-50%);opacity:0.1;"
        >
        </div>
        <div class="container" style="text-align:center;">
            <span class="scaffold-label">Author</span>
            <h1>Words That <span class="gt">Build</span></h1>
            <p class="scaffold-desc">
                13-book SHIFT series. Ebooks. Research papers. Writing that
                bridges 2,000-year-old Tamil wisdom and AI-era leadership.
            </p>
        </div>
    </section>

    <section class="section--tight">
        <div class="container container--narrow">
            <TamilRoot
                tamil="ஆசிரியர்"
                transliteration="Aasiriyar"
                meaning="Author. One who shapes thought into permanent form. Not content creation, knowledge architecture."
                tamilMeaning="எண்ணத்தை நிரந்தர வடிவமாக வடிவமைப்பவர்."
                kural="எண்ணென்ப ஏனை எழுத்தென்ப இவ்விரண்டும் கண்ணென்ப வாழும் உயிர்க்கு."
                kuralNumber={392}
                kuralTranslation="Numbers and letters are the two eyes of the living."
            />
        </div>
    </section>

    <section class="section--tight">
        <div class="container container--narrow">
            <div class="manifesto">
                <h2>Coming <span class="gt">Soon</span></h2>
                <p>
                    Book catalog, publication timeline, and reading guides are
                    being assembled. Connect through the Vibe page.
                </p>
            </div>
        </div>
    </section>
</Page>

<style>
    .scaffold-hero {
        padding: var(--space-4xl) 0 var(--space-2xl);
        text-align: center;
        position: relative;
        overflow: hidden;
    }
    .scaffold-label {
        font-family: var(--font-label);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: var(--space-sm);
        display: block;
    }
    .scaffold-desc {
        max-width: 600px;
        margin: var(--space-md) auto 0;
        color: var(--text-secondary);
        font-size: 1.05rem;
        line-height: 1.7;
    }
</style>
