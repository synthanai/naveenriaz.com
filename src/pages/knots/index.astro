---
import { getCollection } from 'astro:content';
import Page from '../../layouts/Page.astro';

const allKnots = await getCollection('knots');
const sortedKnots = allKnots.sort((a, b) => a.data.knot_number - b.data.knot_number);

const domainMap: Record<string, Record<string, typeof sortedKnots>> = {};
for (const knot of sortedKnots) {
  const d = knot.data.domain;
  const s = knot.data.series;
  if (!domainMap[d]) domainMap[d] = {};
  if (!domainMap[d][s]) domainMap[d][s] = [];
  domainMap[d][s].push(knot);
}

const seriesOrder = [
  'identity', 'culture', 'trust',
  'decisions', 'change', 'intelligence',
  'structure', 'capability', 'energy',
];

const seriesColors: Record<string, [string, string]> = {
  identity: ["#D4A843", "rgba(212, 168, 67, 0.10)"],
  culture: ["#D4A843", "rgba(212, 168, 67, 0.08)"],
  trust: ["#D4A843", "rgba(212, 168, 67, 0.06)"],
  decisions: ["#2874A6", "rgba(40, 116, 166, 0.10)"],
  change: ["#2874A6", "rgba(40, 116, 166, 0.08)"],
  intelligence: ["#2874A6", "rgba(40, 116, 166, 0.06)"],
  structure: ["#27ae60", "rgba(39, 174, 96, 0.10)"],
  capability: ["#27ae60", "rgba(39, 174, 96, 0.08)"],
  energy: ["#27ae60", "rgba(39, 174, 96, 0.06)"],
};

const seriesLayer: Record<string, string> = {
  identity: "Soul", culture: "Soul", trust: "Soul",
  decisions: "Mind", change: "Mind", intelligence: "Mind",
  structure: "Body", capability: "Body", energy: "Body",
};

const domainLabels: Record<string, [string, string]> = {
  organizations: ["🏢", "Organizations"],
  education: ["🎓", "Education"],
};

const domainOrder = ['organizations', 'education'];
---

<Page title="108 Knots" description="108 knots that tangle every system. Named, felt, untied." activeNav="knots">
  <section class="knots-hero">
    <div class="container">
      <p class="hero-badge">UNTANGLING THE WORLD</p>
      <h1>108 <span class="title-accent">Knots</span></h1>
      <p class="hero-sub">
        Every system tangles itself the same way.
        One a day. Named, felt, untied.
      </p>
    </div>
  </section>

  <section class="knots-index container">
    {domainOrder.map((domainName) => {
      const seriesMap = domainMap[domainName];
      if (!seriesMap) return null;

      const totalKnots = Object.values(seriesMap).reduce((sum, k) => sum + k.length, 0);
      const [emoji, label] = domainLabels[domainName] || ["📦", domainName];

      return (
        <details class="accordion" id={`domain-${domainName}`}>
          <summary class="accordion__head accordion__head--domain">
            <span class="accordion__icon">{emoji}</span>
            <span class="accordion__title">{label}</span>
            <span class="accordion__badge">{totalKnots} / 108</span>
            <svg class="accordion__caret" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M4 2L8 6L4 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </summary>

          <div class="accordion__body">
            {seriesOrder.map((seriesName) => {
              const knots = seriesMap[seriesName];
              if (!knots || knots.length === 0) return null;

              const [solidColor, glowColor] = seriesColors[seriesName];
              const layer = seriesLayer[seriesName];
              const seriesNum = seriesOrder.indexOf(seriesName) + 1;

              return (
                <details class="accordion accordion--nested">
                  <summary class="accordion__head accordion__head--series" style={`--s-solid: ${solidColor}; --s-glow: ${glowColor}`}>
                    <span class="accordion__pip" style={`background: ${solidColor}`}></span>
                    <span class="accordion__layer" style={`color: ${solidColor}`}>{layer}</span>
                    <span class="accordion__title accordion__title--sm">
                      {seriesNum}. {seriesName.charAt(0).toUpperCase() + seriesName.slice(1)}
                    </span>
                    <span class="accordion__badge">{knots.length}</span>
                    <svg class="accordion__caret" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M4 2L8 6L4 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  </summary>

                  <div class="knot-grid">
                    {knots.map((knot) => {
                      const num = String(knot.data.knot_number).padStart(3, '0');
                      const [sc] = seriesColors[seriesName];
                      return (
                        <a href={`/knots/${knot.id}`} class="knot-card" style={`--kc: ${sc}; --kg: ${glowColor}`}>
                          <span class="knot-card__num" style={`color: ${sc}`}>#{num}</span>
                          <span class="knot-card__title">{knot.data.title.replace(/-/g, ' ')}</span>
                          <span class="knot-card__punch">{knot.data.punch_line_2}</span>
                        </a>
                      );
                    })}
                  </div>
                </details>
              );
            })}
          </div>
        </details>
      );
    })}
  </section>
</Page>

<style>
  /* ═══ Hero ═══ */
  .knots-hero {
    padding: var(--space-3xl) 0 var(--space-xl);
    text-align: center;
  }
  .hero-badge {
    font-family: var(--font-label);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: var(--space-sm);
  }
  .knots-hero h1 {
    font-size: clamp(2.5rem, 7vw, 4rem);
    font-weight: 800;
    color: var(--text-primary) !important;
    margin-bottom: var(--space-sm);
  }
  .title-accent {
    background: linear-gradient(135deg, var(--soul-color), var(--mind-color), var(--body-color));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub {
    font-size: 1rem;
    color: var(--text-secondary);
    max-width: 420px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .knots-index { padding-bottom: var(--space-4xl); }

  /* ═══ Accordion (shared) ═══ */
  .accordion { margin-bottom: var(--space-sm); }
  .accordion__head {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 20px;
    cursor: pointer;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px;
    list-style: none;
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .accordion__head::-webkit-details-marker,
  .accordion__head::marker { display: none; content: ''; }
  .accordion__head:hover {
    background: rgba(255,255,255,0.03);
    border-color: rgba(255,255,255,0.12);
  }

  /* Caret rotation */
  .accordion__caret {
    color: rgba(255,255,255,0.3);
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }
  details[open] > .accordion__head .accordion__caret {
    transform: rotate(90deg);
  }

  .accordion__icon { font-size: 1.2rem; flex-shrink: 0; }
  .accordion__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--text-primary);
    flex: 1;
  }
  .accordion__title--sm { font-size: 0.92rem; font-weight: 600; }
  .accordion__badge {
    font-family: var(--font-label);
    font-size: 0.68rem;
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    background: rgba(255,255,255,0.05);
    padding: 3px 10px;
    border-radius: 12px;
    letter-spacing: 0.04em;
  }

  /* ─── Domain-level ─── */
  .accordion__head--domain {
    background: linear-gradient(135deg, rgba(255,255,255,0.02), transparent);
  }
  .accordion__body {
    padding: var(--space-xs) 0 var(--space-sm) 20px;
  }

  /* ─── Series-level ─── */
  .accordion--nested { margin-top: 4px; }
  .accordion__head--series {
    padding: 10px 16px;
    border-color: transparent;
    border-left: 3px solid var(--s-solid, rgba(255,255,255,0.1));
    border-radius: 0 10px 10px 0;
  }
  .accordion__head--series:hover {
    background: var(--s-glow, rgba(255,255,255,0.02));
    border-left-color: var(--s-solid);
  }
  .accordion__pip {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .accordion__layer {
    font-family: var(--font-label);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    min-width: 28px;
  }

  /* ═══ Knot Cards ═══ */
  .knot-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 8px;
    padding: 8px 0 12px 24px;
  }

  .knot-card {
    display: flex;
    flex-direction: column;
    padding: 14px 16px;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.06);
    background: linear-gradient(180deg, var(--kg, rgba(255,255,255,0.02)), transparent);
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .knot-card:hover {
    transform: translateY(-2px);
    border-color: var(--kc, rgba(255,255,255,0.15));
    box-shadow: 0 6px 20px rgba(0,0,0,0.4);
    text-decoration: none;
  }
  .knot-card__num {
    font-family: var(--font-label);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .knot-card__title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    color: #ffffff;
    text-transform: capitalize;
    line-height: 1.25;
  }
  .knot-card__punch {
    font-family: var(--font-body);
    font-size: 0.7rem;
    color: rgba(255,255,255,0.35);
    font-style: italic;
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid rgba(255,255,255,0.04);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ═══ Responsive ═══ */
  @media (max-width: 640px) {
    .knot-grid {
      grid-template-columns: 1fr 1fr;
      gap: 6px;
      padding-left: 12px;
    }
    .accordion__body { padding-left: 8px; }
    .accordion__head--domain { padding: 12px 14px; }
    .accordion__title { font-size: 1rem; }
    .knot-card__punch { display: none; }
  }
</style>
