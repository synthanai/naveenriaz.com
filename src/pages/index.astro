---
/**
 * Home Page — Layer 1
 * Logo, name, MBS tagline, dimension nav, Kural #396, connect links.
 * All links verified. No internal ecosystem vocabulary.
 */
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Naveen Riaz | நவீன் ரியாஸ்</title>
    <meta
      name="description"
      content="Every organisation, community, product, and service is alive. Nurture its Mind, Body & Soul. Watch it thrive."
    />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Naveen Riaz | நவீன் ரியாஸ்" />
    <meta property="og:description" content="Every organisation, community, product, and service is alive. Nurture its Mind, Body & Soul. Watch it thrive." />
    <meta property="og:image" content="https://naveenriaz.com/og-image.png" />
    <meta property="og:url" content="https://naveenriaz.com/" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Header activeNav="home" />

    <!-- ═══ Hero ═══ -->
    <section class="hero">
      <div class="container hero-inner">
        <img src="/logo.svg" alt="" class="hero-logo" aria-hidden="true" />
        <h1>
          <span class="hero-name">Naveen Riaz</span>
          <span class="hero-tamil">நவீன் ரியாஸ்</span>
        </h1>
        <p class="hero-tagline">
          Everything we build is alive.<br />
          Nurture its <span class="c-mind">Mind</span>,
          <span class="c-body">Body</span> &amp;
          <span class="c-soul">Soul</span>.<br />
          Watch it thrive.
        </p>
      </div>
    </section>

    <!-- ═══ Three Dimensions ═══ -->
    <section class="dimensions section">
      <div class="container">
        <div class="dim-grid">
          <a href="/think/" class="dim-card dim-card--mind">
            <div class="dim-header">
              <span class="glow-dot" style="color: var(--mind-color);"></span>
              <h2>Think</h2>
            </div>
            <p class="dim-tamil">சிந்தனை</p>
            <p class="dim-desc">
              How I reason. Structured deliberation, intelligence capture, and
              cognitive architecture for the AI era.
            </p>
          </a>
          <a href="/play/" class="dim-card dim-card--soul">
            <div class="dim-header">
              <span class="glow-dot" style="color: var(--soul-color);"></span>
              <h2>Play</h2>
            </div>
            <p class="dim-tamil">ஆன்மா</p>
            <p class="dim-desc">
              Who I am. Tamil roots, identity architecture, and the philosophy
              that governs everything I build.
            </p>
          </a>
          <a href="/work/" class="dim-card dim-card--body">
            <div class="dim-header">
              <span class="glow-dot" style="color: var(--body-color);"></span>
              <h2>Work</h2>
            </div>
            <p class="dim-tamil">செயல்</p>
            <p class="dim-desc">
              What I build. Papers, open source tools, and books. Soul
              aspirations, Mind cooking, Body shipped.
            </p>
          </a>
          <a href="/vibe/" class="dim-card dim-card--vibe">
            <div class="dim-header">
              <span class="glow-dot" style="color: var(--vibe-color);"></span>
              <h2>Vibe</h2>
            </div>
            <p class="dim-tamil">ஒத்திசை</p>
            <p class="dim-desc">
              How to connect. Conversation topics, shared frequencies, and the
              invitation to resonate.
            </p>
          </a>
        </div>
      </div>
    </section>

    <!-- ═══ Content Architecture ═══ -->
    <section class="knots-feature section--tight">
      <div class="container container--narrow" style="text-align: center;">
        <p class="knots-badge">THE CONTENT ARCHITECTURE</p>
        <h2 class="knots-headline">8 <span class="knots-accent">Primitives</span></h2>
        <p class="knots-desc">
          Everything published on this canvas is strictly typed by cadence and cognitive weight. Short forms for daily capture. Long forms for deep synthesis.
        </p>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-xl); text-align: left; margin-top: var(--space-3xl); margin-bottom: var(--space-xl);">
          
          <div class="arch-col dim-card dim-card--mind">
            <h3 style="color: var(--mind-color); font-size: 1rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--space-md);">Think</h3>
            <a href="/sparks/" style="text-decoration: none; display: block; margin-bottom: var(--space-lg);">
              <span class="knots-badge" style="color: var(--text-muted); font-size: 0.55rem;">SHORT FORM</span>
              <strong style="color: var(--text-primary); display: block; font-size: 1.1rem; margin-top: 4px;">Sparks</strong>
              <span style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;">Raw signal capture (100 words).</span>
            </a>
            <a href="/fusions/" style="text-decoration: none; display: block; margin-bottom: var(--space-lg);">
              <span class="knots-badge" style="color: var(--text-muted); font-size: 0.55rem;">LONG FORM</span>
              <strong style="color: var(--text-primary); display: block; font-size: 1.1rem; margin-top: 4px;">Fusions</strong>
              <span style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;">Cross-domain synthesis.</span>
            </a>
          </div>

          <div class="arch-col dim-card dim-card--body">
            <h3 style="color: var(--body-color); font-size: 1rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--space-md);">Work</h3>
            <a href="/knots/" style="text-decoration: none; display: block; margin-bottom: var(--space-lg);">
              <span class="knots-badge" style="color: var(--text-muted); font-size: 0.55rem;">SHORT FORM</span>
              <strong style="color: var(--text-primary); display: block; font-size: 1.1rem; margin-top: 4px;">Knots / Beads</strong>
              <span style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;">Friction untangled into tactical wisdom.</span>
            </a>
            <div style="display: block; margin-bottom: var(--space-lg); opacity: 0.7;">
              <span class="knots-badge" style="color: var(--text-muted); font-size: 0.55rem;">LONG FORM</span>
              <strong style="color: var(--text-primary); display: flex; align-items: center; gap: 8px; font-size: 1.1rem; margin-top: 4px;">
                Digs <span class="knots-badge" style="background: rgba(255,255,255,0.1); padding: 2px 6px; border-radius: 4px;">COMING SOON</span>
              </strong>
              <span style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;">Heavy literature and org excavation.</span>
            </div>
          </div>

          <div class="arch-col dim-card dim-card--soul">
            <h3 style="color: var(--soul-color); font-size: 1rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--space-md);">Play</h3>
            <div style="display: block; margin-bottom: var(--space-lg); opacity: 0.7;">
              <span class="knots-badge" style="color: var(--text-muted); font-size: 0.55rem;">SHORT FORM</span>
              <strong style="color: var(--text-primary); display: flex; align-items: center; gap: 8px; font-size: 1.1rem; margin-top: 4px;">
                Wows <span class="knots-badge" style="background: rgba(255,255,255,0.1); padding: 2px 6px; border-radius: 4px;">COMING SOON</span>
              </strong>
              <span style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;">Quick mindset shifts.</span>
            </div>
            <div style="display: block; margin-bottom: var(--space-lg); opacity: 0.7;">
              <span class="knots-badge" style="color: var(--text-muted); font-size: 0.55rem;">LONG FORM</span>
              <strong style="color: var(--text-primary); display: flex; align-items: center; gap: 8px; font-size: 1.1rem; margin-top: 4px;">
                Awes <span class="knots-badge" style="background: rgba(255,255,255,0.1); padding: 2px 6px; border-radius: 4px;">COMING SOON</span>
              </strong>
              <span style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;">Narrative-heavy emotional arcs.</span>
            </div>
          </div>

          <div class="arch-col dim-card dim-card--vibe">
            <h3 style="color: var(--vibe-color); font-size: 1rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--space-md);">Vibe</h3>
            <div style="display: block; margin-bottom: var(--space-lg); opacity: 0.7;">
              <span class="knots-badge" style="color: var(--text-muted); font-size: 0.55rem;">SHORT FORM</span>
              <strong style="color: var(--text-primary); display: flex; align-items: center; gap: 8px; font-size: 1.1rem; margin-top: 4px;">
                Syncs <span class="knots-badge" style="background: rgba(255,255,255,0.1); padding: 2px 6px; border-radius: 4px;">COMING SOON</span>
              </strong>
              <span style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;">Harmonic connections and shared frequencies.</span>
            </div>
            <div style="display: block; margin-bottom: var(--space-lg); opacity: 0.7;">
              <span class="knots-badge" style="color: var(--text-muted); font-size: 0.55rem;">LONG FORM</span>
              <strong style="color: var(--text-primary); display: flex; align-items: center; gap: 8px; font-size: 1.1rem; margin-top: 4px;">
                SPARs <span class="knots-badge" style="background: rgba(255,255,255,0.1); padding: 2px 6px; border-radius: 4px;">COMING SOON</span>
              </strong>
              <span style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;">Multi-player dialectic debates.</span>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══ Kural ═══ -->
    <section class="kural-section section--tight">
      <div class="container container--narrow">
        <blockquote class="kural-block">
          <p class="kural-tamil">
            தொட்டனைத் தூறும் மணற்கேணி மாந்தர்க்குக்<br />
            கற்றனைத் தூறும் அறிவு.
          </p>
          <p class="kural-en">
            Like a well that springs as you dig, knowledge springs as you learn.
          </p>
          <cite>Thirukkural #396</cite>
        </blockquote>
      </div>
    </section>

    <!-- ═══ Vibe CTA ═══ -->
    <section class="vibe-cta section--tight">
      <div class="container container--narrow" style="text-align: center;">
        <p class="vibe-text">
          Every engagement starts the same way: a conversation.
        </p>
        <div class="vibe-links">
          <a
            href="https://www.linkedin.com/in/mnaveenriaz/"
            target="_blank"
            rel="noopener"
            class="btn">LinkedIn</a
          >
          <a
            href="https://github.com/synthanai"
            target="_blank"
            rel="noopener"
            class="btn">GitHub</a
          >
        </div>
      </div>
    </section>

    <Footer />

    <style>
      .knots-feature {
        padding: var(--space-xl) 0;
      }

      .knots-badge {
        font-family: var(--font-label);
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.15em;
        color: var(--accent);
        margin-bottom: var(--space-xs);
      }

      .knots-headline {
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 800;
        color: var(--text-primary);
        margin-bottom: var(--space-sm);
      }

      .knots-accent {
        background: linear-gradient(
          135deg,
          var(--soul-color),
          var(--mind-color),
          var(--body-color)
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .knots-desc {
        font-size: 1rem;
        color: var(--text-secondary);
        max-width: 480px;
        margin: 0 auto var(--space-lg);
        line-height: 1.6;
      }
    </style>

  </body>
</html>
