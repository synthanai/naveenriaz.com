---
import Page from "../layouts/Page.astro";
import CollisionGate from "../components/CollisionGate.astro";
import TamilRoot from "../components/TamilRoot.astro";
import PulseMetrics from "../components/PulseMetrics.astro";
import AuthorityMetrics from "../components/AuthorityMetrics.astro";
import SocialProof from "../components/SocialProof.astro";
import NewsletterCTA from "../components/NewsletterCTA.astro";
import ConceptCard from "../components/ConceptCard.astro";
import revealData from "../data/reveal.json";
import conceptsData from "../data/concepts.json";

// Merge reveal data with concept file counts
const concepts = revealData.map((r) => {
  const node = conceptsData.nodes.find((n) => n.id === r.id);
  return {
    ...r,
    fileCount: node?.fileCount || 0,
    description: node?.description || "",
  };
});
---

<Page title="Naveen Riaz" activeNav="home">
  <!-- Scroll Progress Bar -->
  <div class="progress-bar" id="progress-bar"></div>

  <!-- ஃ Constellation Hero -->
  <section class="constellation-hero">
    <!-- Ambient orb glow (ported from STEAL ebook) -->
    <div
      class="orb"
      style="width:400px;height:400px;background:var(--mind-color);top:-100px;right:-100px;"
    >
    </div>
    <div
      class="orb"
      style="width:300px;height:300px;background:var(--soul-color);bottom:-50px;left:-100px;"
    >
    </div>

    <div class="constellation-container">
      <!-- The ஃ Triangle -->
      <div class="ahenam" role="navigation" aria-label="Explore dimensions">
        <!-- SVG connection lines -->
        <svg
          class="ahenam-lines"
          viewBox="0 0 600 520"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <line x1="300" y1="60" x2="80" y2="440" class="line line--play-think"
          ></line>
          <line x1="300" y1="60" x2="520" y2="440" class="line line--play-work"
          ></line>
          <line x1="80" y1="440" x2="520" y2="440" class="line line--think-work"
          ></line>
        </svg>

        <!-- Top dot: Play (Soul/Gold) -->
        <a
          href="/play/"
          class="ahenam-dot ahenam-dot--play"
          aria-label="Play: Why I Live"
        >
          <span class="dot-circle"></span>
          <span class="dot-label">Play</span>
          <span class="dot-sub">Why I Live</span>
        </a>

        <!-- Bottom-left dot: Think (Mind/Navy) -->
        <a
          href="/think/"
          class="ahenam-dot ahenam-dot--think"
          aria-label="Think: How I Think"
        >
          <span class="dot-circle"></span>
          <span class="dot-label">Think</span>
          <span class="dot-sub">How I Think</span>
        </a>

        <!-- Bottom-right dot: Work (Body/Green) -->
        <a
          href="/work/"
          class="ahenam-dot ahenam-dot--work"
          aria-label="Work: What I Build"
        >
          <span class="dot-circle"></span>
          <span class="dot-label">Work</span>
          <span class="dot-sub">What I Build</span>
        </a>

        <!-- Center: Collision Gate -->
        <div class="ahenam-center">
          <span class="collision-badge">A Question Worth Asking</span>
          <h2 class="collision-question" id="collision-q">
            What assumption about your organization are you holding right now
            that might be completely wrong?
          </h2>
          <span class="collision-pulse"></span>
        </div>

        <script>
          const questions = [
            "What assumption about your organization are you holding right now that might be completely wrong?",
            "If your team stopped all meetings tomorrow, what would actually break?",
            "What would happen if you treated disagreement as a feature, not a threat?",
            "Which of your 'best practices' would a newcomer question on day one?",
            "If AI could replace 30% of what you do tomorrow, which 30% would you protect?",
            "What is the one conversation your leadership team keeps avoiding?",
            "If your organization were a living system, what organ would be failing?",
          ];
          const el = document.getElementById("collision-q");
          if (el)
            el.textContent =
              questions[Math.floor(Math.random() * questions.length)];
        </script>
      </div>
    </div>
  </section>

  <!-- ஃ Divider -->
  <div class="ahenam-divider" aria-hidden="true">
    <img src="/logo-h.svg" class="divider-logo" width="48" height="14" alt="" />
  </div>

  <!-- Ecosystem Pulse -->
  <section class="section--tight">
    <div class="container">
      <PulseMetrics />
    </div>
  </section>

  <!-- Tamil Root -->
  <section class="section--tight">
    <div class="container container--narrow">
      <TamilRoot
        tamil="தோற்றம்"
        transliteration="Thottram"
        meaning="Emergence. New understanding is born when ideas from unrelated domains collide, compress, and ignite, like stars forming inside a nebula."
        tamilMeaning="தொடர்பற்ற துறைகளின் கருத்துக்கள் மோதி, அழுத்தி, பற்றவைக்கும்போது புதிய புரிதல் பிறக்கிறது."
        kural="தொட்டனைத்தூறும் மணற்கேணி மாந்தர்க்குக் கற்றனைத்தூறும் அறிவு."
        kuralNumber={396}
        kuralTranslation="Like a well that springs as you dig, knowledge springs as you learn."
      />
    </div>
  </section>

  <!-- ஃ Divider -->
  <div class="ahenam-divider" aria-hidden="true">
    <img src="/logo-h.svg" class="divider-logo" width="48" height="14" alt="" />
  </div>

  <!-- Manifesto -->
  <section class="section--tight">
    <div class="container container--narrow">
      <div class="manifesto">
        <h2>What is <span class="gt">The Nebula</span>?</h2>
        <p>
          This is not a blog. It is not a portfolio. It is a <strong
            >living cloud of ideas</strong
          >
          where patterns from unrelated domains collide, compress, and ignite into
          new stars.
        </p>
        <p>
          Ancient Tamil wisdom meets AI reasoning. Organizational consciousness
          meets neuroscience. Dialectic argumentation meets personal
          transformation. Each collision births something new. Each new star has
          its own <strong>AURA</strong>.
        </p>
        <p class="manifesto-signature">
          <img
            src="/logo-h.svg"
            class="sig-logo"
            width="48"
            height="14"
            alt=""
            aria-hidden="true"
          />
          Naveen Riaz Mohamed Kani
        </p>
      </div>
    </div>
  </section>

  <!-- Authority Metrics -->
  <section class="section--tight">
    <div class="container">
      <AuthorityMetrics />
    </div>
  </section>

  <!-- Social Proof -->
  <section class="section--tight">
    <div class="container">
      <SocialProof />
    </div>
  </section>

  <!-- ஃ Divider -->
  <div class="ahenam-divider" aria-hidden="true">
    <img src="/logo-h.svg" class="divider-logo" width="48" height="14" alt="" />
  </div>

  <!-- Newsletter CTA -->
  <section class="section--tight">
    <div class="container">
      <NewsletterCTA />
    </div>
  </section>

  <!-- ஃ Divider -->
  <div class="ahenam-divider" aria-hidden="true">
    <img src="/logo-h.svg" class="divider-logo" width="48" height="14" alt="" />
  </div>

  <!-- Vibe CTA -->
  <section class="section--tight">
    <div class="container container--narrow">
      <div class="vibe-cta">
        <span class="vibe-cta-label">Vibe</span>
        <h2>Let's <span class="gt">Build</span> Something</h2>
        <p>
          Speaking. Consulting. Coaching. Every engagement starts with a
          conversation, not a pitch deck.
        </p>
        <div class="vibe-cta-actions">
          <a href="/vibe/" class="btn btn--vibe">Let's Connect →</a>
          <a href="/challenge/" class="vibe-cta-link">or Challenge a Claim</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Concepts: The Constellation -->
  <section class="section--tight">
    <div class="container">
      <h2 class="concepts-title">The <span class="gt">Constellation</span></h2>
      <p class="concepts-subtitle">
        Patterns connecting across domains. Each a living framework, evolving
        with every pulse.
      </p>
      <div class="grid-3">
        {
          concepts.map((c) => (
            <ConceptCard
              id={c.id}
              status={c.status}
              publicName={c.publicName}
              teaserText={c.teaserText}
              revealText={c.revealText}
              description={c.description}
              dimension={c.dimension}
              fileCount={c.fileCount}
            />
          ))
        }
      </div>
    </div>
  </section>
</Page>

<style>
  /* ─── ஃ CONSTELLATION HERO ─── */
  .constellation-hero {
    padding: var(--space-2xl) 0 var(--space-xl);
    position: relative;
    overflow: hidden;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .constellation-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse at 50% 20%,
        rgba(196, 149, 106, 0.06) 0%,
        transparent 50%
      ),
      radial-gradient(
        ellipse at 20% 80%,
        rgba(26, 82, 118, 0.06) 0%,
        transparent 50%
      ),
      radial-gradient(
        ellipse at 80% 80%,
        rgba(39, 174, 96, 0.05) 0%,
        transparent 50%
      );
    pointer-events: none;
  }

  .constellation-container {
    width: 100%;
    max-width: 640px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  /* The ஃ Formation */
  .ahenam {
    position: relative;
    width: 100%;
    height: 480px;
  }

  /* SVG Connection Lines */
  .ahenam-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .line {
    stroke: rgba(255, 255, 255, 0.06);
    stroke-width: 1;
    stroke-dasharray: 6 4;
    transition: all 0.6s ease;
  }

  .ahenam:hover .line {
    stroke: rgba(255, 255, 255, 0.12);
  }

  .ahenam:hover .line--play-think {
    stroke: rgba(196, 149, 106, 0.15);
  }
  .ahenam:hover .line--play-work {
    stroke: rgba(196, 149, 106, 0.12);
  }
  .ahenam:hover .line--think-work {
    stroke: rgba(26, 82, 118, 0.12);
  }

  /* Dots */
  .ahenam-dot {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: inherit;
    z-index: 2;
    transition: transform 0.3s ease;
  }

  .ahenam-dot:hover {
    transform: scale(1.08);
  }

  /* Positions: Play top, Think bottom-left, Work bottom-right */
  .ahenam-dot--play {
    top: 0;
    left: 50%;
    transform: translateX(-50%);
  }
  .ahenam-dot--play:hover {
    transform: translateX(-50%) scale(1.08);
  }

  .ahenam-dot--think {
    bottom: 0;
    left: 8%;
  }

  .ahenam-dot--work {
    bottom: 0;
    right: 8%;
  }

  .dot-circle {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid;
    position: relative;
    transition: all 0.4s ease;
  }

  .dot-circle::after {
    content: "";
    position: absolute;
    inset: 5px;
    border-radius: 50%;
    transition: all 0.4s ease;
  }

  .ahenam-dot--think .dot-circle {
    border-color: var(--mind-color);
  }
  .ahenam-dot--think .dot-circle::after {
    background: var(--mind-color);
  }
  .ahenam-dot--think:hover .dot-circle {
    box-shadow:
      0 0 20px var(--mind-glow),
      0 0 40px var(--mind-glow);
  }

  .ahenam-dot--work .dot-circle {
    border-color: var(--body-color);
  }
  .ahenam-dot--work .dot-circle::after {
    background: var(--body-color);
  }
  .ahenam-dot--work:hover .dot-circle {
    box-shadow:
      0 0 20px var(--body-glow),
      0 0 40px var(--body-glow);
  }

  .ahenam-dot--play .dot-circle {
    border-color: var(--soul-color);
  }
  .ahenam-dot--play .dot-circle::after {
    background: var(--soul-color);
  }
  .ahenam-dot--play:hover .dot-circle {
    box-shadow:
      0 0 20px var(--soul-glow),
      0 0 40px var(--soul-glow);
  }

  .dot-label {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
  }

  .ahenam-dot--think .dot-label {
    color: var(--mind-color);
  }
  .ahenam-dot--work .dot-label {
    color: var(--body-color);
  }
  .ahenam-dot--play .dot-label {
    color: var(--soul-color);
  }

  .dot-sub {
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.03em;
  }

  /* Center: Collision Gate */
  .ahenam-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -42%);
    text-align: center;
    max-width: 380px;
    z-index: 1;
  }

  .collision-badge {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent-border);
    border-radius: 20px;
    padding: 4px 14px;
    margin-bottom: var(--space-md);
  }

  .collision-question {
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    font-weight: 700;
    line-height: 1.35;
    color: var(--text-primary);
  }

  .collision-pulse {
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    margin: var(--space-md) auto 0;
    animation: pulse 3s ease-in-out infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 0.4;
      box-shadow: 0 0 0 0 var(--accent);
    }
    50% {
      opacity: 1;
      box-shadow: 0 0 12px 4px var(--accent);
    }
  }

  /* ─── ஃ DIVIDER ─── */
  .ahenam-divider {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    padding: var(--space-lg) 0;
  }

  .div-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    opacity: 0.6;
  }

  .div-dot--think {
    background: var(--mind-color);
    box-shadow:
      0 0 0 2px rgba(40, 116, 166, 0.15),
      0 0 5px var(--mind-color);
  }
  .div-dot--work {
    background: var(--body-color);
    box-shadow:
      0 0 0 2px rgba(39, 174, 96, 0.15),
      0 0 5px var(--body-color);
  }
  .div-dot--play {
    background: var(--soul-color);
    box-shadow:
      0 0 0 2px rgba(212, 168, 67, 0.15),
      0 0 5px var(--soul-color);
  }

  /* ─── MANIFESTO ─── */
  .manifesto {
    text-align: center;
    padding: var(--space-2xl) 0;
  }

  .manifesto h2 {
    margin-bottom: var(--space-lg);
  }

  .manifesto p {
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .manifesto-signature {
    margin-top: var(--space-xl);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.95rem;
  }

  .sig-dots {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    width: 36px;
    justify-content: center;
    gap: 2px;
  }

  .sig-dots::before {
    content: "";
    display: block;
  }

  .sig-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 1.5px solid;
    position: relative;
    background: transparent;
  }

  .sig-dot::after {
    content: "";
    position: absolute;
    inset: 2px;
    border-radius: 50%;
  }

  .sig-dot--play {
    border-color: var(--soul-color);
  }
  .sig-dot--play::after {
    background: var(--soul-color);
  }

  .sig-dot--think {
    border-color: var(--mind-color);
    flex-basis: 100%;
    margin: 0 auto;
    width: 12px;
  }
  .sig-dot--think::after {
    background: var(--mind-color);
  }

  .sig-dot--work {
    border-color: var(--body-color);
  }
  .sig-dot--work::after {
    background: var(--body-color);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 600px) {
    .constellation-hero {
      min-height: 60vh;
    }

    .collision-question {
      font-size: 1rem;
    }

    .dot-circle {
      width: 22px;
      height: 22px;
    }

    .dot-label {
      font-size: 0.8rem;
    }

    .dot-sub {
      font-size: 0.65rem;
    }

    .ahenam-center {
      max-width: 260px;
    }
  }

  /* ─── CONCEPTS SECTION ─── */
  .concepts-title {
    font-family: var(--font-label);
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-xs);
  }

  .concepts-subtitle {
    font-size: 0.88rem;
    color: var(--text-dim);
    margin-bottom: var(--space-xl);
  }

  .grid-3 {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  /* ── Vibe CTA ───────────────────────────────── */
  .vibe-cta {
    text-align: center;
    padding: var(--space-2xl) var(--space-xl);
    background: var(--bg-card);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--section-radius, 24px);
    border-top: 3px solid var(--soul-color);
  }

  .vibe-cta-label {
    font-family: var(--font-label);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--soul-color);
    display: block;
    margin-bottom: var(--space-sm);
  }

  .vibe-cta p {
    max-width: 420px;
    margin: var(--space-sm) auto var(--space-lg);
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .vibe-cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .btn--vibe {
    display: inline-flex;
    align-items: center;
    padding: var(--space-sm) var(--space-xl);
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 20px;
    border: 1px solid var(--soul-color);
    color: var(--soul-color);
    background: rgba(212, 168, 67, 0.06);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .btn--vibe:hover {
    background: rgba(212, 168, 67, 0.15);
    color: var(--accent-light);
    box-shadow: 0 4px 20px var(--soul-glow);
  }

  .vibe-cta-link {
    font-size: 0.78rem;
    color: var(--text-dim);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .vibe-cta-link:hover {
    color: var(--mind-color);
  }
</style>

<script>
  const pb = document.getElementById("progress-bar");
  if (pb) {
    window.addEventListener("scroll", () => {
      const pct =
        (window.scrollY /
          (document.documentElement.scrollHeight - window.innerHeight)) *
        100;
      pb.style.width = pct + "%";
    });
  }
</script>
