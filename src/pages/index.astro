---
/**
 * Home Page — Layer 1
 * Logo, name, MBS tagline, dimension nav, Kural #396, connect links.
 * All links verified. No internal ecosystem vocabulary.
 */
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Naveen Riaz | நவீன் ரியாஸ்</title>
    <meta
      name="description"
      content="Every organisation, community, product, and service is alive. Nurture its Mind, Body & Soul. Watch it thrive."
    />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Naveen Riaz | நவீன் ரியாஸ்" />
    <meta property="og:description" content="Every organisation, community, product, and service is alive. Nurture its Mind, Body & Soul. Watch it thrive." />
    <meta property="og:image" content="https://naveenriaz.com/og-image.png" />
    <meta property="og:url" content="https://naveenriaz.com/" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Header activeNav="home" />

    <!-- ═══ Hero ═══ -->
    <section class="hero">
      <div class="container hero-inner">
        <img src="/logo.svg" alt="" class="hero-logo" aria-hidden="true" />
        <h1>
          <span class="hero-name">Naveen Riaz</span>
          <span class="hero-tamil">நவீன் ரியாஸ்</span>
        </h1>
        <p class="hero-tagline">
          Everything we build is alive.<br />
          Nurture its <span class="c-mind">Mind</span>,
          <span class="c-body">Body</span> &amp;
          <span class="c-soul">Soul</span>.<br />
          Watch it thrive.
        </p>
      </div>
    </section>

    <!-- ═══ Three Dimensions ═══ -->
    <section class="dimensions section">
      <div class="container">
        <div class="dim-grid">
          <a href="/think/" class="dim-card dim-card--mind">
            <div class="dim-header">
              <span class="glow-dot" style="color: var(--mind-color);"></span>
              <h2>Think</h2>
            </div>
            <p class="dim-tamil">சிந்தனை</p>
            <p class="dim-desc">
              How I reason. Structured deliberation, intelligence capture, and
              cognitive architecture for the AI era.
            </p>
          </a>
          <a href="/play/" class="dim-card dim-card--soul">
            <div class="dim-header">
              <span class="glow-dot" style="color: var(--soul-color);"></span>
              <h2>Play</h2>
            </div>
            <p class="dim-tamil">ஆன்மா</p>
            <p class="dim-desc">
              Who I am. Tamil roots, identity architecture, and the philosophy
              that governs everything I build.
            </p>
          </a>
          <a href="/work/" class="dim-card dim-card--body">
            <div class="dim-header">
              <span class="glow-dot" style="color: var(--body-color);"></span>
              <h2>Work</h2>
            </div>
            <p class="dim-tamil">செயல்</p>
            <p class="dim-desc">
              What I build. Papers, open source tools, and books. Soul
              aspirations, Mind cooking, Body shipped.
            </p>
          </a>
          <a href="/vibe/" class="dim-card dim-card--vibe">
            <div class="dim-header">
              <span class="glow-dot" style="color: var(--vibe-color);"></span>
              <h2>Vibe</h2>
            </div>
            <p class="dim-tamil">ஒத்திசை</p>
            <p class="dim-desc">
              How to connect. Conversation topics, shared frequencies, and the
              invitation to resonate.
            </p>
          </a>
        </div>
      </div>
    </section>

    <!-- ═══ Content Architecture ═══ -->
    <section class="knots-feature section--tight">
      <div class="container container--narrow" style="text-align: center;">
        <p class="knots-badge">THE CONTENT ARCHITECTURE</p>
        <h2 class="knots-headline">8 <span class="knots-accent">Primitives</span></h2>
        <p class="knots-desc">
          Everything published on this canvas is strictly typed by cadence and cognitive weight. Short forms for daily capture. Long forms for deep synthesis.
        </p>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-xl); text-align: left; margin-top: var(--space-3xl); margin-bottom: var(--space-xl);">
          
          <div class="arch-col">
            <h3 style="color: var(--mind-color); font-size: 1rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--space-md);">Think</h3>
            <a href="/sparks/" class="dim-card dim-card--mind" style="display: block; margin-bottom: var(--space-md);">
              <span class="knots-badge" style="color: var(--text-muted); font-size: 0.55rem;">SHORT FORM</span>
              <strong style="color: var(--text-primary); display: block; font-size: 1.1rem; margin-top: 4px;">Sparks</strong>
              <span style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;">Raw intelligence capture. Single resonant signals observed from the field, constrained to exactly 108 words.</span>
            </a>
            <a href="/fusions/" class="dim-card dim-card--mind" style="display: block; margin-bottom: var(--space-md);">
              <span class="knots-badge" style="color: var(--text-muted); font-size: 0.55rem;">LONG FORM</span>
              <strong style="color: var(--text-primary); display: block; font-size: 1.1rem; margin-top: 4px;">Fusions</strong>
              <span style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;">Deep, cross-domain synthesis. Where individual sparks and observations collide into structural essays linking philosophy with algorithmic execution.</span>
            </a>
          </div>

          <div class="arch-col">
            <h3 style="color: var(--body-color); font-size: 1rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--space-md);">Work</h3>
            <a href="/knots/" class="dim-card dim-card--body" style="display: block; margin-bottom: var(--space-md);">
              <span class="knots-badge" style="color: var(--text-muted); font-size: 0.55rem;">SHORT FORM</span>
              <strong style="color: var(--text-primary); display: block; font-size: 1.1rem; margin-top: 4px;">Knots</strong>
              <span style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;">The tangled friction observed inside living systems. Diagnostic patterns named, felt, and systematically untangled across the architecture.</span>
            </a>
            <div class="dim-card dim-card--body" style="display: block; margin-bottom: var(--space-md); opacity: 0.7;">
              <span class="knots-badge" style="color: var(--text-muted); font-size: 0.55rem;">LONG FORM</span>
              <strong style="color: var(--text-primary); display: flex; align-items: center; gap: 8px; font-size: 1.1rem; margin-top: 4px;">
                Claws <span class="knots-badge" style="background: rgba(255,255,255,0.1); padding: 2px 6px; border-radius: 4px;">COMING SOON</span>
              </strong>
              <span style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;">LAWs that ossify into CLAWs. Examining the rigid constraints, anti-patterns, and legacy forces that actively pull organisations down.</span>
            </div>
            <div class="dim-card dim-card--body" style="display: block; margin-bottom: var(--space-md); opacity: 0.7;">
              <span class="knots-badge" style="color: var(--text-muted); font-size: 0.55rem;">LONG FORM</span>
              <strong style="color: var(--text-primary); display: flex; align-items: center; gap: 8px; font-size: 1.1rem; margin-top: 4px;">
                Digs <span class="knots-badge" style="background: rgba(255,255,255,0.1); padding: 2px 6px; border-radius: 4px;">COMING SOON</span>
              </strong>
              <span style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;">Heavy literature and organisational excavation. Extracting architectural frameworks and cataloguing deep historical strata from the baseline.</span>
            </div>
          </div>

          <div class="arch-col">
            <h3 style="color: var(--soul-color); font-size: 1rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--space-md);">Play</h3>
            <div class="dim-card dim-card--soul" style="display: block; margin-bottom: var(--space-md); opacity: 0.7;">
              <span class="knots-badge" style="color: var(--text-muted); font-size: 0.55rem;">SHORT FORM</span>
              <strong style="color: var(--text-primary); display: flex; align-items: center; gap: 8px; font-size: 1.1rem; margin-top: 4px;">
                Wows <span class="knots-badge" style="background: rgba(255,255,255,0.1); padding: 2px 6px; border-radius: 4px;">COMING SOON</span>
              </strong>
              <span style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;">Catalytic moments and sudden reframes. Documenting the exact 'before' state, the shifting catalyst, and the final 'after' perspective.</span>
            </div>
            <div class="dim-card dim-card--soul" style="display: block; margin-bottom: var(--space-md); opacity: 0.7;">
              <span class="knots-badge" style="color: var(--text-muted); font-size: 0.55rem;">LONG FORM</span>
              <strong style="color: var(--text-primary); display: flex; align-items: center; gap: 8px; font-size: 1.1rem; margin-top: 4px;">
                Awes <span class="knots-badge" style="background: rgba(255,255,255,0.1); padding: 2px 6px; border-radius: 4px;">COMING SOON</span>
              </strong>
              <span style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;">Raw, somatic experiences and narrative-heavy emotional arcs. The lingering echo of witnessing profound elegance and structural beauty.</span>
            </div>
            <a href="/beads/" class="dim-card dim-card--soul" style="display: block; margin-bottom: var(--space-md);">
              <span class="knots-badge" style="color: var(--text-muted); font-size: 0.55rem;">LONG FORM</span>
              <strong style="color: var(--text-primary); display: block; font-size: 1.1rem; margin-top: 4px;">Beads</strong>
              <span style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;">Tactical interventions and hardened wisdom derived directly from execution. Granular, scalable solutions applied to resolve systemic friction.</span>
            </a>
          </div>

          <div class="arch-col">
            <h3 style="color: var(--vibe-color); font-size: 1rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--space-md);">Vibe</h3>
            <div class="dim-card dim-card--vibe" style="display: block; margin-bottom: var(--space-md); opacity: 0.7;">
              <span class="knots-badge" style="color: var(--text-muted); font-size: 0.55rem;">SHORT FORM</span>
              <strong style="color: var(--text-primary); display: flex; align-items: center; gap: 8px; font-size: 1.1rem; margin-top: 4px;">
                Syncs <span class="knots-badge" style="background: rgba(255,255,255,0.1); padding: 2px 6px; border-radius: 4px;">COMING SOON</span>
              </strong>
              <span style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;">Immediate collaborative sparks. Ideas and people that vibrate on the exact same frequency, establishing immediate shared trajectories.</span>
            </div>
            <div class="dim-card dim-card--vibe" style="display: block; margin-bottom: var(--space-md); opacity: 0.7;">
              <span class="knots-badge" style="color: var(--text-muted); font-size: 0.55rem;">LONG FORM</span>
              <strong style="color: var(--text-primary); display: flex; align-items: center; gap: 8px; font-size: 1.1rem; margin-top: 4px;">
                SPARs <span class="knots-badge" style="background: rgba(255,255,255,0.1); padding: 2px 6px; border-radius: 4px;">COMING SOON</span>
              </strong>
              <span style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;">Structured friction and dialectic. Multi-player argumentation sessions combining Human and AI personas to rigorously stress-test reasoning.</span>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══ Cognitive Routing ═══ -->
    <section class="pathways-section section--tight" style="padding-top: var(--space-xl); padding-bottom: var(--space-xl); border-top: 1px solid var(--border-dim); background: rgba(0,0,0,0.02);">
      <div class="container container--narrow">
        <h2 style="font-family: var(--font-header); font-size: 1.5rem; text-align: center; margin-bottom: var(--space-xl); color: var(--text-primary);">
          Cognitive Routing
          <div style="font-size: 0.85rem; color: var(--text-secondary); font-family: var(--font-body); margin-top: 8px; font-weight: 400;">
            The 10 primitives form a dynamic neural network mapping how intelligence flows.
          </div>
        </h2>

        <div style="display: flex; flex-direction: column; gap: var(--space-md);">
          <!-- 1. The Crucible -->
          <div class="dim-card" style="padding: 1.5rem; border-left: 3px solid var(--body-color);">
            <div style="font-size: 0.75rem; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 8px; text-transform: uppercase;">1. The Crucible (Friction-First)</div>
            <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
              <span style="color: var(--body-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--body-color); border-radius: 4px; font-size: 0.9rem;">Knot</span>
              <span style="color: var(--text-muted);">→</span>
              <span style="color: var(--body-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--body-color); border-radius: 4px; font-size: 0.9rem;">Claw</span>
              <span style="color: var(--text-muted);">→</span>
              <span style="color: var(--soul-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--soul-color); border-radius: 4px; font-size: 0.9rem;">Bead</span>
            </div>
            <div style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 10px;">Extracting transcendent values from diagnosed systemic constraints.</div>
          </div>

          <!-- 2. The Scholar -->
          <div class="dim-card" style="padding: 1.5rem; border-left: 3px solid var(--mind-color);">
            <div style="font-size: 0.75rem; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 8px; text-transform: uppercase;">2. The Scholar (Research-First)</div>
            <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
              <span style="color: var(--mind-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--mind-color); border-radius: 4px; font-size: 0.9rem;">Spark</span>
              <span style="color: var(--text-muted);">→</span>
              <span style="color: var(--body-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--body-color); border-radius: 4px; font-size: 0.9rem;">Dig</span>
              <span style="color: var(--text-muted);">→</span>
              <span style="color: var(--mind-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--mind-color); border-radius: 4px; font-size: 0.9rem;">Fusion</span>
            </div>
            <div style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 10px;">Tracking external intelligence signals down to their deep historical roots.</div>
          </div>

          <!-- 3. The Collision -->
          <div class="dim-card" style="padding: 1.5rem; border-left: 3px solid var(--vibe-color);">
            <div style="font-size: 0.75rem; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 8px; text-transform: uppercase;">3. The Collision (Resonance-First)</div>
            <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
              <span style="color: var(--vibe-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--vibe-color); border-radius: 4px; font-size: 0.9rem;">Sync</span>
              <span style="color: var(--text-muted);">→</span>
              <span style="color: var(--vibe-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--vibe-color); border-radius: 4px; font-size: 0.9rem;">SPAR</span>
              <span style="color: var(--text-muted);">→</span>
              <span style="color: var(--soul-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--soul-color); border-radius: 4px; font-size: 0.9rem;">Wow</span>
              <span style="color: var(--text-muted);">→</span>
              <span style="color: var(--mind-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--mind-color); border-radius: 4px; font-size: 0.9rem;">Fusion</span>
            </div>
            <div style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 10px;">Generating sudden mindset shifts through high-friction human interactions.</div>
          </div>

          <!-- 4. The Transmuter -->
          <div class="dim-card" style="padding: 1.5rem; border-left: 3px solid var(--soul-color);">
            <div style="font-size: 0.75rem; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 8px; text-transform: uppercase;">4. The Transmuter (Value-First)</div>
            <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
              <span style="color: var(--soul-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--soul-color); border-radius: 4px; font-size: 0.9rem;">Bead</span>
              <span style="color: var(--text-muted);">→</span>
              <span style="color: var(--vibe-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--vibe-color); border-radius: 4px; font-size: 0.9rem;">SPAR</span>
              <span style="color: var(--text-muted);">→</span>
              <span style="color: var(--body-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--body-color); border-radius: 4px; font-size: 0.9rem;">Knot</span>
            </div>
            <div style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 10px;">Applying an established philosophical value to unravel a specific client tangle.</div>
          </div>

          <!-- 5. The Master Resonance Loop -->
          <div class="dim-card" style="padding: 1.5rem; border: 1px solid var(--border-dim); border-left: 3px solid var(--text-primary); margin-top: var(--space-sm);">
            <div style="font-size: 0.75rem; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 8px; text-transform: uppercase;">5. The Ouroboros (Master Resonance Loop)</div>
            <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
              <span style="color: var(--body-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--body-color); border-radius: 4px; font-size: 0.8rem;">Knot</span>
              <span style="color: var(--text-muted); font-size: 0.8rem;">→</span>
              <span style="color: var(--body-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--body-color); border-radius: 4px; font-size: 0.8rem;">Dig</span>
              <span style="color: var(--text-muted); font-size: 0.8rem;">→</span>
              <span style="color: var(--body-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--body-color); border-radius: 4px; font-size: 0.8rem;">Claw</span>
              <span style="color: var(--text-muted); font-size: 0.8rem;">→</span>
              <span style="color: var(--soul-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--soul-color); border-radius: 4px; font-size: 0.8rem;">Wow</span>
              <span style="color: var(--text-muted); font-size: 0.8rem;">→</span>
              <span style="color: var(--soul-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--soul-color); border-radius: 4px; font-size: 0.8rem;">Awe</span>
              <span style="color: var(--text-muted); font-size: 0.8rem;">→</span>
              <span style="color: var(--soul-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--soul-color); border-radius: 4px; font-size: 0.8rem;">Bead</span>
              <span style="color: var(--text-muted); font-size: 0.8rem;">→</span>
              <span style="color: var(--mind-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--mind-color); border-radius: 4px; font-size: 0.8rem;">Spark</span>
              <span style="color: var(--text-muted); font-size: 0.8rem;">→</span>
              <span style="color: var(--mind-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--mind-color); border-radius: 4px; font-size: 0.8rem;">Fusion</span>
              <span style="color: var(--text-muted); font-size: 0.8rem;">→</span>
              <span style="color: var(--vibe-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--vibe-color); border-radius: 4px; font-size: 0.8rem;">Sync</span>
              <span style="color: var(--text-muted); font-size: 0.8rem;">→</span>
              <span style="color: var(--vibe-color); font-weight: bold; padding: 4px 10px; border: 1px solid var(--vibe-color); border-radius: 4px; font-size: 0.8rem;">SPAR</span>
              <span style="color: var(--text-muted); font-size: 0.8rem;">→</span>
              <span style="color: var(--body-color); font-weight: bold; padding: 4px 10px; border: 1px dashed var(--body-color); opacity: 0.6; border-radius: 4px; font-size: 0.8rem;">Knot...</span>
            </div>
            <div style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 10px;">The overarching engine block sequence traversing all 4 dimensions infinitely. Work → Play → Think → Vibe.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ Kural ═══ -->
    <section class="kural-section section--tight">
      <div class="container container--narrow">
        <blockquote class="kural-block">
          <p class="kural-tamil">
            தொட்டனைத் தூறும் மணற்கேணி மாந்தர்க்குக்<br />
            கற்றனைத் தூறும் அறிவு.
          </p>
          <p class="kural-en">
            Like a well that springs as you dig, knowledge springs as you learn.
          </p>
          <cite>Thirukkural #396</cite>
        </blockquote>
      </div>
    </section>

    <!-- ═══ Vibe CTA ═══ -->
    <section class="vibe-cta section--tight">
      <div class="container container--narrow" style="text-align: center;">
        <p class="vibe-text">
          Every engagement starts the same way: a conversation.
        </p>
        <div class="vibe-links">
          <a
            href="https://www.linkedin.com/in/mnaveenriaz/"
            target="_blank"
            rel="noopener"
            class="btn">LinkedIn</a
          >
          <a
            href="https://github.com/synthanai"
            target="_blank"
            rel="noopener"
            class="btn">GitHub</a
          >
        </div>
      </div>
    </section>

    <Footer />

    <style>
      .knots-feature {
        padding: var(--space-xl) 0;
      }

      .knots-badge {
        font-family: var(--font-label);
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.15em;
        color: var(--accent);
        margin-bottom: var(--space-xs);
      }

      .knots-headline {
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 800;
        color: var(--text-primary);
        margin-bottom: var(--space-sm);
      }

      .knots-accent {
        background: linear-gradient(
          135deg,
          var(--soul-color),
