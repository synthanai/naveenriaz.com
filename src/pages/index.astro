---
/**
 * Home Page — Layer 1
 * Logo, name, MBS tagline, dimension nav, Kural #396, connect links.
 * All links verified. No internal ecosystem vocabulary.
 */
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Naveen Riaz | நவீன் ரியாஸ்</title>
    <meta
      name="description"
      content="Every organisation, community, product, and service is alive. Nurture its Mind, Body & Soul. Watch the Aura thrive!"
    />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Naveen Riaz | நவீன் ரியாஸ்" />
    <meta
      property="og:description"
      content="Every organisation, community, product, and service is alive. Nurture its Mind, Body & Soul. Watch the Aura thrive!"
    />
    <meta property="og:image" content="https://naveenriaz.com/og-image.png" />
    <meta property="og:url" content="https://naveenriaz.com/" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Header activeNav="home" />

    <!-- ═══ Hero ═══ -->
    <section class="hero">
      <div class="container hero-inner">
        <img src="/logo.svg" alt="" class="hero-logo" aria-hidden="true" />
        <h1>
          <span class="hero-name">Naveen Riaz</span>
          <span class="hero-tamil">நவீன் ரியாஸ்</span>
        </h1>
        <p class="hero-tagline">
          Everything we build is alive.<br />
          Nurture its <span class="c-mind">Mind</span>,
          <span class="c-body">Body</span> &amp;
          <span class="c-soul">Soul</span>.<br />
          Watch the <span class="c-aura">Aura</span> thrive!
        </p>
      </div>
    </section>

    <!-- ═══ Why This Exists ═══ -->
    <section class="origin-section section--tight">
      <div class="container container--narrow" style="text-align: center;">
        <p class="origin-text">
          Born in Nagercoil, Tamil Nadu, India. <br />Currently in Melbourne,
          Australia.<br />Moved across countries, industries, and identities.
        </p>
        <p
          class="origin-text"
          style="margin-top: var(--space-lg); opacity: 0.8;"
        >
          This site is not a portfolio.<br />
          It is the answer to a question I kept asking:<br />
          <em
            >What would it look like if everything <br />I built, learned, and
            failed at lived in one place, <br />organised by how it actually
            happened?</em
          >
        </p>
      </div>
    </section>

    <!-- ═══ Three Dimensions ═══ -->
    <section class="dimensions section">
      <div class="container">
        <div class="dim-grid">
          <a href="/think/" class="dim-card dim-card--mind">
            <div class="dim-header">
              <span class="glow-dot" style="color: var(--mind-color);"></span>
              <h2>Think</h2>
            </div>
            <p class="dim-tamil">சிந்தனை</p>
            <p class="dim-desc">
              How I stop myself from thinking alone. Frameworks built from
              friction, deliberation, and intelligence capture.
            </p>
          </a>
          <a href="/play/" class="dim-card dim-card--soul">
            <div class="dim-header">
              <span class="glow-dot" style="color: var(--soul-color);"></span>
              <h2>Play</h2>
            </div>
            <p class="dim-tamil">ஆன்மா</p>
            <p class="dim-desc">
              What remained after performance stopped working. Tamil roots,
              identity architecture, and the philosophy underneath the build.
            </p>
          </a>
          <a href="/work/" class="dim-card dim-card--body">
            <div class="dim-header">
              <span class="glow-dot" style="color: var(--body-color);"></span>
              <h2>Work</h2>
            </div>
            <p class="dim-tamil">செயல்</p>
            <p class="dim-desc">
              What survived contact with reality. Papers, tools, and books. Some
              shipped. Some didn't.
            </p>
          </a>
          <a href="/vibe/" class="dim-card dim-card--vibe">
            <div class="dim-header">
              <span class="glow-dot" style="color: var(--vibe-color);"></span>
              <h2>Vibe</h2>
            </div>
            <p class="dim-tamil">ஒத்திசை</p>
            <p class="dim-desc">
              Where conversation becomes shared work. Topics, tensions, and the
              kinds of problems I care about.
            </p>
          </a>
        </div>
      </div>
    </section>

    <!-- ═══ Content Architecture ═══ -->
    <section class="knots-feature section--tight">
      <div class="container container--narrow" style="text-align: center;">
        <p class="knots-badge">THE CONTENT ARCHITECTURE</p>
        <h2 class="knots-headline"><span class="knots-accent">Atoms</span></h2>
        <p class="knots-desc">
          These are not mood categories. They are containers for thought, work,
          rupture, delight, grief, and transformation. Short forms for daily
          capture. Long forms for deep synthesis.
        </p>

        <div class="arch-grid">
          <div class="arch-col">
            <h3
              style="color: var(--mind-color); font-size: 1rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--space-md);"
            >
              Think
            </h3>
            <a
              href="/sparks/"
              class="dim-card dim-card--mind"
              style="display: block; margin-bottom: var(--space-md);"
            >
              <span
                class="knots-badge"
                style="color: var(--text-muted); font-size: 0.55rem;"
                >SHORT FORM</span
              >
              <strong
                style="color: var(--text-primary); display: block; font-size: 1.1rem; margin-top: 4px;"
                >Sparks</strong
              >
              <span
                style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;"
                >Compressed field captures. Signals that excite, disturb, or
                destabilise, constrained to 108 words.</span
              >
            </a>
            <a
              href="/fusions/"
              class="dim-card dim-card--mind"
              style="display: block; margin-bottom: var(--space-md);"
            >
              <span
                class="knots-badge"
                style="color: var(--text-muted); font-size: 0.55rem;"
                >LONG FORM</span
              >
              <strong
                style="color: var(--text-primary); display: block; font-size: 1.1rem; margin-top: 4px;"
                >Fusions</strong
              >
              <span
                style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;"
                >Cross-domain collision. Where multiple signals fuse, resist, or
                fracture into structural essays.</span
              >
            </a>
          </div>

          <div class="arch-col">
            <h3
              style="color: var(--body-color); font-size: 1rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--space-md);"
            >
              Work
            </h3>
            <a
              href="/knots/"
              class="dim-card dim-card--body"
              style="display: block; margin-bottom: var(--space-md);"
            >
              <span
                class="knots-badge"
                style="color: var(--text-muted); font-size: 0.55rem;"
                >SHORT FORM</span
              >
              <strong
                style="color: var(--text-primary); display: block; font-size: 1.1rem; margin-top: 4px;"
                >Knots</strong
              >
              <span
                style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;"
                >Systemic friction named and felt. Diagnostic patterns inside
                living systems, including the ones I helped tangle.</span
              >
            </a>
          </div>

          <div class="arch-col">
            <h3
              style="color: var(--soul-color); font-size: 1rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--space-md);"
            >
              Play
            </h3>
            <a
              href="/beads/"
              class="dim-card dim-card--soul"
              style="display: block; margin-bottom: var(--space-md);"
            >
              <span
                class="knots-badge"
                style="color: var(--text-muted); font-size: 0.55rem;"
                >LONG FORM</span
              >
              <strong
                style="color: var(--text-primary); display: block; font-size: 1.1rem; margin-top: 4px;"
                >Beads</strong
              >
              <span
                style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 4px;"
                >Earned tactical wisdom. The solutions that work now because
                something else failed first.</span
              >
            </a>
          </div>

          <div
            class="arch-col"
            style="display: flex; flex-direction: column; justify-content: center; align-items: center;"
          >
            <p
              style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.6; margin: 0;"
            >
              Eight more atoms are incubating.<br />
              <a
                href="/experiences/"
                style="color: var(--accent); font-size: 0.8rem;"
                >See all experiences →</a
              >
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ Kural ═══ -->
    <section class="kural-section section--tight">
      <div class="container container--narrow">
        <blockquote class="kural-block">
          <p class="kural-tamil">
            தொட்டனைத் தூறும் மணற்கேணி மாந்தர்க்குக்<br />
            கற்றனைத் தூறும் அறிவு.
          </p>
          <p class="kural-en">
            Like a well that springs as you dig, knowledge springs as you learn.
          </p>
          <cite>Thirukkural #396</cite>
        </blockquote>
      </div>
    </section>

    <!-- ═══ Vibe CTA ═══ -->
    <section class="vibe-cta section--tight">
      <div class="container container--narrow" style="text-align: center;">
        <p class="vibe-text">
          Every engagement starts the same way: a conversation.
        </p>
        <div class="vibe-links">
          <a
            href="https://www.linkedin.com/in/mnaveenriaz/"
            target="_blank"
            rel="noopener"
            class="btn">LinkedIn</a
          >
          <a
            href="https://github.com/synthanai"
            target="_blank"
            rel="noopener"
            class="btn">GitHub</a
          >
        </div>
      </div>
    </section>

    <Footer />

    <style>
      .knots-feature {
        padding: var(--space-xl) 0;
      }

      .knots-badge {
        font-family: var(--font-label);
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.15em;
        color: var(--accent);
        margin-bottom: var(--space-xs);
      }

      .knots-headline {
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 800;
        color: var(--text-primary);
        margin-bottom: var(--space-sm);
      }

      .knots-accent {
        background: linear-gradient(
          135deg,
          var(--soul-color),
          var(--mind-color),
          var(--body-color)
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .knots-desc {
        font-size: 1rem;
        color: var(--text-secondary);
        max-width: 480px;
        margin: 0 auto var(--space-lg);
        line-height: 1.6;
      }

      .arch-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-xl);
        text-align: left;
        margin-top: var(--space-3xl);
        margin-bottom: var(--space-xl);
      }

      @media (max-width: 768px) {
        .arch-grid {
          grid-template-columns: 1fr;
          gap: var(--space-lg);
        }
      }
    </style>
  </body>
</html>
