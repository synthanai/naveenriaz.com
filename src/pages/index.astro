---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Naveen Riaz | நவீன் ரியாஸ்</title>
    <meta name="description" content="Coming soon." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <main class="coming-soon">
      <div class="symbol">ஃ</div>
      <h1>Naveen Riaz</h1>
      <p class="tamil">நவீன் ரியாஸ் மொஹமத் கனி</p>
      <p class="tagline">Coming soon.</p>
      <div class="links">
        <a href="https://www.linkedin.com/in/mnaveenriaz/" target="_blank" rel="noopener">LinkedIn</a>
        <span class="sep">·</span>
        <a href="https://github.com/synthanai" target="_blank" rel="noopener">GitHub</a>
      </div>
    </main>

    <style>
      .coming-soon {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: var(--space-xl);
      }

      .symbol {
        font-family: var(--font-tamil);
        font-size: 3.5rem;
        color: var(--soul-color);
        margin-bottom: var(--space-lg);
        opacity: 0.6;
        animation: pulseGlow 4s ease-in-out infinite;
      }

      h1 {
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        margin-bottom: var(--space-xs);
      }

      .tamil {
        font-family: var(--font-tamil);
        font-size: 1rem;
        color: var(--tamil-accent);
        opacity: 0.6;
        margin-bottom: var(--space-2xl);
      }

      .tagline {
        font-size: 1rem;
        color: var(--text-muted);
        letter-spacing: 0.15em;
        text-transform: uppercase;
        font-family: var(--font-label);
        font-weight: 500;
      }

      .links {
        margin-top: var(--space-2xl);
        display: flex;
        gap: var(--space-sm);
        align-items: center;
      }

      .links a {
        font-size: 0.85rem;
        color: var(--text-muted);
        transition: color var(--transition-base);
      }

      .links a:hover {
        color: var(--accent);
        text-decoration: none;
      }

      .sep {
        color: var(--text-dim);
        font-size: 0.8rem;
      }
    </style>
  </body>
</html>
