---
import { getCollection } from 'astro:content';
import Page from '../../layouts/Page.astro';

const allSparks = await getCollection('sparks');
const sorted = allSparks
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const tempColors: Record<string, [string, string]> = {
  "🔥": ["#27ae60", "rgba(39, 174, 96, 0.08)"],
  "🔥🔥": ["#D4A843", "rgba(212, 168, 67, 0.08)"],
  "🔥🔥🔥": ["#2874A6", "rgba(40, 116, 166, 0.12)"],
};

const tempLabels: Record<string, string> = {
  "🔥": "Warm",
  "🔥🔥": "Hot",
  "🔥🔥🔥": "On Fire",
};
---

<Page title="Sparks" description="Signals from the field. 108 words. One observation. Source attributed." activeNav="sparks">
  <section class="sparks-hero">
    <div class="container">
      <p class="hero-badge">SIGNAL LAYER</p>
      <h1>
        <span class="title-accent">Sparks</span>
      </h1>
      <p class="hero-sub">
        One observation. 108 words. Source attributed.<br />
        When multiple sparks connect, they become a fusion.
      </p>
      <p class="hero-count">{sorted.length} sparks captured</p>
    </div>
  </section>

  <section class="sparks-grid container">
    {sorted.map((spark) => {
      const temp = spark.data.temperature;
      const [solidColor, glowColor] = tempColors[temp] || ["#d4a574", "rgba(212, 165, 116, 0.08)"];
      const label = tempLabels[temp] || temp;
      const date = spark.data.date.toLocaleDateString("en-GB", {
        day: "numeric",
        month: "short",
        year: "numeric",
      });

      return (
        <a
          href={`/sparks/${spark.slug}`}
          class="spark-card"
          style={`--sc: ${solidColor}; --sg: ${glowColor}`}
        >
          <div class="spark-card__top">
            <span class="spark-card__temp" style={`color: ${solidColor}`}>
              {temp} {label}
            </span>
            <span class="spark-card__date">{date}</span>
          </div>
          <h3 class="spark-card__title">{spark.data.title}</h3>
          <p class="spark-card__signal">{spark.data.signal}</p>
          <div class="spark-card__bottom">
            <div class="spark-card__tags">
              {spark.data.tags?.slice(0, 3).map((tag) => (
                <span class="spark-card__tag">{tag}</span>
              ))}
            </div>
            {spark.data.fusion_link && (
              <span class="spark-card__fusion-badge">→ fusion</span>
            )}
          </div>
        </a>
      );
    })}
  </section>
</Page>

<style>
  /* ═══ Hero ═══ */
  .sparks-hero {
    padding: var(--space-3xl) 0 var(--space-xl);
    text-align: center;
  }

  .hero-badge {
    font-family: var(--font-label);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--soul-color);
    margin-bottom: var(--space-sm);
  }

  .sparks-hero h1 {
    font-size: clamp(2.5rem, 7vw, 4rem);
    font-weight: 800;
    color: var(--text-primary) !important;
    margin-bottom: var(--space-sm);
  }

  .title-accent {
    background: linear-gradient(135deg, #D4A843, #E8742E, #C43D3D);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1rem;
    color: var(--text-secondary);
    max-width: 440px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .hero-count {
    font-family: var(--font-label);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    opacity: 0.5;
    margin-top: var(--space-md);
  }

  /* ═══ Grid ═══ */
  .sparks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-md);
    padding-bottom: var(--space-4xl);
  }

  /* ═══ Card ═══ */
  .spark-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-lg) var(--space-xl);
    border-radius: var(--border-radius);
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: linear-gradient(180deg, var(--sg, rgba(255,255,255,0.02)), transparent);
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .spark-card:hover {
    transform: translateY(-3px);
    border-color: var(--sc, rgba(255, 255, 255, 0.15));
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.4);
    text-decoration: none;
  }

  .spark-card__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-sm);
  }

  .spark-card__temp {
    font-family: var(--font-label);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .spark-card__date {
    font-family: var(--font-label);
    font-size: 0.6rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.04em;
  }

  .spark-card__title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
    margin-bottom: var(--space-xs);
  }

  .spark-card__signal {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.45);
    font-style: italic;
    line-height: 1.45;
    margin-bottom: var(--space-sm);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .spark-card__bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-top: auto;
    padding-top: var(--space-sm);
  }

  .spark-card__tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .spark-card__tag {
    font-family: var(--font-label);
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.3);
    padding: 2px 8px;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(255, 255, 255, 0.02);
  }

  .spark-card__fusion-badge {
    font-family: var(--font-label);
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--mind-color);
    opacity: 0.6;
    white-space: nowrap;
  }

  /* ═══ Responsive ═══ */
  @media (max-width: 640px) {
    .sparks-grid {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
    }

    .spark-card {
      padding: var(--space-md) var(--space-lg);
    }
  }
</style>
