---
import { getCollection, render } from 'astro:content';
import SparkLayout from '../../layouts/SparkLayout.astro';

export async function getStaticPaths() {
  const sparks = await getCollection('sparks');
  return sparks.map((spark) => ({
    params: { slug: spark.id },
    props: { spark },
  }));
}

const { spark } = Astro.props;
const { Content } = await render(spark);
const d = spark.data;
---

<SparkLayout
  title={d.title}
  description={d.description}
  date={d.date}
  source={d.source}
  signal={d.signal}
  temperature={d.temperature}
  tags={d.tags}
  fusionLink={d.fusion_link}
>
  <Content />
</SparkLayout>
