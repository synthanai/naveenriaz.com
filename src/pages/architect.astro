---
/**
 * Architect — Systems Design & Technical Leadership
 * Vibe sub-page scaffold
 */
import Page from "../layouts/Page.astro";
import TamilRoot from "../components/TamilRoot.astro";
---

<Page
    title="Architect"
    description="Systems design, technical leadership, and the art of building structures that outlast their builders."
    activeNav="architect"
>
    <section class="scaffold-hero">
        <div
            class="orb"
            style="width:400px;height:400px;background:var(--body-color);top:-160px;left:50%;transform:translateX(-50%);opacity:0.1;"
        >
        </div>
        <div class="container" style="text-align:center;">
            <span class="scaffold-label">Architect</span>
            <h1>Structures That <span class="gt">Outlast</span></h1>
            <p class="scaffold-desc">
                Systems design and technical leadership. Building structures
                that outlast their builders, organizations that outlast their
                founders.
            </p>
        </div>
    </section>

    <section class="section--tight">
        <div class="container container--narrow">
            <TamilRoot
                tamil="கட்டிடக்கலைஞர்"
                transliteration="Kattidakkalainjar"
                meaning="Architect. One who sees the whole before touching the parts. Structure is not constraint, it is freedom."
                tamilMeaning="பகுதிகளைத் தொடுவதற்கு முன் முழுமையைப் பார்ப்பவர்."
                kural="ஆற்றின் அளவறிந்து ஈக அதுபொருள் போற்றி வழங்கும் நெறி."
                kuralNumber={477}
                kuralTranslation="Give by measuring capacity. That is the discipline of stewardship."
            />
        </div>
    </section>

    <section class="section--tight">
        <div class="container container--narrow">
            <div class="manifesto">
                <h2>Coming <span class="gt">Soon</span></h2>
                <p>
                    Architecture portfolio, design philosophy, and technical
                    case studies are being assembled. Connect through the Vibe
                    page.
                </p>
            </div>
        </div>
    </section>
</Page>

<style>
    .scaffold-hero {
        padding: var(--space-4xl) 0 var(--space-2xl);
        text-align: center;
        position: relative;
        overflow: hidden;
    }
    .scaffold-label {
        font-family: var(--font-label);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: var(--space-sm);
        display: block;
    }
    .scaffold-desc {
        max-width: 600px;
        margin: var(--space-md) auto 0;
        color: var(--text-secondary);
        font-size: 1.05rem;
        line-height: 1.7;
    }
</style>
