---
/**
 * Vibe Page — Layer 1
 * Connection page. What conversations interest me. How to reach me.
 */
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import TamilRoot from "../components/TamilRoot.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vibe | Naveen Riaz</title>
    <meta
      name="description"
      content="Let's connect. Conversations about living systems, cognitive architecture, and Tamil wisdom."
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Vibe | Naveen Riaz" />
    <meta property="og:description" content="Let's connect. Conversations about living systems, cognitive architecture, and Tamil wisdom." />
    <meta property="og:image" content="https://naveenriaz.com/og-image.png" />
    <meta property="og:url" content="https://naveenriaz.com/vibe/" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="section-vibe">
    <Header activeNav="vibe" />

    <main class="container container--narrow">
      <section class="page-hero section">
        <h1>Vibe</h1>
        <p class="page-subtitle">Let's connect.</p>
        <p>
          Every engagement starts the same way: a conversation.<br />
          I am most alive when exploring ideas with people who care about depth over
          speed.
        </p>
      </section>

      <section class="section--tight">
        <h2>Primitives <span class="layer-label">The Vibe</span></h2><br />
        <div class="topic-list" style="grid-template-columns: 1fr 1fr;">
          <div class="topic-item" style="display: block; opacity: 0.7;">
            <p class="knots-badge" style="color: var(--vibe-color);">SHORT FORM</p>
            <strong style="font-size: 1.5rem; margin-bottom: 8px; display: flex; align-items: center; gap: 8px;">
              Syncs <span class="knots-badge" style="background: rgba(255,255,255,0.1); padding: 2px 6px; border-radius: 4px; font-size: 0.55rem; color: var(--text-muted);">COMING SOON</span>
            </strong>
            <p>
              Harmony and resonance. Ideas and people that vibrate on the same frequency. Immediate collaborative sparks and shared trajectories.
            </p>
          </div>
          <div class="topic-item" style="display: block; opacity: 0.7;">
            <p class="knots-badge" style="color: var(--vibe-color);">LONG FORM</p>
            <strong style="font-size: 1.5rem; margin-bottom: 8px; display: flex; align-items: center; gap: 8px;">
              SPARs <span class="knots-badge" style="background: rgba(255,255,255,0.1); padding: 2px 6px; border-radius: 4px; font-size: 0.55rem; color: var(--text-muted);">COMING SOON</span>
            </strong>
            <p>
              Friction and dialectic. Multi-player argumentation sessions combining Human and AI personas to stress-test reasoning.
            </p>
          </div>
        </div>
      </section>

      <div class="divider"><img src="/logo-h.svg" alt="ஃ" /></div>

      <section class="section--tight connect-section">
        <h2>Find Me</h2><br />
        <div class="connect-grid">
          <a
            href="https://www.linkedin.com/in/mnaveenriaz/"
            target="_blank"
            rel="noopener"
            class="connect-card"
          >
            <strong>LinkedIn</strong>
            <p>Professional conversations and updates.</p>
          </a>
          <a
            href="https://github.com/synthanai"
            target="_blank"
            rel="noopener"
            class="connect-card"
          >
            <strong>GitHub</strong>
            <p>Open source tools and code.</p>
          </a>
        </div>
      </section>

      <TamilRoot
        tamil="ஒத்திசை"
        transliteration="Otticai"
        meaning="Harmony, resonance, being in tune. The frequency you emit when your mind, body, and soul are aligned."
        kural={`கடன்என்ப நல்லவை எல்லாம் கடன்அறிந்து\nசான்றாண்மை மேற்கொள் பவர்க்கு.`}
        kuralNumber={981}
        kuralTranslation="All virtues are said to be the duty of those who have embraced good conduct."
      />
    </main>

    <Footer />
  </body>
</html>
