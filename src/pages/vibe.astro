---
/**
 * VIBE — Let's Vibe Together (speaking, consulting, coaching)
 * Pattern: dimension-hero (warmest room) + service cards
 * Three Rooms: Vibe = warmest, most inviting, most human
 */
import Page from "../layouts/Page.astro";
import TamilRoot from "../components/TamilRoot.astro";
---

<Page
  title="Vibe"
  description="Let's vibe together. Speaking, consulting, and coaching on organizational transformation, AI strategy, and systems thinking."
  activeNav="vibe"
>
  <section class="dimension-hero dimension-hero--services">
    <div class="container">
      <div class="orientation" aria-label="Vibe">
        <span class="ori-dot ori-dot--mind" title="Think"></span>
        <span class="ori-dot ori-dot--body" title="Work"></span>
        <span class="ori-dot ori-dot--soul" title="Play"></span>
      </div>
      <span class="dimension-label"
        >Vibe <span class="personality-dot">·</span>
        <span class="personality-type">Omnivert</span></span
      >
      <h1>
        <span class="vibe-mind">Let's</span>
        <span class="vibe-body">Vibe</span>
        <span class="vibe-soul">Together</span>
      </h1>
      <p class="dimension-desc">
        I help leaders and organisations see what's alive inside their systems,
        then build the structures that let it grow.
      </p>
      <p class="dimension-warmth">
        Every engagement starts the same way: a conversation. No pitch decks. No
        frameworks upfront. Just two people exploring what matters.
      </p>
    </div>
  </section>

  <section class="section--tight">
    <div class="container container--narrow">
      <TamilRoot
        tamil="ஒலுக்கம்"
        transliteration="Olukkam"
        meaning="Resonance. When two systems vibrate at the same frequency, transformation becomes inevitable."
        tamilMeaning="தலைவர்கள் தங்கள் அமைப்புகளுக்குள் உயிர்ப்பாக இருப்பதைக் காண உதவுதல், பின்னர் அது வளர அனுமதிக்கும் கட்டமைப்புகளை உருவாக்குதல்."
        kural={`கடன்என்ப நல்லவை எல்லாம் கடன்அறிந்து
சான்றாண்மை மேற்கொள் பவர்க்கு.`}
        kuralNumber={981}
        kuralTranslation="The truly great are those who accomplish the hardest deeds."
      />
    </div>
  </section>

  <section class="section--tight">
    <div class="container">
      <div class="services-grid">
        <div class="service-card service-card--soul">
          <div class="service-icon">🎤</div>
          <h3 class="service-title">Speaking</h3>
          <p class="service-desc">
            Keynotes, workshops, and panel discussions on organisational
            consciousness, AI-augmented thinking, and the art of productive
            disagreement.
          </p>
          <ul class="service-topics">
            <li>Organizations as Living Systems</li>
            <li>AI as Thinking Partner (not Replacement)</li>
            <li>The Art of Structured Disagreement (SPAR)</li>
            <li>Ancient Wisdom in Modern Leadership</li>
          </ul>
          <a href="/speaker/" class="btn btn--warm">Let's Talk</a>
        </div>

        <div class="service-card service-card--mind">
          <div class="service-icon">🔬</div>
          <h3 class="service-title">Consulting</h3>
          <p class="service-desc">
            Strategic advisory on organisational transformation, product
            architecture, and AI integration. I work with leaders who see their
            organisations as living systems, not machines.
          </p>
          <ul class="service-topics">
            <li>Organisational Health Diagnostics</li>
            <li>AI Strategy & Governance</li>
            <li>Product & Platform Architecture</li>
            <li>Decision Governance Frameworks</li>
          </ul>
          <a href="/consultant/" class="btn btn--warm">Start a Conversation</a>
        </div>

        <div class="service-card service-card--body">
          <div class="service-icon">🌱</div>
          <h3 class="service-title">Coaching</h3>
          <p class="service-desc">
            One-on-one coaching for tech leaders and product architects
            navigating complexity. Systems thinking, dialectic reasoning, and
            the discipline of building what matters.
          </p>
          <ul class="service-topics">
            <li>Leadership in Complex Systems</li>
            <li>From Architect to Systems Thinker</li>
            <li>Building an Intellectual Ecosystem</li>
            <li>Writing & Publishing with AI</li>
          </ul>
          <a href="/coach/" class="btn btn--warm">Let's Grow</a>
        </div>

        <div class="service-card service-card--warm">
          <div class="service-icon">✍️</div>
          <h3 class="service-title">Author</h3>
          <p class="service-desc">
            Books, ebooks, and written explorations on organisational
            consciousness, structured thinking, and the human side of AI. Every
            word is earned through practice, not generated on autopilot.
          </p>
          <ul class="service-topics">
            <li>Let's SPAR: Disagree to Agree (13-book SHIFT series)</li>
            <li>Thirukkural for Modern Leaders</li>
            <li>AI Gym: 21 Reps for the Thinking Professional</li>
            <li>Living Organization Field Guides</li>
          </ul>
          <a href="/author/" class="btn btn--warm">Explore the Books</a>
        </div>

        <div class="service-card service-card--warm">
          <div class="service-icon">🏗️</div>
          <h3 class="service-title">Architect</h3>
          <p class="service-desc">
            System design, platform architecture, and the invisible structures
            that make organisations feel alive. I build the scaffolding that
            lets emergence happen, not the cage that prevents it.
          </p>
          <ul class="service-topics">
            <li>AI-Native Platform Design</li>
            <li>Knowledge Graph Architecture</li>
            <li>Decision Governance Systems</li>
            <li>Living System Infrastructure</li>
          </ul>
          <a href="/architect/" class="btn btn--warm">Build Together</a>
        </div>

        <div class="service-card service-card--warm">
          <div class="service-icon">⚡</div>
          <h3 class="service-title">Challenge</h3>
          <p class="service-desc">
            Bring your hardest problem. A structured dialectic session where we
            disagree to agree, stress-test assumptions, and find the signal
            buried under the noise. SPAR methodology, applied live.
          </p>
          <ul class="service-topics">
            <li>Live SPAR Debate Sessions</li>
            <li>Strategy Stress-Testing</li>
            <li>Assumption Audits</li>
            <li>Decision Moment Facilitation</li>
          </ul>
          <a href="/challenge/" class="btn btn--warm">Bring the Challenge</a>
        </div>
      </div>
    </div>
  </section>
</Page>

<style>
  .vibe-mind {
    color: var(--mind-color);
  }
  .vibe-body {
    color: var(--body-color);
  }
  .vibe-soul {
    color: var(--soul-color);
  }

  .dimension-hero--services {
    padding: var(--space-4xl) 0 var(--space-2xl);
    position: relative;
    text-align: center;
  }

  .dimension-hero--services::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse at 50% 30%,
        rgba(212, 168, 67, 0.08) 0%,
        transparent 50%
      ),
      radial-gradient(
        ellipse at 30% 70%,
        rgba(196, 149, 106, 0.06) 0%,
        transparent 40%
      ),
      radial-gradient(
        ellipse at 70% 60%,
        rgba(39, 174, 96, 0.04) 0%,
        transparent 40%
      );
    pointer-events: none;
  }

  .dimension-hero--services .orientation {
    justify-content: center;
  }

  .dimension-label {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--soul-color);
    display: block;
    margin-bottom: var(--space-sm);
  }

  .dimension-hero--services h1 {
    position: relative;
    z-index: 1;
  }

  .dimension-desc {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 560px;
    margin-inline: auto;
    position: relative;
    z-index: 1;
  }

  .dimension-warmth {
    font-size: 0.95rem;
    color: var(--text-dim);
    max-width: 480px;
    margin-inline: auto;
    margin-top: var(--space-sm);
    font-style: italic;
    position: relative;
    z-index: 1;
  }

  .orientation {
    display: flex;
    gap: 8px;
    margin-bottom: var(--space-md);
    position: relative;
    z-index: 1;
  }

  .ori-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .ori-dot--active {
    background: var(--soul-color);
    box-shadow: 0 0 8px var(--soul-glow);
  }

  .ori-dot--dim {
    background: rgba(255, 255, 255, 0.12);
  }

  .ori-dot--mind {
    background: var(--mind-color);
    box-shadow: 0 0 8px var(--mind-glow);
  }
  .ori-dot--body {
    background: var(--body-color);
    box-shadow: 0 0 8px var(--body-glow);
  }
  .ori-dot--soul {
    background: var(--soul-color);
    box-shadow: 0 0 8px var(--soul-glow);
  }

  .personality-dot {
    opacity: 0.3;
    margin: 0 2px;
  }

  .personality-type {
    font-weight: 400;
    opacity: 0.5;
    letter-spacing: 0.06em;
    font-size: 0.65rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-xl);
  }

  .service-card {
    background: var(--bg-card);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--section-radius, 24px);
    padding: var(--space-xl) var(--space-xl) var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    transition:
      transform var(--transition-base),
      box-shadow var(--transition-base),
      border-color var(--transition-base);
  }

  .service-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .service-card--soul {
    border-top: 3px solid var(--soul-color);
  }
  .service-card--soul:hover {
    box-shadow: 0 12px 40px var(--soul-glow);
  }

  .service-card--mind {
    border-top: 3px solid var(--mind-color);
  }
  .service-card--mind:hover {
    box-shadow: 0 12px 40px var(--mind-glow);
  }

  .service-card--body {
    border-top: 3px solid var(--body-color);
  }
  .service-card--body:hover {
    box-shadow: 0 12px 40px var(--body-glow);
  }

  .service-card--warm {
    border-top: 3px solid var(--accent);
  }
  .service-card--warm:hover {
    box-shadow: 0 12px 40px rgba(196, 149, 106, 0.15);
  }

  .service-icon {
    font-size: 2rem;
  }

  .service-title {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
  }

  .service-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 0;
  }

  .service-topics {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .service-topics li {
    font-size: 0.8rem;
    color: var(--text-muted);
    padding-left: 1rem;
    position: relative;
  }

  .service-topics li::before {
    content: "◆";
    position: absolute;
    left: 0;
    font-size: 0.5rem;
    top: 0.25em;
    color: var(--accent);
  }

  .service-card .btn {
    margin-top: auto;
    align-self: flex-start;
  }

  /* Warm button variant for Vibe */
  .btn--warm {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-lg);
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 20px;
    border: 1px solid var(--accent-border);
    color: var(--accent);
    background: rgba(196, 149, 106, 0.06);
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .btn--warm:hover {
    background: rgba(196, 149, 106, 0.15);
    border-color: var(--accent);
    color: var(--accent-light);
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(196, 149, 106, 0.15);
  }

  @media (max-width: 480px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
