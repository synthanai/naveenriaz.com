---
/**
 * Vibe Page — Layer 1
 * Connection page. What conversations interest me. How to reach me.
 */
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import TamilRoot from "../components/TamilRoot.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vibe | Naveen Riaz</title>
    <meta name="description" content="Let's connect. Conversations about living systems, cognitive architecture, and Tamil wisdom." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="section-vibe">
    <Header activeNav="vibe" />

    <main class="container container--narrow">
      <section class="page-hero section">
        <h1>Vibe</h1>
        <p class="page-subtitle">Let's connect.</p>
        <p>
          Every engagement starts the same way: a conversation.
          I am most alive when exploring ideas with people who care about depth over speed.
        </p>
      </section>

      <section class="section--tight">
        <h2>Conversations I'm Interested In</h2>
        <div class="topic-list">
          <div class="topic-item">
            <strong>Living Systems</strong>
            <p>How organisations, communities, products, and services breathe, grow, and sometimes die. The patterns that separate thriving from decay.</p>
          </div>
          <div class="topic-item">
            <strong>Cognitive Architecture</strong>
            <p>How humans and AI systems reason. Structured deliberation, decision quality, and thinking as a craft.</p>
          </div>
          <div class="topic-item">
            <strong>Ancient Wisdom, Modern Application</strong>
            <p>The Thirukkural is 2000 years old but speaks directly to contemporary leadership. Pattern recognition across time.</p>
          </div>
          <div class="topic-item">
            <strong>The AI Era</strong>
            <p>Not "how to use AI" but "how AI changes what it means to think, build, and lead."</p>
          </div>
        </div>
      </section>

      <div class="divider"><img src="/logo-h.svg" alt="ஃ" /></div>

      <section class="section--tight connect-section">
        <h2>Find Me</h2>
        <div class="connect-grid">
          <a href="https://www.linkedin.com/in/mnaveenriaz/" target="_blank" rel="noopener" class="connect-card">
            <strong>LinkedIn</strong>
            <p>Professional conversations and updates.</p>
          </a>
          <a href="https://github.com/synthanai" target="_blank" rel="noopener" class="connect-card">
            <strong>GitHub</strong>
            <p>Open source tools and code.</p>
          </a>
        </div>
      </section>

      <TamilRoot
        tamil="ஒத்திசை"
        transliteration="Otticai"
        meaning="Harmony, resonance, being in tune. The frequency you emit when your mind, body, and soul are aligned."
        kural={`கடன்என்ப நல்லவை எல்லாம் கடன்அறிந்து\nசான்றாண்மை மேற்கொள் பவர்க்கு.`}
        kuralNumber={981}
        kuralTranslation="All virtues are said to be the duty of those who have embraced good conduct."
      />
    </main>

    <Footer />

  </body>
</html>
