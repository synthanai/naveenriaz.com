---
/**
 * Pulse Page: The Heartbeat
 * Public dashboard showing ecosystem velocity, delivery status, and git metrics.
 * Data source: src/data/pulse.json (generated by scripts/pulse-scanner.mjs)
 */
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import TamilRoot from "../components/TamilRoot.astro";
import pulse from "../data/pulse.json";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pulse | Naveen Riaz</title>
    <meta
      name="description"
      content="The heartbeat of the SYNTHAI ecosystem. Live metrics on research, code, publications, and delivery velocity."
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Pulse | Naveen Riaz" />
    <meta
      property="og:description"
      content="The heartbeat of the SYNTHAI ecosystem. Live metrics on research, code, and delivery."
    />
    <meta property="og:image" content="https://naveenriaz.com/og-image.png" />
    <meta property="og:url" content="https://naveenriaz.com/pulse/" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="section-pulse">
    <Header activeNav="pulse" />

    <main class="container container--wide">
      <section class="page-hero section">
        <h1>Pulse</h1>
        <p class="page-subtitle">The heartbeat of the ecosystem.</p>
        <p>
          Everything I build is part of one living system: SYNTHAI.<br />
          This page shows the real-time vital signs.
        </p>
      </section>

      <!-- ═══ HEADLINE KPIs ═══ -->
      <section class="pulse-kpis">
        <div class="kpi-card">
          <span class="kpi-num" style="color: var(--mind-color);"
            >{pulse.pulse.totalCommits.toLocaleString()}</span
          >
          <span class="kpi-label">Commits</span>
        </div>
        <div class="kpi-card">
          <span class="kpi-num" style="color: var(--soul-color);"
            >{pulse.pulse.repos}</span
          >
          <span class="kpi-label">Repositories</span>
        </div>
        <div class="kpi-card">
          <span class="kpi-num" style="color: var(--body-color);"
            >{pulse.pulse.researchFiles.toLocaleString()}</span
          >
          <span class="kpi-label">Research Files</span>
        </div>
        <div class="kpi-card">
          <span class="kpi-num" style="color: var(--mind-color);"
            >{pulse.pulse.knowledgeItems}</span
          >
          <span class="kpi-label">Knowledge Items</span>
        </div>
        <div class="kpi-card">
          <span class="kpi-num" style="color: var(--soul-color);"
            >{pulse.pulse.workflows}</span
          >
          <span class="kpi-label">Workflows</span>
        </div>
        <div class="kpi-card">
          <span class="kpi-num" style="color: var(--body-color);"
            >{pulse.pulse.skills}</span
          >
          <span class="kpi-label">Skills</span>
        </div>
      </section>

      <!-- ═══ MBS BALANCE ═══ -->
      <section class="section--tight">
        <h2>Mind · Body · Soul</h2>
        <p class="section-note">
          Three layers, one ecosystem. <strong>The Mind is currently dominating. That's honest.</strong> The body and soul are catching up as the architecture solidifies.
        </p>
        <div class="mbs-grid">
          <div class="mbs-card mbs-mind">
            <div class="mbs-icon">🔵</div>
            <div class="mbs-name">Mind</div>
            <div class="mbs-desc">Research, protocols, intelligence</div>
            <div class="mbs-stat">
              <span class="mbs-num">69%</span>
              <span class="mbs-sub">delivered</span>
            </div>
          </div>
          <div class="mbs-card mbs-soul">
            <div class="mbs-icon">🟡</div>
            <div class="mbs-name">Soul</div>
            <div class="mbs-desc">Identity, philosophy, governance</div>
            <div class="mbs-stat">
              <span class="mbs-num">45%</span>
              <span class="mbs-sub">delivered</span>
            </div>
          </div>
          <div class="mbs-card mbs-body">
            <div class="mbs-icon">🟢</div>
            <div class="mbs-name">Body</div>
            <div class="mbs-desc">Code, books, publications</div>
            <div class="mbs-stat">
              <span class="mbs-num">43%</span>
              <span class="mbs-sub">delivered</span>
            </div>
          </div>
        </div>
      </section>

      <div class="divider"><img src="/logo-h.svg" alt="ஃ" /></div>

      <!-- ═══ GIT PULSE ═══ -->
      <section class="section--tight">
        <h2>Git Pulse</h2>
        <p class="section-note">
          Engineering velocity across 16 public repositories on <a
            href="https://github.com/synthanai"
            target="_blank"
            rel="noopener">GitHub</a
          >.
        </p>

        <div class="git-stats">
          <div class="git-stat">
            <span class="git-num">16,890</span>
            <span class="git-label">Files tracked</span>
          </div>
          <div class="git-stat">
            <span class="git-num">1.02M</span>
            <span class="git-label">Lines of content</span>
          </div>
          <div class="git-stat">
            <span class="git-num">4.5</span>
            <span class="git-label">Months active</span>
          </div>
          <div class="git-stat">
            <span class="git-num">233</span>
            <span class="git-label">Commits/month</span>
          </div>
        </div>

        <div class="composition-bar">
          <div
            class="comp-seg comp-md"
            style="width:89.3%;"
            title=".md (15,095)"
          >
          </div>
          <div
            class="comp-seg comp-json"
            style="width:4.6%;"
            title=".json (771)"
          >
          </div>
          <div class="comp-seg comp-txt" style="width:1.8%;" title=".txt (300)">
          </div>
          <div class="comp-seg comp-py" style="width:1.2%;" title=".py (204)">
          </div>
          <div
            class="comp-seg comp-html"
            style="width:1.1%;"
            title=".html (180)"
          >
          </div>
          <div
            class="comp-seg comp-other"
            style="width:2%;"
            title="Other (151)"
          >
          </div>
        </div>
        <p class="composition-note">
          89% Markdown. This is a knowledge base that happens to have code, not
          a codebase that has docs.
        </p>
      </section>

      <!-- ═══ PUBLIC REPOS ═══ -->
      <section class="section--tight">
        <h2>Public Repositories</h2>
        <p class="section-note">
          16 open-source repositories on <a
            href="https://github.com/synthanai"
            target="_blank"
            rel="noopener">GitHub</a
          >.
        </p>
        <div class="repo-grid">
          <div class="repo-chip">
            <span class="repo-dot repo-dot--live"></span>spar-kit
          </div>
          <div class="repo-chip">
            <span class="repo-dot repo-dot--live"></span>agentic-kit
          </div>
          <div class="repo-chip">
            <span class="repo-dot repo-dot--live"></span>decision-moment-graph
          </div>
          <div class="repo-chip">
            <span class="repo-dot repo-dot--live"></span>resonance-kit
          </div>
          <div class="repo-chip">
            <span class="repo-dot repo-dot--live"></span>ramp-kit
          </div>
          <div class="repo-chip">
            <span class="repo-dot repo-dot--live"></span>vault-kit
          </div>
          <div class="repo-chip">
            <span class="repo-dot repo-dot--live"></span>steal-kit
          </div>
          <div class="repo-chip">
            <span class="repo-dot repo-dot--live"></span>student-kit
          </div>
          <div class="repo-chip">
            <span class="repo-dot repo-dot--live"></span>intent-of-thought
          </div>
          <div class="repo-chip">
            <span class="repo-dot repo-dot--live"
            ></span>intent-of-thought-lifecycle
          </div>
          <div class="repo-chip">
            <span class="repo-dot repo-dot--live"
            ></span>decision-moment-standard
          </div>
          <div class="repo-chip">
            <span class="repo-dot repo-dot--live"></span>naveenriaz.com
          </div>
          <div class="repo-chip">
            <span class="repo-dot repo-dot--live"></span>agentic-wasm
          </div>
          <div class="repo-chip">
            <span class="repo-dot repo-dot--live"
            ></span>book-production-pipeline-template
          </div>
          <div class="repo-chip">
            <span class="repo-dot repo-dot--live"></span>article-search-by-topic
          </div>
          <div class="repo-chip">
            <span class="repo-dot repo-dot--live"></span>.github
          </div>
        </div>
      </section>

      <!-- ═══ PRIVATE REPO ═══ -->
      <section class="section--tight">
        <h2>Private Monorepo</h2>
        <p class="section-note">
          The SYNTHAI master repository: all research, books, protocols, and
          tooling in one place.
        </p>
        <div class="git-stats">
          <div class="git-stat">
            <span class="git-num"
              >{pulse.pulse.totalCommits.toLocaleString()}</span
            >
            <span class="git-label">Commits</span>
          </div>
          <div class="git-stat">
            <span class="git-num">16,890</span>
            <span class="git-label">Files</span>
          </div>
          <div class="git-stat">
            <span class="git-num">1.02M</span>
            <span class="git-label">Lines</span>
          </div>
          <div class="git-stat">
            <span class="git-num"
              >{pulse.pulse.researchFiles.toLocaleString()}</span
            >
            <span class="git-label">Research files</span>
          </div>
        </div>
      </section>

      <div class="divider"><img src="/logo-h.svg" alt="ஃ" /></div>

      <!-- ═══ METABOLIC WASTE ═══ -->
      <section class="section--tight">
        <h2>Metabolic Waste</h2>
        <p class="section-note">
          Living systems molt. This is what I have officially archived, deprecated, or let die so the rest of the system can breathe.
        </p>
        <div class="git-stats" style="grid-template-columns: repeat(3, 1fr); border-color: rgba(255,255,255,0.02) !important;">
          <div class="git-stat" style="opacity: 0.6; background: rgba(0,0,0,0.2);">
            <span class="git-num" style="color: var(--text-muted)">18</span>
            <span class="git-label">Archived Repositories</span>
          </div>
          <div class="git-stat" style="opacity: 0.6; background: rgba(0,0,0,0.2);">
            <span class="git-num" style="color: var(--text-muted)">4</span>
            <span class="git-label">Deprecated Cognitive Patterns</span>
          </div>
          <div class="git-stat" style="opacity: 0.6; background: rgba(0,0,0,0.2);">
            <span class="git-num" style="color: var(--text-muted)">12</span>
            <span class="git-label">Abandoned Book Chapters</span>
          </div>
        </div>
      </section>

      <TamilRoot
        tamil="துடிப்பு"
        transliteration="Thudippu"
        meaning="Pulse, heartbeat, vital force. The rhythm that proves something is alive."
        kural={`ஊக்க முடையான் ஒடுக்கம் பொருதகர்\nதாக்கற் குப்பொற்றுத் தவிர்ந்து.`}
        kuralNumber={486}
        kuralTranslation="The restraint of the resolute is like a charging ram pausing before it strikes: calculated, not passive."
      />
    </main>

    <Footer />
  </body>
</html>

<style>
  /* ═══ KPI Grid ═══ */
  .pulse-kpis {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    margin: var(--space-xl) 0;
  }

  .kpi-card {
    text-align: center;
    padding: var(--space-lg) var(--space-sm);
    background: var(--bg-secondary);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 10px;
    transition: border-color var(--transition-base);
  }

  .kpi-card:hover {
    border-color: rgba(255, 255, 255, 0.1);
  }

  .kpi-num {
    display: block;
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .kpi-label {
    display: block;
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: var(--space-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ═══ MBS Grid ═══ */
  .mbs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    margin: var(--space-lg) 0;
  }

  .mbs-card {
    padding: var(--space-lg);
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    text-align: center;
    transition: transform var(--transition-base);
  }

  .mbs-card:hover {
    transform: translateY(-2px);
  }

  .mbs-soul {
    background: linear-gradient(
      180deg,
      rgba(212, 168, 67, 0.08),
      var(--bg-secondary)
    );
    border-color: rgba(212, 168, 67, 0.2);
  }
  .mbs-mind {
    background: linear-gradient(
      180deg,
      rgba(40, 116, 166, 0.08),
      var(--bg-secondary)
    );
    border-color: rgba(40, 116, 166, 0.2);
  }
  .mbs-body {
    background: linear-gradient(
      180deg,
      rgba(39, 174, 96, 0.08),
      var(--bg-secondary)
    );
    border-color: rgba(39, 174, 96, 0.2);
  }

  .mbs-icon {
    font-size: 1.4rem;
    margin-bottom: var(--space-xs);
  }
  .mbs-name {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.1rem;
  }
  .mbs-desc {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-top: 2px;
  }
  .mbs-stat {
    margin-top: var(--space-md);
  }
  .mbs-num {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.8rem;
    letter-spacing: -0.03em;
  }
  .mbs-sub {
    display: block;
    font-size: 0.68rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .mbs-soul .mbs-num {
    color: var(--soul-color);
  }
  .mbs-mind .mbs-num {
    color: var(--mind-color);
  }
  .mbs-body .mbs-num {
    color: var(--body-color);
  }

  /* ═══ Git Stats ═══ */
  .git-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
    margin: var(--space-lg) 0;
  }

  .git-stat {
    text-align: center;
    padding: var(--space-md);
    background: var(--bg-secondary);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 8px;
  }

  .git-num {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--body-color);
    letter-spacing: -0.02em;
  }

  .git-label {
    display: block;
    font-size: 0.68rem;
    color: var(--text-muted);
    margin-top: 2px;
  }

  /* ═══ Composition Bar ═══ */
  .composition-bar {
    display: flex;
    height: 24px;
    border-radius: 6px;
    overflow: hidden;
    gap: 1px;
    margin: var(--space-md) 0 var(--space-sm);
  }

  .comp-seg {
    transition: opacity var(--transition-fast);
    cursor: default;
  }
  .comp-seg:hover {
    opacity: 0.8;
  }
  .comp-md {
    background: var(--mind-color);
  }
  .comp-json {
    background: var(--soul-color);
  }
  .comp-txt {
    background: var(--body-color);
  }
  .comp-py {
    background: var(--vibe-color);
    opacity: 0.7;
  }
  .comp-html {
    background: var(--soul-color);
    opacity: 0.6;
  }
  .comp-other {
    background: rgba(255, 255, 255, 0.15);
  }

  .composition-note {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .section-note {
    font-size: 0.82rem;
    color: var(--text-dim);
    margin-bottom: var(--space-md);
  }

  .section-note a {
    color: var(--body-color);
  }

  /* ═══ Repo Grid ═══ */
  .repo-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin: var(--space-md) 0;
  }

  .repo-chip {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: var(--bg-secondary);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-primary);
    transition: border-color var(--transition-base);
  }

  .repo-chip:hover {
    border-color: rgba(39, 174, 96, 0.3);
  }

  .repo-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .repo-dot--live {
    background: var(--body-color);
  }

  /* ═══ Knowledge Items ═══ */
  .ki-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-sm);
    margin: var(--space-md) 0;
  }

  .ki-card {
    padding: var(--space-md);
    background: var(--bg-secondary);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 8px;
    transition: border-color var(--transition-base);
  }

  .ki-card:hover {
    border-color: rgba(255, 255, 255, 0.1);
  }

  .ki-title {
    font-weight: 600;
    font-size: 0.78rem;
    color: var(--text-primary);
    margin-bottom: 4px;
    line-height: 1.3;
  }

  .ki-summary {
    font-size: 0.7rem;
    color: var(--text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ═══ Responsive ═══ */
  @media (max-width: 768px) {
    .pulse-kpis {
      grid-template-columns: repeat(2, 1fr);
    }
    .mbs-grid {
      grid-template-columns: 1fr;
    }
    .git-stats {
      grid-template-columns: repeat(2, 1fr);
    }
    .ki-grid {
      grid-template-columns: 1fr;
    }
    .repo-row {
      grid-template-columns: 140px 30px 1fr;
    }
    .kpi-num {
      font-size: 1.6rem;
    }
    .mbs-num {
      font-size: 1.4rem;
    }
  }
</style>
