---
import Page from "../layouts/Page.astro";
import TamilRoot from "../components/TamilRoot.astro";

// Load pulse data
let pulseData: any = null;
try {
  pulseData = await import("../data/pulse.json");
} catch (e) {
  pulseData = null;
}
const raw = pulseData?.default || pulseData;
const pulse = raw?.pulse || null;
const generatedAt = raw?.generatedAt || null;
---

<Page
  title="The Pulse"
  description="This site is alive. It reads 22 repositories, thousands of files, and rebuilds itself with every scan."
  activeNav="pulse"
>
  <section class="pulse-hero">
    <!-- Ambient orb glow -->
    <div
      class="orb"
      style="width:500px;height:500px;background:var(--body-color);top:-150px;left:50%;transform:translateX(-50%);opacity:0.2;"
    >
    </div>

    <div class="container container--narrow" style="text-align:center;">
      <span class="pulse-label">The Pulse</span>
      <h1>The Living <span class="gt">Metrics</span></h1>
      <p class="pulse-desc">
        Most websites are snapshots. Static pages built once, deployed,
        forgotten. This one breathes. A scanner reads the entire ecosystem,
        extracts metrics, maps connections, and feeds the data into every page
        you see.
      </p>
    </div>
  </section>

  <div class="proof-banner">
    <a href="/work/" class="proof-banner-link">
      See the full Proof of Work: Soul → Mind → Body →
    </a>
  </div>

  <section class="section--tight">
    <div class="container container--narrow">
      <TamilRoot
        tamil="துடிப்பு"
        transliteration="Thudippu"
        meaning="Pulse. A living system's vital signs. This site reads itself, measures its own health, and tells you what is alive."
        tamilMeaning="ஒரு உயிர்ப்பான அமைப்பின் உயிர்நாடி. இந்த தளம் தன்னைத்தானே படிக்கிறது, தனது ஆரோக்கியத்தை அளவிடுகிறது, உயிர்ப்பாக இருப்பதைச் சொல்கிறது."
        kural="அன்பிலார் எல்லாம் தமக்குரியர் அன்புடையார் என்பும் உரியர் பிறர்க்கு."
        kuralNumber={312}
        kuralTranslation="The loveless belong only to themselves. The loving belong to others, even to their bones."
      />
    </div>
  </section>

  <section class="section--tight">
    <div class="container">
      <h2 class="section-label">How It Works</h2>
      <div class="grid-3">
        <div class="card card--body">
          <h3>1. Scan</h3>
          <p>
            A Node.js scanner traverses 22 repositories, counting files, reading
            commit histories, indexing knowledge items. It sees the whole
            nebula.
          </p>
        </div>

        <div class="card card--mind">
          <h3>2. Map</h3>
          <p>
            Each concept is classified by dimension (Think, Work, Play), linked
            to its neighbors, and assigned a reveal status: stealth, emerging,
            or revealed.
          </p>
        </div>

        <div class="card card--soul">
          <h3>3. Feed</h3>
          <p>
            The scanner outputs <code>pulse.json</code> and <code
              >concepts.json</code
            >. Every component on this site reads from these files. The data is
            the design.
          </p>
        </div>
      </div>
    </div>
  </section>

  {
    pulse && (
      <section class="section--tight">
        <div class="container">
          <h2 class="section-label">Current Pulse</h2>
          <div class="pulse-grid">
            <div class="pulse-stat">
              <span class="pulse-number" style="color:var(--body-color);">
                {pulse.repos}
              </span>
              <span class="pulse-unit">Repositories</span>
            </div>

            <div class="pulse-stat">
              <span class="pulse-number" style="color:var(--mind-color);">
                {pulse.researchFiles?.toLocaleString()}
              </span>
              <span class="pulse-unit">Research Files</span>
            </div>

            <div class="pulse-stat">
              <span class="pulse-number" style="color:var(--soul-color);">
                {pulse.bookChapters?.toLocaleString()}
              </span>
              <span class="pulse-unit">Book Chapters</span>
            </div>

            <div class="pulse-stat">
              <span class="pulse-number" style="color:var(--body-color);">
                {pulse.totalCommits?.toLocaleString()}
              </span>
              <span class="pulse-unit">Commits</span>
            </div>

            <div class="pulse-stat">
              <span class="pulse-number" style="color:var(--mind-color);">
                {pulse.knowledgeItems}
              </span>
              <span class="pulse-unit">Knowledge Items</span>
            </div>

            <div class="pulse-stat">
              <span class="pulse-number" style="color:var(--soul-color);">
                {pulse.workflows}
              </span>
              <span class="pulse-unit">Workflows</span>
            </div>
          </div>

          <p class="pulse-timestamp">
            Last scan:{" "}
            {generatedAt
              ? new Date(generatedAt).toLocaleDateString("en-AU", {
                  day: "numeric",
                  month: "short",
                  year: "numeric",
                })
              : "Unknown"}
          </p>
        </div>
      </section>
    )
  }

  <section class="section--tight">
    <div class="container container--narrow">
      <div class="manifesto">
        <h2>Why Does This <span class="gt">Matter</span>?</h2>
        <p>
          A living site cannot lie about its activity. The numbers are not
          curated. They are counted. If I stop writing, the pulse shows it. If I
          build something new, the constellation updates.
        </p>
        <p>
          This is not a portfolio that ages. It is a mirror that reflects the
          current state of the work, updated with every scan. The site <em
            >is</em
          > the work.
        </p>
      </div>
    </div>
  </section>
</Page>

<style>
  .pulse-hero {
    padding: var(--space-4xl) 0 var(--space-2xl);
    position: relative;
    overflow: hidden;
  }

  .pulse-label {
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--body-color);
    margin-bottom: var(--space-sm);
    display: block;
  }

  .pulse-desc {
    max-width: 600px;
    margin: var(--space-md) auto 0;
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .section-label {
    font-family: var(--font-label);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-lg);
  }

  .pulse-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .pulse-stat {
    background: var(--bg-card);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: var(--border-radius);
    padding: var(--space-xl) var(--space-lg);
    text-align: center;
  }

  .pulse-number {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 800;
    display: block;
    line-height: 1;
  }

  .pulse-unit {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-top: var(--space-xs);
    display: block;
  }

  .pulse-timestamp {
    text-align: center;
    margin-top: var(--space-lg);
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  @media (max-width: 768px) {
    .pulse-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .pulse-grid {
      grid-template-columns: 1fr;
    }
  }

  .proof-banner {
    text-align: center;
    padding: var(--space-md) 0;
  }

  .proof-banner-link {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    padding: var(--space-sm) var(--space-xl);
    border: 1px solid var(--accent-border);
    border-radius: 20px;
    transition: all var(--transition-base);
    text-decoration: none;
  }

  .proof-banner-link:hover {
    background: rgba(196, 149, 106, 0.1);
    border-color: var(--accent);
    box-shadow: 0 4px 16px rgba(196, 149, 106, 0.12);
  }
</style>
