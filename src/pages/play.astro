---
/**
 * Play Page — Layer 1
 * Who I am. CORE identity, CliftonStrengths, SYNTHAI philosophy reveal, Tamil roots.
 * Personal voice. SYNTHAI named but not explained.
 */
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import TamilRoot from "../components/TamilRoot.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Play | Naveen Riaz</title>
    <meta
      name="description"
      content="Who I am. Tamil roots, identity architecture, and the philosophy that governs everything I build."
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Play | Naveen Riaz" />
    <meta property="og:description" content="Who I am. Tamil roots, identity architecture, and the philosophy that governs everything I build." />
    <meta property="og:image" content="https://naveenriaz.com/og-image.png" />
    <meta property="og:url" content="https://naveenriaz.com/play/" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="section-play">
    <Header activeNav="play" />

    <main class="container container--narrow">
      <section class="page-hero section">
        <h1>Play</h1>
        <p class="page-subtitle">Who I am.</p>
        <p>
          Play is where I live. My Soulful Identity. <br />Tamil roots,
          philosophical detours, and the identity architecture behind everything
          I build. <br />This is not a résumé. It is a map of the patterns that
          make me, me.
        </p>
      </section>

      <!-- Section 1: CORE Identity -->
      <section class="section--tight">
        <h2>CORE</h2><br />
        <p class="section-hook">The four dimensions that define me.</p>
        <br />
        <div class="core-grid">
          <div class="core-card">
            <div class="core-label">Calling</div>
            <h4>The Pattern Connector</h4>
            <p>
              I connect patterns from unrelated domains. Ancient wisdom meets AI
              architecture. Decision science meets handwriting. The connection
              is the creation.
            </p>
          </div>

          <div class="core-card">
            <div class="core-label">Origin</div>
            <h4>The Late Starter</h4>
            <p>
              Deep-thinking introvert, often set aside. A "delayed" trajectory
              that turned out to be a preparation sequence. The delay was the
              curriculum.
            </p>
          </div>

          <div class="core-card">
            <div class="core-label">Reason</div>
            <h4>The Living System Curator</h4>
            <p>
              I believe every organisation, community, product, and service is
              alive. Nurture its Mind, Body, and Soul, and watch it thrive.
            </p>
          </div>

          <div class="core-card">
            <div class="core-label">Endurance</div>
            <h4>The Sovereign Flight</h4>
            <p>
              I am building something that outlasts me. Not a product. Not a
              company. A way of seeing the world that others can carry forward.
            </p>
          </div>
        </div>
      </section>

      <div class="divider"><img src="/logo-h.svg" alt="ஃ" /></div>

      <!-- Section 2: CliftonStrengths -->
      <section class="section--tight">
        <h2>How I'm Wired</h2><br />
        <p class="section-hook">
          4 of my top 5 strengths are Strategic Thinking. <br />Zero
          Influencing. Zero Relationship Building. <br />I don't persuade, I
          pattern-match. I don't network, I synthesise.
        </p>
        <br />
        <div class="strengths-row">
          <div class="strength">
            <span class="strength-rank">1</span>
            <span class="strength-name">Ideation</span>
          </div>
          <div class="strength">
            <span class="strength-rank">2</span>
            <span class="strength-name">Strategic</span>
          </div>
          <div class="strength">
            <span class="strength-rank">3</span>
            <span class="strength-name">Achiever</span>
          </div>
          <div class="strength">
            <span class="strength-rank">4</span>
            <span class="strength-name">Learner</span>
          </div>
          <div class="strength">
            <span class="strength-rank">5</span>
            <span class="strength-name">Futuristic</span>
          </div>
        </div>

        <p class="strengths-footnote">
          CliftonStrengths (Gallup), Certified March 2025
        </p>
      </section>

      <div class="divider"><img src="/logo-h.svg" alt="ஃ" /></div>

      <!-- Section 3: SYNTHAI Reveal -->
      <section class="section--tight synthai-reveal">
        <h2>The Governing Philosophy</h2><br />
        <p>
          There is a philosophy behind everything on this site. <br />The
          reasoning tools. The decision frameworks. The cross-domain collisions.
          Even this page.
        </p><br />
        <blockquote class="reveal-quote">
          I call it <strong>SYNTHAI</strong>, from the Tamil
          <span class="tamil">சிந்தை</span>: mind, thought, intellect.
          <br /><br />
          Everything we build is Alive!
          <br />Every organisation.
          <br />Every community.
          <br />Every product.
          <br />Every service.
          <br />
          Nurture its <span class="c-mind">Mind</span>,
          <span class="c-body">Body</span> &amp;
          <span class="c-soul">Soul</span>.
          <br />
          Watch it thrive!
          <br /><br />
          <em>This site is a living proof of that belief.</em>
        </blockquote>
      </section>

      <div class="divider"><img src="/logo-h.svg" alt="ஃ" /></div>

      <!-- Section 4: Tamil Roots -->
      <section class="section--tight">
        <h2>Tamil Roots</h2><br />
        <p>
          I am Indian Tamil. <br />My thinking is grounded in 2000 years <br
          />of Tamil literature, philosophy, and wisdom. <br /><br />The
          Thirukkural is my compass. <br />Every page on this site carries <br
          />a Tamil root word and a Kural couplet, <br />as a foundation.
        </p>
        <p>
          Tamil is not ornamental but architectural. <br />The concepts that
          govern my work: <br />
          <div class="c-mind">சிந்தை (Cintai, mind)</div>
          <div class="c-body">செயல் (Seyal, body)</div>
          <div class="c-soul">ஆன்மா (Aanma, soul)</div>
          <div class="c-vibe">ஒத்திசை (Otticai, vibe)</div>
        </p>
      </section>

      <TamilRoot
        tamil="ஆன்மா"
        transliteration="Aanma"
        meaning="Soul, the animating principle. The part of a living system that cannot be measured, only felt."
        kural={`உள்ளம் உடைமை உடைமை பொருளுடைமை\nநில்லாது நீங்கி விடும்.`}
        kuralNumber={592}
        kuralTranslation="The wealth of the mind endures. All other wealth will depart."
      />
    </main>

    <Footer />
  </body>
</html>
