---
/**
 * PIC — AI Profiling (PIC Framework)
 * Pattern: methodology-hero (centered) + 3x3 matrix + PIC layers
 * Source: student-kit/workshops/ai-profiling-seminar
 */
import Page from "../../layouts/Page.astro";
import TamilRoot from "../../components/TamilRoot.astro";

const matrix = [
    {
        domain: "🧠 Personal",
        desc: "Your inner operating system",
        input: "How you learn",
        process: "How you think",
        output: "How you express",
    },
    {
        domain: "🤝 Social",
        desc: "Your social interface",
        input: "How you read people",
        process: "How you navigate relationships",
        output: "How you communicate",
    },
    {
        domain: "💼 Professional",
        desc: "Your professional engine",
        input: "How you absorb work knowledge",
        process: "How you solve problems",
        output: "How you deliver results",
    },
];

const picLayers = [
    {
        letter: "P",
        name: "Persona",
        question: "Who are you?",
        desc: "Your cognitive fingerprint across all 9 cells. Not what you do, but how you think, learn, and express.",
        color: "mind",
    },
    {
        letter: "I",
        name: "Interface",
        question: "How should AI serve you?",
        desc: "Format, tone, depth, pacing. The instruction set that turns a generic AI into YOUR AI.",
        color: "body",
    },
    {
        letter: "C",
        name: "Compass",
        question: "How should AI grow you?",
        desc: "70% serve your strengths, 30% stretch your gaps. The AI gently pushes you beyond your defaults.",
        color: "soul",
    },
];

const seminarSections = [
    {
        time: "0:00",
        name: "The Hook",
        duration: "5 min",
        desc: "AI is coming for your skills",
    },
    {
        time: "0:05",
        name: "The Matrix",
        duration: "8 min",
        desc: "3×3 Profiling Framework",
    },
    {
        time: "0:13",
        name: "The Demo",
        duration: "10 min",
        desc: "Same question, two AIs",
    },
    {
        time: "0:23",
        name: "The Tool",
        duration: "5 min",
        desc: "Meet your Profile GPTs",
    },
    {
        time: "0:28",
        name: "Hands-On",
        duration: "20 min",
        desc: "Build your personal profile",
    },
    {
        time: "0:48",
        name: "The Reveal",
        duration: "7 min",
        desc: "Load it, test it, see the difference",
    },
    { time: "0:55", name: "The Close", duration: "5 min", desc: "What's next" },
];
---

<Page
    title="PIC"
    description="AI Profiling with the PIC Framework. Nine cells. Three layers. One AI that actually knows you."
    activeNav="pic"
>
    <section class="pic-hero">
        <div
            class="orb"
            style="width:500px;height:500px;background:var(--accent);top:-180px;left:50%;transform:translateX(-50%);opacity:0.15;"
        >
        </div>

        <div class="container">
            <span class="pic-label">PIC</span>
            <h1>Your Profile Is Your <span class="gt">Strategy</span></h1>
            <p class="pic-desc">
                In the AI era, the people who win aren't the ones who use AI the
                most. They're the ones AI understands the best.
            </p>
        </div>
    </section>

    <section class="section--tight">
        <div class="container container--narrow">
            <TamilRoot
                tamil="சுயவிவரம்"
                transliteration="Suyavivaaram"
                meaning="Self-Profile. A structured map of how you think, learn, and express, used to transform a generic AI into a personal thinking partner."
                tamilMeaning="நீங்கள் எப்படி சிந்திக்கிறீர்கள், கற்றுக்கொள்கிறீர்கள், வெளிப்படுத்துகிறீர்கள் என்பதின் கட்டமைக்கப்பட்ட வரைபடம்."
                kural={`கள்வார்க்குத் தள்ளும் உயிர்நிலை கள்வார்க்குத்
தள்ளாது புத்தே ளுளகு.`}
                kuralNumber={290}
                kuralTranslation="If you guard yourself, what greater protection do you need?"
            />
        </div>
    </section>

    <!-- The 3×3 Matrix -->
    <section class="section--tight">
        <div class="container">
            <h2 class="section-label">The 3×3 Matrix</h2>
            <p class="section-sub">
                Nine cells define how you operate. Three domains crossed with
                three stages. Each cell changes how AI works with you.
            </p>

            <div class="matrix-table">
                <table>
                    <thead>
                        <tr>
                            <th></th>
                            <th>📥 Input</th>
                            <th>⚙️ Process</th>
                            <th>📤 Output</th>
                        </tr>
                    </thead>
                    <tbody>
                        {
                            matrix.map((row) => (
                                <tr>
                                    <td class="matrix-domain">
                                        <span class="domain-emoji">
                                            {row.domain}
                                        </span>
                                    </td>
                                    <td>{row.input}</td>
                                    <td>{row.process}</td>
                                    <td>{row.output}</td>
                                </tr>
                            ))
                        }
                    </tbody>
                </table>
            </div>

            <div class="matrix-insight">
                <p>
                    <strong>Professional Output</strong> is the cell AI replaces fastest.
                    <strong>Personal Input</strong> is the cell AI can't touch. The
                    question: do you know which are your strengths and which are your
                    gaps?
                </p>
            </div>
        </div>
    </section>

    <!-- PIC Layers -->
    <section class="section--tight">
        <div class="container container--narrow">
            <h2 class="section-label">The PIC Layers</h2>
            <p class="section-sub">
                The matrix is WHAT gets profiled. PIC is HOW it becomes an AI
                instruction set.
            </p>

            <div class="pic-stack">
                {
                    picLayers.map((layer) => (
                        <div class={`pic-layer pic-layer--${layer.color}`}>
                            <div class="pic-letter">{layer.letter}</div>
                            <div class="pic-content">
                                <h3>
                                    {layer.name}
                                    <span class="pic-question">
                                        {layer.question}
                                    </span>
                                </h3>
                                <p>{layer.desc}</p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- The Seminar -->
    <section class="section--tight">
        <div class="container">
            <h2 class="section-label">The Seminar</h2>
            <p class="section-sub">
                60 minutes. Every student leaves with a working AI instruction
                set loaded into ChatGPT. Delivered February 2026.
            </p>

            <div class="seminar-timeline">
                {
                    seminarSections.map((s) => (
                        <div class="seminar-step">
                            <span class="step-time">{s.time}</span>
                            <div class="step-content">
                                <strong>{s.name}</strong>
                                <span class="step-desc">{s.desc}</span>
                            </div>
                            <span class="step-duration">{s.duration}</span>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Closing -->
    <section class="section--tight">
        <div class="container container--narrow">
            <div class="manifesto">
                <h2>The <span class="gt">Difference</span></h2>
                <p>
                    A generic AI treats you like everyone else. A profiled AI
                    knows how you learn, how you think, and how you express. It
                    serves your strengths (70%) and stretches your gaps (30%).
                </p>
                <p>
                    The profile takes 15 minutes to build. The difference lasts
                    every conversation after.
                </p>
            </div>
        </div>
    </section>
</Page>

<style>
    .pic-hero {
        padding: var(--space-4xl) 0 var(--space-2xl);
        text-align: right;
        position: relative;
        overflow: hidden;
    }

    .pic-label {
        font-family: var(--font-label);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--soul-color);
        margin-bottom: var(--space-sm);
        display: block;
    }

    .pic-desc {
        max-width: 600px;
        margin: var(--space-md) 0 0 auto;
        color: var(--text-secondary);
        font-size: 1.05rem;
        line-height: 1.7;
    }

    .section-label {
        font-family: var(--font-label);
        font-size: 1rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: var(--space-xs);
    }

    .section-sub {
        font-size: 0.9rem;
        color: var(--text-dim);
        margin-bottom: var(--space-xl);
        max-width: 560px;
    }

    /* ── 3×3 Matrix ───────────────────────────── */
    .matrix-table {
        overflow-x: auto;
        margin-bottom: var(--space-lg);
    }

    .matrix-table table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.88rem;
    }

    .matrix-table th {
        font-family: var(--font-heading);
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        color: var(--accent-light);
        padding: var(--space-md);
        text-align: center;
        border-bottom: 2px solid rgba(255, 255, 255, 0.06);
    }

    .matrix-table td {
        padding: var(--space-md);
        text-align: center;
        color: var(--text-muted);
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        line-height: 1.4;
    }

    .matrix-domain {
        font-weight: 600;
        color: var(--text-primary);
        text-align: left !important;
        white-space: nowrap;
    }

    .matrix-insight {
        background: var(--bg-card);
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-left: 3px solid var(--accent);
        border-radius: var(--border-radius);
        padding: var(--space-lg);
    }

    .matrix-insight p {
        font-size: 0.88rem;
        color: var(--text-muted);
        line-height: 1.6;
        margin: 0;
    }

    .matrix-insight strong {
        color: var(--text-primary);
    }

    /* ── PIC Stack ────────────────────────────── */
    .pic-stack {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .pic-layer {
        display: flex;
        align-items: flex-start;
        gap: var(--space-lg);
        padding: var(--space-lg) var(--space-xl);
        border: 1px solid rgba(255, 255, 255, 0.04);
    }

    .pic-layer--mind {
        border-radius: var(--border-radius) var(--border-radius) 0 0;
        border-left: 4px solid var(--mind-color);
        border-bottom: none;
    }
    .pic-layer--body {
        border-left: 4px solid var(--body-color);
        border-bottom: none;
    }
    .pic-layer--soul {
        border-radius: 0 0 var(--border-radius) var(--border-radius);
        border-left: 4px solid var(--soul-color);
    }

    .pic-letter {
        font-family: var(--font-heading);
        font-size: 1.8rem;
        font-weight: 800;
        line-height: 1;
        flex-shrink: 0;
        width: 40px;
    }

    .pic-layer--mind .pic-letter {
        color: var(--mind-color);
    }
    .pic-layer--body .pic-letter {
        color: var(--body-color);
    }
    .pic-layer--soul .pic-letter {
        color: var(--soul-color);
    }

    .pic-content h3 {
        font-size: 1rem;
        margin-bottom: var(--space-xs);
    }

    .pic-layer--mind h3 {
        color: var(--mind-color);
    }
    .pic-layer--body h3 {
        color: var(--body-color);
    }
    .pic-layer--soul h3 {
        color: var(--soul-color);
    }

    .pic-question {
        font-size: 0.72rem;
        font-weight: 400;
        color: var(--text-dim);
        margin-left: var(--space-sm);
        font-style: italic;
    }

    .pic-content p {
        font-size: 0.88rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin: 0;
    }

    /* ── Seminar Timeline ──────────────────────── */
    .seminar-timeline {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .seminar-step {
        display: flex;
        align-items: center;
        gap: var(--space-md);
        padding: var(--space-md) var(--space-lg);
        background: var(--bg-card);
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-radius: var(--border-radius);
        transition: transform var(--transition-base);
    }

    .seminar-step:hover {
        transform: translateX(4px);
    }

    .step-time {
        font-family: var(--font-heading);
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--accent);
        letter-spacing: 0.04em;
        min-width: 36px;
    }

    .step-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .step-content strong {
        font-family: var(--font-heading);
        font-size: 0.88rem;
        color: var(--text-primary);
    }

    .step-desc {
        font-size: 0.78rem;
        color: var(--text-dim);
    }

    .step-duration {
        font-size: 0.7rem;
        color: var(--text-dim);
        letter-spacing: 0.04em;
        white-space: nowrap;
    }

    /* ── Responsive ────────────────────────────── */
    @media (max-width: 768px) {
        .pic-layer {
            flex-direction: column;
            gap: var(--space-sm);
        }
        .pic-letter {
            width: auto;
        }
    }

    @media (max-width: 480px) {
        .matrix-table {
            font-size: 0.78rem;
        }
    }
</style>
