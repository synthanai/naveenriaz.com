---
/**
 * Challenge — Think You Disagree? Prove It.
 * Pattern: scaffold (Vibe sub-page)
 * The interactive layer: SPAR with the Framework
 */
import Page from "../layouts/Page.astro";
import TamilRoot from "../components/TamilRoot.astro";
---

<Page
    title="Challenge"
    description="Think you disagree? Prove it. SPAR with the Framework, not the person. Structured dialectic, open to all."
    activeNav="vibe"
>
    <section class="challenge-hero">
        <div
            class="orb"
            style="width:400px;height:400px;background:var(--mind-color);top:-120px;right:-100px;"
        >
        </div>
        <div
            class="orb"
            style="width:300px;height:300px;background:var(--soul-color);bottom:-80px;left:-80px;"
        >
        </div>

        <div class="container">
            <span class="challenge-label">Challenge</span>
            <h1>Think You <span class="gt">Disagree</span>?</h1>
            <p class="challenge-desc">
                Every claim on this site was built through structured debate.
                If you think one is wrong, don't just disagree. Prove it.
                SPAR with the framework, not the person.
            </p>
        </div>
    </section>

    <section class="section--tight">
        <div class="container container--narrow">
            <TamilRoot
                tamil="சவால்"
                transliteration="Savaal"
                meaning="Challenge. Not confrontation, but the disciplined art of testing ideas until only the strongest survive."
                tamilMeaning="மோதல் அல்ல, கருத்துக்களை வலிமையானவை மட்டுமே எஞ்சும் வரை சோதிக்கும் ஒழுங்கான கலை."
                kural={`எப்பொருள் யார்யார்வாய்க் கேட்பினும் அப்பொருள்
மெய்ப்பொருள் காண்ப தறிவு.`}
                kuralNumber={423}
                kuralTranslation="True wisdom is the ability to discern the truth in whatever anyone says."
            />
        </div>
    </section>

    <section class="section--tight">
        <div class="container">
            <div class="coming-grid">
                <div class="coming-card coming-card--mind">
                    <h3>🔵 Challenge a Claim</h3>
                    <p>
                        Every manifesto block on Think pages will have a
                        "Challenge This" button. Click it, and the SPAR protocol
                        argues why that claim might be wrong.
                    </p>
                    <span class="coming-status">Coming Soon</span>
                </div>

                <div class="coming-card coming-card--body">
                    <h3>🟢 Submit a Topic</h3>
                    <p>
                        Propose a question for a future SPAR debate. The best
                        submissions become public debates with full verdicts,
                        dissent records, and confidence scores.
                    </p>
                    <span class="coming-status">Coming Soon</span>
                </div>

                <div class="coming-card coming-card--soul">
                    <h3>🟡 Ask the Kural</h3>
                    <p>
                        An oracle of 2,000-year-old Tamil wisdom. Ask a question,
                        receive a Thirukkural with a modern interpretation.
                        Ancient pattern recognition, on demand.
                    </p>
                    <span class="coming-status">Coming Soon</span>
                </div>
            </div>
        </div>
    </section>

    <section class="section--tight">
        <div class="container container--narrow">
            <div class="manifesto">
                <h2>Why <span class="gt">Challenge</span>?</h2>
                <p>
                    Agreement is comfortable. Challenge is productive. Every
                    framework on this site was forged through collision, not
                    consensus. The SPAR protocol exists because the best ideas
                    survive friction, not applause.
                </p>
                <p>
                    This is not "Talk to Naveen." This is SPAR with the
                    Framework. The methodology speaks for itself. Your
                    perspective makes it stronger.
                </p>
            </div>
        </div>
    </section>
</Page>

<style>
    .challenge-hero {
        padding: var(--space-4xl) 0 var(--space-2xl);
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .challenge-label {
        font-family: var(--font-label);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: var(--space-sm);
        display: block;
    }

    .challenge-desc {
        max-width: 600px;
        margin: var(--space-md) auto 0;
        color: var(--text-secondary);
        font-size: 1.05rem;
        line-height: 1.7;
    }

    .coming-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: var(--space-xl);
    }

    .coming-card {
        background: var(--bg-card);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: var(--section-radius, 24px);
        padding: var(--space-xl);
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        transition:
            transform var(--transition-base),
            box-shadow var(--transition-base);
    }

    .coming-card:hover {
        transform: translateY(-4px);
    }

    .coming-card--mind {
        border-top: 3px solid var(--mind-color);
    }
    .coming-card--mind:hover {
        box-shadow: 0 12px 40px var(--mind-glow);
    }
    .coming-card--body {
        border-top: 3px solid var(--body-color);
    }
    .coming-card--body:hover {
        box-shadow: 0 12px 40px var(--body-glow);
    }
    .coming-card--soul {
        border-top: 3px solid var(--soul-color);
    }
    .coming-card--soul:hover {
        box-shadow: 0 12px 40px var(--soul-glow);
    }

    .coming-card h3 {
        font-size: 1.1rem;
    }

    .coming-card p {
        font-size: 0.9rem;
        color: var(--text-muted);
        line-height: 1.7;
    }

    .coming-status {
        font-family: var(--font-label);
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-dim);
        margin-top: auto;
    }

    @media (max-width: 480px) {
        .coming-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
