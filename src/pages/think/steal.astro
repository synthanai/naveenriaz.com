---
import Page from "../../layouts/Page.astro";
import TamilRoot from "../../components/TamilRoot.astro";

// Research corpus counts (anonymized, no names revealed)
const corpus = {
    organisations: 1587,
    persons: 215,
    concepts: 80,
    sectors: 32,
    frameworks: 40,
    theories: 25,
    events: 18,
    movements: 12,
    total: 1914,
};

const dimensions = [
    {
        label: "Organisations",
        value: corpus.organisations,
        color: "body",
        icon: "🏢",
        desc: "Companies, institutions, and systems studied across 32 sectors.",
    },
    {
        label: "Persons",
        value: corpus.persons,
        color: "mind",
        icon: "👤",
        desc: "Leaders, theorists, and practitioners whose work shaped the thinking.",
    },
    {
        label: "Concepts",
        value: corpus.concepts,
        color: "soul",
        icon: "💡",
        desc: "Frameworks, patterns, and theoretical constructs extracted and mapped.",
    },
    {
        label: "Sectors",
        value: corpus.sectors,
        color: "body",
        icon: "🌐",
        desc: "Industries and domains cross-referenced for emergence patterns.",
    },
];

const steps = [
    {
        letter: "S",
        word: "Scan",
        desc: "Gather raw intelligence. Read, watch, listen. No filters yet.",
        color: "mind",
    },
    {
        letter: "T",
        word: "Translate",
        desc: "Convert domain-specific language into portable abstractions.",
        color: "body",
    },
    {
        letter: "E",
        word: "Evaluate",
        desc: "Score relevance. Does this change how we see the problem?",
        color: "soul",
    },
    {
        letter: "A",
        word: "Abstract",
        desc: "Extract the transferable pattern. Strip the context, keep the signal.",
        color: "mind",
    },
    {
        letter: "L",
        word: "Leverage",
        desc: "Apply the stolen pattern to our own ecosystem. Ship or shelf.",
        color: "body",
    },
];
---

<Page
    title="STEAL"
    description="Learn without imitation. How patterns from 1,900+ sources became frameworks."
    activeNav="steal"
>
    <section class="steal-hero">
        <!-- Ambient orb glow -->
        <div
            class="orb"
            style="width:400px;height:400px;background:var(--mind-color);top:-120px;left:-100px;"
        >
        </div>
        <div
            class="orb"
            style="width:300px;height:300px;background:var(--body-color);bottom:-80px;right:-80px;"
        >
        </div>

        <div class="container">
            <span class="steal-label">STEAL</span>
            <h1>Learn Without <span class="gt">Imitation</span></h1>
            <p class="steal-desc">
                Copy nothing. Learn everything. Every framework I built started
                with a STEAL: scanning external intelligence, extracting
                portable patterns, and applying them to problems no one else was
                connecting.
            </p>
        </div>
    </section>

    <section class="section--tight">
        <div class="container container--narrow">
            <TamilRoot
                tamil="திருடு"
                transliteration="Thirudu"
                meaning="To steal. Not imitation, but the disciplined art of extracting transferable patterns from any domain and applying them where nobody expects."
                tamilMeaning="பிரதி எடுப்பது அல்ல, எந்த துறையிலிருந்தும் மாற்றக்கூடிய முறைகளைப் பிரித்தெடுத்து யாரும் எதிர்பார்க்காத இடத்தில் பயன்படுத்தும் ஒழுங்கான கலை."
                kural={`செவுக்குண வில்லாத போழ்து சிறிது
வயிற்றுக்கும் ஈயப் படும்.`}
                kuralNumber={412}
                kuralTranslation="When the ear finds no intellectual nourishment, even the stomach must be fed sparingly."
            />
        </div>
    </section>

    <!-- Research Corpus (Anonymized) -->
    <section class="section--tight">
        <div class="container">
            <div class="corpus-header">
                <span class="corpus-label">Research Corpus</span>
                <span class="corpus-sub">
                    {corpus.total.toLocaleString()} intelligence sources. No names
                    revealed.
                </span>
            </div>
            <div class="corpus-grid">
                {
                    dimensions.map((d, i) => (
                        <div
                            class={`corpus-card corpus-card--${d.color}`}
                            style={`animation-delay: ${i * 100}ms`}
                        >
                            <span class="corpus-icon">{d.icon}</span>
                            <span class="corpus-value">
                                {d.value.toLocaleString()}
                            </span>
                            <span class="corpus-dimension">{d.label}</span>
                            <p class="corpus-desc">{d.desc}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- How STEAL Works -->
    <section class="section--tight">
        <div class="container">
            <h2 class="section-label">How STEAL Works</h2>
            <div class="steal-steps">
                {
                    steps.map((s) => (
                        <div class={`steal-step steal-step--${s.color}`}>
                            <span class="step-letter">{s.letter}</span>
                            <div class="step-content">
                                <h3>{s.word}</h3>
                                <p>{s.desc}</p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Closing -->
    <section class="section--tight">
        <div class="container container--narrow">
            <div class="manifesto">
                <h2>Why <span class="gt">STEAL</span>?</h2>
                <p>
                    Good ideas do not respect industry boundaries. The best
                    pattern for hospital safety came from aviation checklists.
                    The best model for team dynamics came from jazz
                    improvisation. The only crime is refusing to look outside
                    your own domain.
                </p>
                <p>
                    Every entry in this corpus was scanned, translated into
                    portable abstractions, evaluated against our frameworks, and
                    either absorbed or rejected. Nothing is copied. Everything
                    is learned.
                </p>
                <a href="/challenge/" class="challenge-link">Challenge This →</a
                >
            </div>
        </div>
    </section>
</Page>

<style>
    .steal-hero {
        padding: var(--space-4xl) 0 var(--space-2xl);
        text-align: left;
        position: relative;
        overflow: hidden;
    }

    .steal-label {
        font-family: var(--font-label);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--mind-color);
        margin-bottom: var(--space-sm);
        display: block;
    }

    .steal-desc {
        max-width: 600px;
        margin: var(--space-md) 0 0;
        color: var(--text-secondary);
        font-size: 1.05rem;
        line-height: 1.7;
    }

    /* ── Corpus Grid ───────────────────────────── */
    .corpus-header {
        margin-bottom: var(--space-xl);
        text-align: center;
    }

    .corpus-label {
        font-family: var(--font-heading);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--accent);
        display: block;
        margin-bottom: var(--space-xs);
    }

    .corpus-sub {
        font-size: 0.85rem;
        color: var(--text-muted);
        font-style: italic;
    }

    .corpus-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: var(--space-lg);
    }

    .corpus-card {
        background: var(--bg-card);
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: var(--border-radius);
        padding: var(--space-xl) var(--space-lg);
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        transition:
            transform var(--transition-base),
            box-shadow var(--transition-base);
    }

    .corpus-card:hover {
        transform: translateY(-3px);
    }

    .corpus-card--mind {
        border-top: 3px solid var(--mind-color);
    }
    .corpus-card--mind:hover {
        box-shadow: 0 4px 20px var(--mind-glow);
    }
    .corpus-card--body {
        border-top: 3px solid var(--body-color);
    }
    .corpus-card--body:hover {
        box-shadow: 0 4px 20px var(--body-glow);
    }
    .corpus-card--soul {
        border-top: 3px solid var(--soul-color);
    }
    .corpus-card--soul:hover {
        box-shadow: 0 4px 20px var(--soul-glow);
    }

    .corpus-icon {
        font-size: 1.5rem;
    }

    .corpus-value {
        font-family: var(--font-heading);
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--text-primary);
        line-height: 1;
    }

    .corpus-dimension {
        font-size: 0.72rem;
        color: var(--text-muted);
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .corpus-desc {
        font-size: 0.82rem;
        color: var(--text-dim);
        line-height: 1.4;
        margin: 4px 0 0;
    }

    /* ── STEAL Steps ───────────────────────────── */
    .section-label {
        font-family: var(--font-label);
        font-size: 1rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: var(--space-lg);
    }

    .steal-steps {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        max-width: 640px;
        margin: 0 auto;
    }

    .steal-step {
        display: flex;
        gap: var(--space-lg);
        align-items: flex-start;
        background: var(--bg-card);
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: var(--border-radius);
        padding: var(--space-lg);
        transition:
            transform var(--transition-base),
            box-shadow var(--transition-base);
    }

    .steal-step:hover {
        transform: translateY(-2px);
    }

    .steal-step--mind {
        border-left: 3px solid var(--mind-color);
    }
    .steal-step--mind:hover {
        box-shadow: 0 4px 20px var(--mind-glow);
    }
    .steal-step--body {
        border-left: 3px solid var(--body-color);
    }
    .steal-step--body:hover {
        box-shadow: 0 4px 20px var(--body-glow);
    }
    .steal-step--soul {
        border-left: 3px solid var(--soul-color);
    }
    .steal-step--soul:hover {
        box-shadow: 0 4px 20px var(--soul-glow);
    }

    .step-letter {
        font-family: var(--font-heading);
        font-size: 1.6rem;
        font-weight: 800;
        min-width: 32px;
        color: var(--accent-light);
        line-height: 1;
    }

    .step-content h3 {
        font-size: 1rem;
        margin-bottom: var(--space-xs);
        color: var(--text-primary);
    }

    .step-content p {
        font-size: 0.88rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin: 0;
    }

    @media (max-width: 480px) {
        .corpus-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>
